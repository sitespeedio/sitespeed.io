/*
	X-Content-Type-Options: nosniff
	X-XSS-Protection: 1; mode=block
	Referrer-Policy: no-referrer
	Permissions-Policy: interest-cohort=()
	Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'
	Cross-Origin-Opener-Policy: same-origin
	Cross-Origin-Embedder-Policy: require-corp
	Cross-Origin-Resource-Policy: same-origin
	Cache-Control: public, max-age=0, must-revalidate, no-transform
	Strict-Transport-Security: max-age=31536000; includeSubDomains

# The scripting API reference is generated by jsdoc (clean-jsdoc-theme),
# which inlines its own bootstrap script and a small style block. We
# can't tighten this without rebuilding the theme.
/documentation/sitespeed.io/scripting/*
	Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'

# Testcase fixtures are intentionally hand-rolled HTML with inline
# content for measurement experiments. They have to stay as-is.
/testcases/*
	Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'self'

/img/*
	Cache-Control: public, max-age=31536000
/js/*
	Cache-Control: public, max-age=31536000, immutable
/css/*
	Cache-Control: public, max-age=31536000, immutable
/feed/*
	Access-Control-Allow-Origin: *
