h2 Comparison Data

table
  thead
    tr
      th Metric Name
      th Score #{compare.meta.testOptions.testType}
      th Baseline mean
      th Current mean
      th Baseline median
      th Current median
      th Baseline Std Dev
      th Current Std Dev
      th Significant Change?

    tbody
      each metricGroup, groupName in compare.metrics
        each values, metricName in metricGroup
          tr
            td
              a(href=createGraphLink(groupName, metricName)) 
                b #{groupName + '.' + metricName}
            if values.statisticalTestU === "N/A" || values.statisticalTestU === "Datasets are identical" || values.statisticalTestU === "No variability" || values.statisticalTestU === "Datasets have different lengths"
              td #{values.statisticalTestU}
            else
              td #{h.decimals(values.statisticalTestU)}
            td #{h.decimals(values.baseline.mean)}
            td #{h.decimals(values.current.mean)}
            td #{h.decimals(values.baseline.median)}
            td #{h.decimals(values.current.median)}
            td #{h.decimals(values.baseline.stdev)}
            td #{h.decimals(values.current.stdev)}
            if values.statisticalTestU === "N/A" || values.statisticalTestU === "Datasets are identical"
              td No Test Conducted
            else
              td #{values.statisticalTestU < 0.05 ? 'Yes - ' + cliffDeltaHelper(values.cliffsDelta) : 'No'}


h2 Graphs

each metricGroup, groupName in compare.metrics
  each values, metricName in metricGroup
    - var fullMetricName = groupName + '.' + metricName
    - var metricId = fullMetricName.replace(/\./g, '_')
    - var baseline = values.baseline.values
    - var current = values.current.values
    - var allValues = baseline.concat(current).filter(v => typeof v === 'number')
    - var yMin = allValues.length ? Math.min.apply(null, allValues) : 0
    - var yMax = allValues.length ? Math.max.apply(null, allValues) : 1
    - var ySpan = yMax - yMin || 1
    - var xMax = Math.max(baseline.length, current.length, 1)
    - var sortedBaseline = baseline.slice().sort((a, b) => a - b)
    - var sortedCurrent = current.slice().sort((a, b) => a - b)
    - var baseMedian = sortedBaseline.length ? sortedBaseline[Math.floor(sortedBaseline.length / 2)] : null
    - var currMedian = sortedCurrent.length ? sortedCurrent[Math.floor(sortedCurrent.length / 2)] : null
    h3 #{fullMetricName} #{values.statisticalTestU === "N/A" || values.statisticalTestU === "Datasets are identical" ? '' : values.statisticalTestU < 0.05 ? '(significant change)' : ''}
    .cmp-chart(id=`chart-${metricId}`)
      svg.cmp-svg(aria-hidden='true')&attributes({viewBox: '0 0 100 100', preserveAspectRatio: 'none'})
        if baseMedian !== null
          - var baseMedianY = (100 - (baseMedian - yMin) / ySpan * 100).toFixed(2)
          line.cmp-median.cmp-baseline(x1='0', x2='100', y1=baseMedianY, y2=baseMedianY)
        if currMedian !== null
          - var currMedianY = (100 - (currMedian - yMin) / ySpan * 100).toFixed(2)
          line.cmp-median.cmp-current(x1='0', x2='100', y1=currMedianY, y2=currMedianY)
        each v, i in baseline
          if typeof v === 'number'
            - var bx = ((i + 0.5) / xMax * 100).toFixed(2)
            - var by = (100 - (v - yMin) / ySpan * 100).toFixed(2)
            - var overlap = current[i] === v
            circle.cmp-point(class=overlap ? 'cmp-overlap' : 'cmp-baseline', cx=bx, cy=by, r='1.6')
        each v, i in current
          if typeof v === 'number' && current[i] !== baseline[i]
            - var cx2 = ((i + 0.5) / xMax * 100).toFixed(2)
            - var cy2 = (100 - (v - yMin) / ySpan * 100).toFixed(2)
            circle.cmp-point.cmp-current(cx=cx2, cy=cy2, r='1.6')
      .cmp-axis
        span.cmp-axis-y-max #{h.decimals(yMax)}
        span.cmp-axis-y-min #{h.decimals(yMin)}
        span.cmp-axis-x #{xMax} run#{xMax === 1 ? '' : 's'}
      ul.cmp-legend
        li
          span.cmp-swatch.cmp-baseline
          | Baseline: [#{values.baseline.values.join(', ')}]
        li
          span.cmp-swatch.cmp-current
          | Current: [#{values.current.values.join(', ')}]
