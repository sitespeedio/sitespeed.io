- const compare = pageInfo.data.compare.pageSummary
- const meta = compare.meta
- const baselineRaw = compare.raw.baseline
- const currentRaw = compare.raw.current
- const baselineXray = baselineRaw.pagexray.statistics
- const currentXray = currentRaw.pagexray.statistics

//- The per-metric row ids keep the old graph-anchor scheme
//- (#chart-<group>_<metric>) so deep links into the previous layout
//- keep landing on the right metric.
- var chartId = function(metricGroup, metricName) {
-   return 'chart-' + metricGroup.replace(/\./g, '_') + '_' + metricName.replace(/\./g, '_')
- }
- var cliffDeltaHelper = function(delta) {
-   const size = Math.abs(delta)
-   if (size < 0.3) return 'small effect (' + h.decimals(delta) + ')'
-   if (size < 0.5) return 'medium effect (' + h.decimals(delta) + ')'
-   return 'large effect (' + h.decimals(delta) + ')'
- }
- var isInformational = function(s) {
-   return s === 'N/A' || s === 'Datasets are identical' || s === 'No variability' || s === 'Datasets have different lengths'
- }
- var fmtCount = function(stats) {
-   if (!stats) return '–'
-   const count = stats.requests ? stats.requests.median : (stats.median !== undefined ? stats.median : '')
-   const transfer = stats.transferSize ? h.size.format(stats.transferSize.median) : null
-   const content = stats.contentSize ? h.size.format(stats.contentSize.median) : null
-   let extra = ''
-   if (transfer && content) extra = ' (' + transfer + ' / ' + content + ')'
-   else if (transfer) extra = ' (' + transfer + ')'
-   return count + extra
- }
//- Adaptive precision: whole numbers from three digits up, one decimal
//- in the tens, two below — keeps 5.593 from meeting 288 in the same
//- column with different noise levels.
- var fmtVal = function(v) {
-   if (v === null || v === undefined || Number.isNaN(v)) return '–'
-   const size = Math.abs(v)
-   if (size >= 100 || v === Math.round(v)) return String(Math.round(v))
-   if (size >= 10) return v.toFixed(1)
-   return String(Math.round(v * 100) / 100)
- }
//- The compare helper only ships a fixed set of groups (helper.js), so
//- units can be derived from group + metric name. Unknown groups (user
//- extras) get no unit rather than a guessed one.
- var metricUnit = function(groupName, metricName) {
-   if (groupName === 'timings' || groupName === 'visualMetrics' || groupName === 'userTimings' || groupName === 'elementTimings') return ' ms'
-   if (groupName === 'googleWebVitals') return metricName === 'cumulativeLayoutShift' ? '' : ' ms'
-   if (groupName === 'renderBlocking') return metricName.endsWith('ms') ? ' ms' : ''
-   if (groupName === 'cpu') return metricName === 'tasks' ? '' : ' ms'
-   return ''
- }

- const testName = meta.testOptions.testType === 'mannwhitneyu' ? 'Mann-Whitney U' : 'Wilcoxon signed-rank'
- const alternative = meta.testOptions.alternative
- const sigWord = alternative === 'greater' ? 'slower' : (alternative === 'less' ? 'faster' : 'changed')
//- A significant change is only bad news when it points the wrong way:
//- "faster" gets the good tone, "slower" the error tone. All compared
//- metrics are lower-is-better. For two-sided tests the direction
//- comes from the Cliff's delta sign per metric (positive = current
//- ranks higher = slower).
- var directionFor = function(cliffs) {
-   if (alternative === 'greater') return 'slower'
-   if (alternative === 'less') return 'faster'
-   if (cliffs > 0) return 'slower'
-   if (cliffs < 0) return 'faster'
-   return 'changed'
- }
- var toneFor = function(direction) {
-   return direction === 'faster' ? 'ok' : (direction === 'slower' ? 'error' : 'neutral')
- }

//- Count the metrics once so the verdict can say "5 of 24". Guard on
//- baseline/current existing — extras metrics can arrive half-shaped
//- when a metric is missing on one side.
- const significantMetrics = []
- let totalMetrics = 0
- for (const vGroupName in compare.metrics) {
-   const vMetricGroup = compare.metrics[vGroupName]
-   for (const vMetricName in vMetricGroup) {
-     const v = vMetricGroup[vMetricName]
-     if (!v || !v.baseline || !v.current || !Array.isArray(v.baseline.values)) continue
-     totalMetrics++
-     const vScore = v.statisticalTestU
-     if (!isInformational(vScore) && vScore < 0.05) significantMetrics.push({ name: vGroupName + '.' + vMetricName, tone: toneFor(directionFor(v.cliffsDelta)) })
-   }
- }

- const groupTitles = { timings: 'Timings', visualMetrics: 'Visual metrics', googleWebVitals: 'Google Web Vitals', renderBlocking: 'Render blocking', elementTimings: 'Element timings', userTimings: 'User timings', cpu: 'CPU long tasks', browser: 'Browser' }

a#compare
h1.cmp-title Compare

if meta.iterations < 21
  .cmp-alert.cmp-alert--warning
    | The number of iterations (#{meta.iterations}) is less than the&nbsp;
    a(href='https://en.wikipedia.org/wiki/Mann–Whitney_U_test#Calculations') recommended minimum of 21
    | . This may impact the reliability of the statistical comparison.

//- ---------------------------------------------------------------------
//- Setup strip — what was tested against what and how. One line instead
//- of the old Settings + Run setup cards; the screenshots/video live in
//- the collapsed details block below.
//- ---------------------------------------------------------------------
.cmp-setupline
  span
    span.cmp-setup-key Test
    b #{testName}
    if alternative === 'greater'
      |  · greater (is current slower/higher?)
    else if alternative === 'less'
      |  · less (is current faster/lower?)
    else
      |  · two-sided (change in either direction)
  span
    span.cmp-setup-key Iterations
    b #{meta.iterations}
  span
    span.cmp-setup-key Baseline
    | #{meta.baseline.timestamp}
  span
    span.cmp-setup-key Current
    | #{meta.current.timestamp}
  if meta.testOptions.testType === 'mannwhitneyu'
    span.cmp-setup-extra
      | method #{meta.testOptions.mannwhitneyu.method} · continuity #{meta.testOptions.mannwhitneyu.useContinuity ? 'enabled' : 'disabled'} ·&nbsp;
      a(href='https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.mannwhitneyu.html') about the test
  else if meta.testOptions.testType === 'wilcoxon'
    span.cmp-setup-extra
      | correction #{meta.testOptions.wilcoxon.correction ? 'enabled' : 'disabled'} ·&nbsp;
      a(href='https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.wilcoxon.html') about the test

//- Cards use <div> rather than <section> because the page-level tab JS
//- hides every `#tabSections section` and only un-hides the active
//- panel — nested <section> elements stay display:none.
details.cmp-run-details
  summary Run setup — screenshots, video and full results
  .cmp-runs
    each run, key in {baseline: {meta: meta.baseline, raw: baselineRaw}, current: {meta: meta.current, raw: currentRaw}}
      .cmp-run(class='cmp-run--' + key)
        .cmp-run-head
          span.cmp-run-tag(class='cmp-run-tag--' + key) #{key === 'baseline' ? 'Baseline' : 'Current'}
          span.cmp-run-timestamp #{run.meta.timestamp}
        a.cmp-run-url(href=run.meta.url) #{run.meta.alias || run.meta.url}
        if run.raw.pagexray.meta.screenshot
          a.cmp-run-thumb(href=run.raw.pagexray.meta.screenshot, target='_blank', rel='noopener')
            img(src=run.raw.pagexray.meta.screenshot, alt=key + ' screenshot', loading='lazy')
        if run.raw.pagexray.meta.video
          .cmp-run-video
            video(controls, preload='none')
              source(src=run.raw.pagexray.meta.video, type='video/mp4')
        if run.raw.pagexray.meta.result
          a.cmp-run-result(href=run.raw.pagexray.meta.result, target='_blank', rel='noopener') Open full result

//- ---------------------------------------------------------------------
//- Content breakdown — request counts and transfer sizes per resource
//- type. Answers "did the page get heavier?" before the timing story.
//- ---------------------------------------------------------------------
.cmp-card
  .cmp-card-header
    h2.cmp-card-title Content breakdown
  table.cmp-types
    thead
      tr
        th Resource
        th.cmp-types-num Baseline
        th.cmp-types-num Current
    tbody
      tr
        td Total
        td.cmp-types-num #{fmtCount(baselineXray)}
        td.cmp-types-num #{fmtCount(currentXray)}
      tr
        td HTML
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.html)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.html)}
      tr
        td JavaScript
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.javascript)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.javascript)}
      tr
        td CSS
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.css)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.css)}
      tr
        td Images
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.image)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.image)}
      tr
        td DOM elements
        td.cmp-types-num #{baselineRaw.browsertime.statistics.pageinfo.domElements.median}
        td.cmp-types-num #{currentRaw.browsertime.statistics.pageinfo.domElements.median}

//- ---------------------------------------------------------------------
//- Verdict — the headline answer, with chips that jump to the flagged
//- metrics. The legend for the strips lives here so it renders once,
//- not once per row.
//- ---------------------------------------------------------------------
.cmp-verdict
  .cmp-verdict-line
    if significantMetrics.length > 0
      b #{significantMetrics.length} of #{totalMetrics}
      |  #{significantMetrics.length === 1 ? 'metrics is' : 'metrics are'} significantly #{sigWord} compared to the baseline (p &lt; 0.05).
    else
      b None
      |  of the #{totalMetrics} compared metrics show a significant change against the baseline (p &lt; 0.05).
  if significantMetrics.length > 0
    .cmp-verdict-chips
      each sig in significantMetrics
        a.cmp-verdict-chip(class='cmp-verdict-chip--' + sig.tone, href='#' + chartId(sig.name.split('.')[0], sig.name.split('.').slice(1).join('.'))) #{sig.name}
  .cmp-legend
    span
      span.cmp-swatch.cmp-swatch--baseline
      | Baseline — each dot is one run, the tall tick is the median
    span
      span.cmp-swatch.cmp-swatch--current
      | Current

//- ---------------------------------------------------------------------
//- One row per metric: name + p-value, the distribution strip (both
//- runs on a shared value axis — run order carries no meaning for
//- independent samples, distributions do), median → median with the
//- delta, and the verdict chip. Replaces the old wide stats table and
//- the per-metric run-index scatter cards.
//- ---------------------------------------------------------------------
each metricGroup, groupName in compare.metrics
  - const groupRows = []
  - for (const rowMetricName in metricGroup) {
  -   const v = metricGroup[rowMetricName]
  -   if (v && v.baseline && v.current && Array.isArray(v.baseline.values) && Array.isArray(v.current.values)) groupRows.push({ metricName: rowMetricName, values: v })
  - }
  if groupRows.length > 0
    .cmp-group
      .cmp-group-head
        h2.cmp-group-title #{groupTitles[groupName] || groupName}
      each row in groupRows
        - const metricName = row.metricName
        - const values = row.values
        - const unit = metricUnit(groupName, metricName)
        - const score = values.statisticalTestU
        - const informational = isInformational(score)
        - const significant = !informational && score < 0.05
        - const direction = directionFor(values.cliffsDelta)
        - const tone = toneFor(direction)
        - const baseline = values.baseline.values
        - const current = values.current.values
        - const allValues = baseline.concat(current).filter(v => typeof v === 'number')
        - const lo = allValues.length > 0 ? Math.min.apply(null, allValues) : 0
        - const hi = allValues.length > 0 ? Math.max.apply(null, allValues) : 0
        - const span = hi - lo
        - const medB = values.baseline.median
        - const medC = values.current.median
        - const delta = medC - medB
        - const deltaPct = medB !== 0 ? Math.round(delta / medB * 1000) / 10 : undefined
        //- Positions are percentages with a small inset so edge dots
        //- don't clip; computed in code lines because pug's attribute
        //- parser trips on division after a bracket.
        - const pad = 4
        - const xPos = function(v) { return (pad + (v - lo) / span * (100 - 2 * pad)).toFixed(2) }
        .cmp-metric(id=chartId(groupName, metricName), class=significant ? 'cmp-metric--significant cmp-metric--' + tone : null)
          .cmp-metric-name
            b #{metricName}
            small #{informational ? 'no test' : 'p = ' + h.decimals(score)}
          .cmp-metric-strip
            if span > 0
              .cmp-strip
                .cmp-strip-rail
                  span.cmp-strip-median.cmp-strip-median--baseline(style='left:' + xPos(medB) + '%', title='Baseline median ' + fmtVal(medB) + unit)
                  each v, i in baseline
                    if typeof v === 'number'
                      - const left = xPos(v)
                      - const jitter = (i % 3 - 1) * 3
                      span.cmp-strip-dot.cmp-strip-dot--baseline(style='left:' + left + '%;margin-top:' + jitter + 'px', title='Baseline run ' + (i + 1) + ': ' + fmtVal(v) + unit)
                .cmp-strip-rail
                  span.cmp-strip-median.cmp-strip-median--current(style='left:' + xPos(medC) + '%', title='Current median ' + fmtVal(medC) + unit)
                  each v, i in current
                    if typeof v === 'number'
                      - const left = xPos(v)
                      - const jitter = (i % 3 - 1) * 3
                      span.cmp-strip-dot.cmp-strip-dot--current(style='left:' + left + '%;margin-top:' + jitter + 'px', title='Current run ' + (i + 1) + ': ' + fmtVal(v) + unit)
                .cmp-strip-axis
                  span #{fmtVal(lo)}#{unit}
                  span #{fmtVal(hi)}#{unit}
            else
              p.cmp-metric-flat
                | all #{baseline.length}+#{current.length} runs measured&nbsp;
                b #{fmtVal(lo)}#{unit}
                | &nbsp;— nothing to compare
          .cmp-metric-delta
            if span > 0
              b
                | #{fmtVal(medB)}&nbsp;
                span.cmp-arrow →
                | &nbsp;#{fmtVal(medC)}#{unit}
              if medB !== 0
                small Δ #{delta > 0 ? '+' : ''}#{fmtVal(delta)}#{unit} (#{deltaPct > 0 ? '+' : ''}#{deltaPct} %)
              else if delta !== 0
                small Δ #{delta > 0 ? '+' : ''}#{fmtVal(delta)}#{unit}
              else
                //- Both medians are zero but the runs differ — the
                //- means carry the story (flaky CPU long tasks do this).
                small mean #{fmtVal(values.baseline.mean)} → #{fmtVal(values.current.mean)}#{unit}
          .cmp-metric-chip
            if informational
              span.cmp-chip.cmp-chip--neutral #{score === 'Datasets are identical' ? 'identical runs' : String(score).toLowerCase()}
            else if significant
              span.cmp-chip(class='cmp-chip--' + tone) #{direction} · #{cliffDeltaHelper(values.cliffsDelta)}
            else
              span.cmp-chip.cmp-chip--neutral no change
