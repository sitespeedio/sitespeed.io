- const compare = pageInfo.data.compare.pageSummary
- const meta = compare.meta
- const baselineRaw = compare.raw.baseline
- const currentRaw = compare.raw.current
- const baselineXray = baselineRaw.pagexray.statistics
- const currentXray = currentRaw.pagexray.statistics

- var createGraphLink = function(metricGroup, metricName) {
-   return '#chart-' + metricGroup.replace(/\./g, '_') + '_' + metricName.replace(/\./g, '_')
- }
- var cliffDeltaHelper = function(delta) {
-   if (delta < 0.3) return 'Small effect (' + h.decimals(delta) + ')'
-   if (delta < 0.5) return 'Medium effect (' + h.decimals(delta) + ')'
-   return 'Large effect (' + h.decimals(delta) + ')'
- }
- var isInformational = function(s) {
-   return s === 'N/A' || s === 'Datasets are identical' || s === 'No variability' || s === 'Datasets have different lengths'
- }
- var fmtCount = function(stats) {
-   if (!stats) return '–'
-   const count = stats.requests ? stats.requests.median : (stats.median !== undefined ? stats.median : '')
-   const transfer = stats.transferSize ? h.size.format(stats.transferSize.median) : null
-   const content = stats.contentSize ? h.size.format(stats.contentSize.median) : null
-   let extra = ''
-   if (transfer && content) extra = ' (' + transfer + ' / ' + content + ')'
-   else if (transfer) extra = ' (' + transfer + ')'
-   return count + extra
- }

a#compare
h1.cmp-title Compare

if meta.iterations < 21
  .cmp-alert.cmp-alert--warning
    | The number of iterations (#{meta.iterations}) is less than the&nbsp;
    a(href='https://en.wikipedia.org/wiki/Mann–Whitney_U_test#Calculations') recommended minimum of 21
    | . This may impact the reliability of the statistical comparison.

p.cmp-intro
  | Statistical tests highlight whether the difference between baseline and current measurements is real or noise.
  | The Mann-Whitney U test compares independent samples (e.g. two pages or two conditions); the Wilcoxon signed-rank test compares paired samples (e.g. the same page before and after a change).

//- ---------------------------------------------------------------------
//- Settings — which test was run and how it was parameterised. Keeps the
//- knobs separate from the data so a reader can quickly answer "what is
//- this comparison even doing?" before diving into numbers.
//- ---------------------------------------------------------------------
//- Cards use <div> rather than <section> because the page-level tab JS
//- hides every `#tabSections section` and only un-hides the active
//- panel — nested <section> elements stay display:none.
.cmp-card
  .cmp-card-header
    h2.cmp-card-title Settings
  dl.cmp-meta
    dt Test type
    dd
      code= meta.testOptions.testType
    dt Alternative
    dd
      code= meta.testOptions.alternative
    dt Iterations
    dd #{meta.iterations}
    if meta.testOptions.testType === 'mannwhitneyu'
      dt Continuity
      dd #{meta.testOptions.mannwhitneyu.useContinuity ? 'enabled' : 'disabled'}
      dt Method
      dd
        code= meta.testOptions.mannwhitneyu.method
    else if meta.testOptions.testType === 'wilcoxon'
      dt Correction
      dd #{meta.testOptions.wilcoxon.correction ? 'enabled' : 'disabled'}
  p.cmp-card-help
    if meta.testOptions.alternative === 'less'
      | We test whether the current run is significantly faster/lower than the baseline.&nbsp;
    else if meta.testOptions.alternative === 'greater'
      | We test whether the current run is significantly slower/higher than the baseline.&nbsp;
    else if meta.testOptions.alternative === 'two-sided'
      | We test for change in either direction.&nbsp;
    if meta.testOptions.testType === 'mannwhitneyu'
      | More on the&nbsp;
      a(href='https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.mannwhitneyu.html') Mann-Whitney U test
      | .
    else if meta.testOptions.testType === 'wilcoxon'
      | More on the&nbsp;
      a(href='https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.wilcoxon.html') Wilcoxon test
      | .

//- ---------------------------------------------------------------------
//- Run setup — baseline and current side by side: alias / URL, when it
//- ran, and the visual artefacts (screenshot, video, full result link).
//- ---------------------------------------------------------------------
.cmp-card
  .cmp-card-header
    h2.cmp-card-title Run setup
  .cmp-runs
    each run, key in {baseline: {meta: meta.baseline, raw: baselineRaw}, current: {meta: meta.current, raw: currentRaw}}
      .cmp-run(class='cmp-run--' + key)
        .cmp-run-head
          span.cmp-run-tag(class='cmp-run-tag--' + key) #{key === 'baseline' ? 'Baseline' : 'Current'}
          span.cmp-run-timestamp #{run.meta.timestamp}
        a.cmp-run-url(href=run.meta.url) #{run.meta.alias || run.meta.url}
        if run.raw.pagexray.meta.screenshot
          a.cmp-run-thumb(href=run.raw.pagexray.meta.screenshot, target='_blank', rel='noopener')
            img(src=run.raw.pagexray.meta.screenshot, alt=key + ' screenshot', loading='lazy')
        if run.raw.pagexray.meta.video
          .cmp-run-video
            video(controls, preload='none')
              source(src=run.raw.pagexray.meta.video, type='video/mp4')
        if run.raw.pagexray.meta.result
          a.cmp-run-result(href=run.raw.pagexray.meta.result, target='_blank', rel='noopener') Open full result

//- ---------------------------------------------------------------------
//- Content breakdown — request counts and transfer sizes per resource
//- type. Pulled out of the old "Setup" table because it answers a very
//- different question ("did the page get heavier?") from the run
//- metadata above.
//- ---------------------------------------------------------------------
.cmp-card
  .cmp-card-header
    h2.cmp-card-title Content breakdown
  table.cmp-types
    thead
      tr
        th Resource
        th.cmp-types-num Baseline
        th.cmp-types-num Current
    tbody
      tr
        td Total
        td.cmp-types-num #{fmtCount(baselineXray)}
        td.cmp-types-num #{fmtCount(currentXray)}
      tr
        td HTML
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.html)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.html)}
      tr
        td JavaScript
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.javascript)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.javascript)}
      tr
        td CSS
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.css)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.css)}
      tr
        td Images
        td.cmp-types-num #{fmtCount(baselineXray.contentTypes.image)}
        td.cmp-types-num #{fmtCount(currentXray.contentTypes.image)}
      tr
        td DOM elements
        td.cmp-types-num #{baselineRaw.browsertime.statistics.pageinfo.domElements.median}
        td.cmp-types-num #{currentRaw.browsertime.statistics.pageinfo.domElements.median}

//- ---------------------------------------------------------------------
//- Comparison data — the wide stats table. Wrapped so it scrolls
//- horizontally on narrow screens instead of breaking the layout, with
//- baseline / current columns paired visually so the eye doesn't have
//- to count cells.
//- ---------------------------------------------------------------------
.cmp-card
  .cmp-card-header
    h2.cmp-card-title Comparison data
  .cmp-data-scroll
    table.cmp-data
      thead
        tr
          th(rowspan=2) Metric
          th(rowspan=2) Score #{meta.testOptions.testType}
          th.cmp-data-pair(colspan=2) Mean
          th.cmp-data-pair(colspan=2) Median
          th.cmp-data-pair(colspan=2) Std dev
          th(rowspan=2) Significant change?
        tr
          th.cmp-data-base Baseline
          th.cmp-data-curr Current
          th.cmp-data-base Baseline
          th.cmp-data-curr Current
          th.cmp-data-base Baseline
          th.cmp-data-curr Current
      tbody
        each metricGroup, groupName in compare.metrics
          each values, metricName in metricGroup
            - const score = values.statisticalTestU
            - const informational = isInformational(score)
            - const significant = !informational && score !== 'N/A' && score !== 'Datasets are identical' && score < 0.05
            tr
              td.cmp-data-metric
                a(href=createGraphLink(groupName, metricName)) #{groupName}.#{metricName}
              td.cmp-data-score #{informational ? score : h.decimals(score)}
              td.cmp-data-base #{h.decimals(values.baseline.mean)}
              td.cmp-data-curr #{h.decimals(values.current.mean)}
              td.cmp-data-base #{h.decimals(values.baseline.median)}
              td.cmp-data-curr #{h.decimals(values.current.median)}
              td.cmp-data-base #{h.decimals(values.baseline.stdev)}
              td.cmp-data-curr #{h.decimals(values.current.stdev)}
              td.cmp-data-sig
                if score === 'N/A' || score === 'Datasets are identical'
                  span.cmp-chip.cmp-chip--neutral No test
                else if significant
                  span.cmp-chip.cmp-chip--error Yes — #{cliffDeltaHelper(values.cliffsDelta)}
                else
                  span.cmp-chip.cmp-chip--ok No

//- ---------------------------------------------------------------------
//- Graphs — one card per metric, with a scatter plot rendered as
//- absolutely-positioned dots over a relative wrapper. SVG circles got
//- distorted into ellipses because the previous chart used a 100×100
//- viewBox stretched into a wide rectangle with preserveAspectRatio
//- 'none' — DOM dots stay round at any width.
//- ---------------------------------------------------------------------
.cmp-graphs
  h2.cmp-card-title Graphs

  each metricGroup, groupName in compare.metrics
    each values, metricName in metricGroup
      - const fullMetricName = groupName + '.' + metricName
      - const metricId = fullMetricName.replace(/\./g, '_')
      - const baseline = values.baseline.values
      - const current = values.current.values
      - const allValues = baseline.concat(current).filter(v => typeof v === 'number')
      - const yMin = allValues.length ? Math.min.apply(null, allValues) : 0
      - const yMax = allValues.length ? Math.max.apply(null, allValues) : 1
      - const ySpan = yMax - yMin || 1
      - const xMax = Math.max(baseline.length, current.length, 1)
      - const sortedBaseline = baseline.slice().sort((a, b) => a - b)
      - const sortedCurrent = current.slice().sort((a, b) => a - b)
      - const baseMedian = sortedBaseline.length ? sortedBaseline[Math.floor(sortedBaseline.length / 2)] : null
      - const currMedian = sortedCurrent.length ? sortedCurrent[Math.floor(sortedCurrent.length / 2)] : null
      - const score = values.statisticalTestU
      - const informational = isInformational(score)
      - const significant = !informational && score !== 'N/A' && score !== 'Datasets are identical' && score < 0.05

      //- Y-axis ticks: 5 evenly-spaced values from yMax down to yMin so
      //- the reader can read off any dot's value, not just guess between
      //- the corner badges. Each tick also drops a faint horizontal grid
      //- line across the plot.
      - const yTickCount = 5
      - const yTicks = []
      - for (let t = 0; t < yTickCount; t++) {
      -   const value = yMax - (t / (yTickCount - 1)) * ySpan
      -   yTicks.push({ value: value, top: (t / (yTickCount - 1) * 100).toFixed(2) })
      - }

      .cmp-chart-card(id='chart-' + metricId)
        .cmp-chart-header
          h3.cmp-chart-title #{fullMetricName}
          if significant
            span.cmp-chip.cmp-chip--error Significant change
        .cmp-chart-body
          .cmp-y-axis
            each t in yTicks
              span.cmp-y-tick(style='top: ' + t.top + '%') #{h.decimals(t.value)}
          .cmp-plot
            each t in yTicks
              .cmp-grid(style='top: ' + t.top + '%')
            if baseMedian !== null
              - const baseMedianTop = (100 - (baseMedian - yMin) / ySpan * 100).toFixed(2)
              .cmp-median.cmp-median--baseline(style='top: ' + baseMedianTop + '%', title='Baseline median ' + h.decimals(baseMedian))
            if currMedian !== null
              - const currMedianTop = (100 - (currMedian - yMin) / ySpan * 100).toFixed(2)
              .cmp-median.cmp-median--current(style='top: ' + currMedianTop + '%', title='Current median ' + h.decimals(currMedian))
            each v, i in baseline
              if typeof v === 'number'
                - const overlap = current[i] === v
                - const left = ((i + 0.5) / xMax * 100).toFixed(2)
                - const top = (100 - (v - yMin) / ySpan * 100).toFixed(2)
                .cmp-point(class=overlap ? 'cmp-point--overlap' : 'cmp-point--baseline', style='left: ' + left + '%; top: ' + top + '%', title='Baseline run ' + (i + 1) + ': ' + h.decimals(v))
            each v, i in current
              if typeof v === 'number' && current[i] !== baseline[i]
                - const left = ((i + 0.5) / xMax * 100).toFixed(2)
                - const top = (100 - (v - yMin) / ySpan * 100).toFixed(2)
                .cmp-point.cmp-point--current(style='left: ' + left + '%; top: ' + top + '%', title='Current run ' + (i + 1) + ': ' + h.decimals(v))
            span.cmp-axis-x #{xMax} run#{xMax === 1 ? '' : 's'}
        ul.cmp-legend
          li
            span.cmp-swatch.cmp-swatch--baseline
            span.cmp-legend-label Baseline
            span.cmp-legend-value [#{values.baseline.values.join(', ')}]
          li
            span.cmp-swatch.cmp-swatch--current
            span.cmp-legend-label Current
            span.cmp-legend-value [#{values.current.values.join(', ')}]
