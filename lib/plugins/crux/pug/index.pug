- const crux = pageInfo.data.crux.pageSummary;
- const experiences = ['loadingExperience','originLoadingExperience'];

//- p75 thresholds (web.dev/vitals) used for the KPI tile colour coding.
- const fcpClass = (v) => v == null ? '' : (v >= 3000 ? 'error' : (v >= 1800 ? 'warning' : 'ok'))
- const lcpClass = (v) => v == null ? '' : (v >= 4000 ? 'error' : (v >= 2500 ? 'warning' : 'ok'))
- const clsClass = (v) => v == null ? '' : (v >= 0.25 ? 'error' : (v >= 0.1 ? 'warning' : 'ok'))
- const inpClass = (v) => v == null ? '' : (v >= 500 ? 'error' : (v >= 200 ? 'warning' : 'ok'))
- const ttfbClass = (v) => v == null ? '' : (v >= 1800 ? 'error' : (v >= 800 ? 'warning' : 'ok'))
- const rttClass = (v) => v == null ? '' : (v >= 600 ? 'error' : (v >= 200 ? 'warning' : 'ok'))

//- Distribution pulled out of the histogram array. Returns
//- { good, ni, poor } as percentages (0–100, 2 decimals) so the
//- stacked bar can flex its segments by ratio.
- const distribution = (metric) => {
-   if (!metric || !metric.histogram) return null;
-   const get = (i) => Number((metric.histogram[i] && metric.histogram[i].density || 0) * 100);
-   const good = get(0), ni = get(1), poor = get(2);
-   return { good: good.toFixed(2), ni: ni.toFixed(2), poor: poor.toFixed(2) };
- }

mixin distroBar(metric, lowLabel, midLabel, highLabel)
  - const dist = distribution(metric)
  if dist
    .crux-distro
      .crux-distro-bar
        if Number(dist.good) > 0
          span.crux-distro-segment.crux-good(style='flex: ' + dist.good + ' 0 0', title=lowLabel + ': ' + dist.good + '%')
        if Number(dist.ni) > 0
          span.crux-distro-segment.crux-ni(style='flex: ' + dist.ni + ' 0 0', title=midLabel + ': ' + dist.ni + '%')
        if Number(dist.poor) > 0
          span.crux-distro-segment.crux-poor(style='flex: ' + dist.poor + ' 0 0', title=highLabel + ': ' + dist.poor + '%')
      .crux-distro-legend
        span.crux-distro-good #{dist.good}%
        span.crux-distro-ni #{dist.ni}%
        span.crux-distro-poor #{dist.poor}%

if experiences && (crux.loadingExperience || crux.originLoadingExperience)
  small
    ||
    each experience in experiences
      if crux[experience]
        each formFactor in Object.keys(crux[experience])
          a(href='#' + experience + '-' + formFactor) #{experience} #{formFactor} |
          | &nbsp;|&nbsp;

  a#crux
  h2 CrUx
  p.small Chrome User Experience Report (CrUx) is real-user data from opted-in Chrome users, aggregated over the last 30 days. Toggle the form factor with
    |
    code --crux.formFactor
    | .

  each experience in experiences
    if crux[experience]
      if experience === 'loadingExperience'
        h3.crux-experience-heading This page
      else
        h3.crux-experience-heading All pages on this origin

      each formFactor in Object.keys(crux[experience])
        - const ff = crux[experience][formFactor]
        if ff && ff.data
          a(id=experience + '-' + formFactor)
          - const metrics = ff.data.record.metrics
          - const period = ff.data.record.collectionPeriod
          - const fcp75 = metrics.first_contentful_paint && metrics.first_contentful_paint.percentiles.p75
          - const lcp75 = metrics.largest_contentful_paint && metrics.largest_contentful_paint.percentiles.p75
          - const cls75 = metrics.cumulative_layout_shift && metrics.cumulative_layout_shift.percentiles.p75
          - const inp75 = metrics.interaction_to_next_paint && metrics.interaction_to_next_paint.percentiles.p75
          - const ttfb75 = metrics.experimental_time_to_first_byte && metrics.experimental_time_to_first_byte.percentiles.p75
          - const rtt75 = metrics.round_trip_time && metrics.round_trip_time.percentiles.p75

          .crux-card
            .crux-card-header
              h4.crux-card-title Form factor #{formFactor}
              span.crux-card-period #{period.firstDate.year}-#{String(period.firstDate.month).padStart(2,'0')}-#{String(period.firstDate.day).padStart(2,'0')} to #{period.lastDate.year}-#{String(period.lastDate.month).padStart(2,'0')}-#{String(period.lastDate.day).padStart(2,'0')}

            //- p75 KPI tiles
            .crux-kpis
              if fcp75 != null
                .crux-kpi(class=fcpClass(fcp75))
                  span.crux-kpi-label FCP
                  span.crux-kpi-value #{h.time.ms(fcp75)}
              if lcp75 != null
                .crux-kpi(class=lcpClass(lcp75))
                  span.crux-kpi-label LCP
                  span.crux-kpi-value #{h.time.ms(lcp75)}
              if cls75 != null
                .crux-kpi(class=clsClass(Number(cls75)))
                  span.crux-kpi-label CLS
                  span.crux-kpi-value #{Number(cls75).toFixed(3)}
              if inp75 != null
                .crux-kpi(class=inpClass(inp75))
                  span.crux-kpi-label INP
                  span.crux-kpi-value #{h.time.ms(inp75)}
              if ttfb75 != null
                .crux-kpi(class=ttfbClass(ttfb75))
                  span.crux-kpi-label TTFB
                  span.crux-kpi-value #{h.time.ms(ttfb75)}
              if rtt75 != null
                .crux-kpi(class=rttClass(rtt75))
                  span.crux-kpi-label RTT
                  span.crux-kpi-value #{h.time.ms(rtt75)}

            //- Distribution stacked bars (replaces the 3×2 pie grid).
            //- Reads as: good (green) | needs improvement (amber) | poor (red).
            h5.crux-section-heading Distribution
            dl.crux-distros
              if metrics.first_contentful_paint
                dt First Contentful Paint
                dd
                  +distroBar(metrics.first_contentful_paint, 'Good', 'Needs improvement', 'Poor')
              if metrics.largest_contentful_paint
                dt Largest Contentful Paint
                dd
                  +distroBar(metrics.largest_contentful_paint, 'Good', 'Needs improvement', 'Poor')
              if metrics.cumulative_layout_shift
                dt Cumulative Layout Shift
                dd
                  +distroBar(metrics.cumulative_layout_shift, 'Good', 'Needs improvement', 'Poor')
              if metrics.interaction_to_next_paint
                dt Interaction to Next Paint
                dd
                  +distroBar(metrics.interaction_to_next_paint, 'Good', 'Needs improvement', 'Poor')
              if metrics.experimental_time_to_first_byte
                dt TTFB
                dd
                  +distroBar(metrics.experimental_time_to_first_byte, 'Good', 'Needs improvement', 'Poor')
              if metrics.round_trip_time
                dt Round Trip Time
                dd
                  +distroBar(metrics.round_trip_time, 'Low', 'Medium', 'High')

            //- Form factor / navigation type / LCP resource breakdowns
            //- — only render when CrUx returned them. Each bucket is a
            //- small horizontal bar with percentage.
            if ff.FORM_FACTORS_FRACTIONS
              h5.crux-section-heading Form factors
              .crux-bars
                - const fr = ff.FORM_FACTORS_FRACTIONS
                each pct, name in {desktop: fr.desktop, phone: fr.phone, tablet: fr.tablet}
                  - const p = Number(pct * 100)
                  .crux-bar-row
                    span.crux-bar-label #{name}
                    .crux-bar-track
                      span.crux-bar-fill(style='width: ' + p.toFixed(2) + '%')
                    span.crux-bar-value #{p.toFixed(2)}%

            if ff.NAVIGATION_TYPES_FRACTIONS
              h5.crux-section-heading Navigation types
              .crux-bars
                - const nt = ff.NAVIGATION_TYPES_FRACTIONS
                - const navItems = [['Navigate', nt.navigate], ['Navigate cache', nt.navigate_cache], ['Reload', nt.reload], ['Restore', nt.restore], ['Back/Forward', nt.back_forward], ['Back/Forward cache', nt.back_forward_cache], ['Prerender', nt.prerender]]
                each item in navItems
                  - const p = Number(item[1] * 100)
                  .crux-bar-row
                    span.crux-bar-label #{item[0]}
                    .crux-bar-track
                      span.crux-bar-fill(style='width: ' + p.toFixed(2) + '%')
                    span.crux-bar-value #{p.toFixed(2)}%

            if ff.LCP_RESOURCE_TYPES_FRACTIONS
              h5.crux-section-heading LCP resource type
              .crux-bars
                - const lr = ff.LCP_RESOURCE_TYPES_FRACTIONS
                each pct, name in {Text: lr.text, Image: lr.image}
                  - const p = Number(pct * 100)
                  .crux-bar-row
                    span.crux-bar-label #{name}
                    .crux-bar-track
                      span.crux-bar-fill(style='width: ' + p.toFixed(2) + '%')
                    span.crux-bar-value #{p.toFixed(2)}%

              h5.crux-section-heading LCP image breakdown (p75)
              dl.crux-image-breakdown
                if ff.LARGEST_CONTENTFUL_PAINT_MS
                  dt Largest Contentful Paint
                  dd #{h.time.ms(ff.LARGEST_CONTENTFUL_PAINT_MS.p75)}
                if ff.LCP_IMAGE_RESOURCE_LOAD_DURATION_MS
                  dt Image load duration
                  dd #{h.time.ms(ff.LCP_IMAGE_RESOURCE_LOAD_DURATION_MS.p75)}
                if ff.LCP_IMAGE_RESOURCE_LOAD_DELAY_MS
                  dt Image load delay
                  dd #{h.time.ms(ff.LCP_IMAGE_RESOURCE_LOAD_DELAY_MS.p75)}
                if ff.LCP_IMAGE_ELEMENT_RENDER_DELAY_MS
                  dt Image render delay
                  dd #{h.time.ms(ff.LCP_IMAGE_ELEMENT_RENDER_DELAY_MS.p75)}
                if ff.LCP_IMAGE_TTFB_MS
                  dt Image TTFB
                  dd #{h.time.ms(ff.LCP_IMAGE_TTFB_MS.p75)}

else
  p No data available in the Chrome User Experience report.
