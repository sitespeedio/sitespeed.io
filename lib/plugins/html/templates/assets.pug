extends ./layout.pug
include _tableMixins

mixin rows(assets)
  each asset in assets
    //- `count > 1` means this exact asset URL was requested across more
    //- than one page in the run — i.e. cache reuse is already happening
    //- or a candidate for it. Tinting the row makes those wins pop.
    tr(class=(asset.requestCount > 1 ? 'asset-reused' : ''))
      td.url.assetsurl(data-title='URL')
        a(href=asset.url)= h.shortAsset(asset.url)
        | &nbsp;
        a.from-page(href=asset.page + 'index.html', title='Open the page that loaded this asset') → page
      td.type-cell(data-title='type')
        if asset.type
          span(class='type-chip type-chip--' + asset.type)= asset.type
        else
          | —
      +durationCell('last modified',asset.lastModification)
      +durationCell('cache time',asset.cacheTime)
      +kbSizeCell('size', asset.size)
      +numberCell('count', asset.requestCount)

block content
  include runInfo
  if fullCount > 0
    //- Top-N assets across the run, framed as a card so the page reads
    //- in the same idiom as Toplist / Pages / Detailed. The "showing N
    //- of M" hint moves into the header meta when truncated, otherwise
    //- the chip just shows the total count.
    .listing-card
      .listing-card-header
        h3.listing-card-title Assets
        if count < fullCount
          span.listing-card-meta Top #{count} of #{fullCount}
        else
          span.listing-card-meta #{fullCount} #{fullCount === 1 ? 'asset' : 'assets'}
      .responsive
        table(data-sortable, id='assets')
          +rowHeading(['url', 'type', 'time since last modified', 'cache time', 'size (kb)', 'count'])
          +rows(topAssets)
  else
    p We are missing assets metrics, the HAR was not created.
