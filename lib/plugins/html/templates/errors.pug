extends ./layout.pug
include _tableMixins

mixin row(errors)
  each error, url in errors
    tr
      td
        - if (url !== 'generic')
          a(href=url)= url
      td
        ul
          each pageerrors, tool in error
            each myerror in pageerrors
              li #{myerror}
                b  (#{tool})

block content
  //- One framed card around the errors table so the page matches the
  //- rest of the modernised report. The count chip surfaces how many
  //- URLs reported errors at a glance.
  - const errorUrlCount = Object.keys(errors).length
  .listing-card
    .listing-card-header
      h3.listing-card-title Errors
      span.listing-card-meta #{errorUrlCount} #{errorUrlCount === 1 ? 'URL' : 'URLs'}
    .responsive
      table(data-sortable, id='errors')
        +rowHeading(['url', 'errors'])
        +row(errors)
