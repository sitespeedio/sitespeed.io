extends ./layout.pug
include _tableMixins

mixin rows(assets, showTiming)
  each asset in assets
    tr
      td.url.assetsurl(data-title='URL')
        a(href=asset.url)= h.shortAsset(asset.url)
        | &nbsp;
        a.from-page(href=asset.runPage + '.html', title='Open the iteration page where this asset was loaded') → run
      +durationCell('last modified',asset.lastModification)
      +durationCell('cache time',asset.cacheTime)
      +kbSizeCell('transfer', asset.transferSize)
      +kbSizeCell('size', asset.contentSize)
      if showTiming
        +numberCell('timing', asset.totalTime.toFixed(0))

//- Each top-N table sits in its own card so the page reads as a stack
//- of cleanly framed sections instead of a single long scroll of bare
//- tables. Quicklinks above swap the old `| A | B | C |` separator
//- strip for chip-style anchors.
mixin listingCard(id, title, count, headings, assets, showTiming)
  .listing-card(id=id)
    .listing-card-header
      h3.listing-card-title= title
      span.listing-card-meta #{count} #{count === 1 ? 'file' : 'files'}
    .responsive
      table(data-sortable)
        +rowHeading(headings)
        +rows(assets, showTiming)

block content
  include runInfo

  if (assetsBySize)
    - const topLists = ['javascript', 'image', 'css', 'html'];
    - const contentTypeNames = {javascript: 'JavaScript', image: 'image' , css: 'CSS', html : 'HTML'}
    - const headingsBySize = ['url', 'time since last modified', 'cache time', 'transfer (kb)', 'size (kb)']
    - const headingsByTime = headingsBySize.concat(['timing (ms)'])

    ul.listing-quicklinks
      each type in topLists
        if (assetsBySize[type] && assetsBySize[type].length > 1)
          li
            a(href='#' + type) Largest #{contentTypeNames[type]} files
      li
        a(href='#slowest') Slowest responses
      if options.firstParty
        li
          a(href='#largestThirdParty') Largest 3rd party responses
        li
          a(href='#slowestThirdParty') Slowest 3rd party responses

    each type in topLists
      if (assetsBySize[type] && assetsBySize[type].length > 1)
        +listingCard(type, 'Largest ' + contentTypeNames[type] + ' files', assetsBySize[type].length, headingsBySize, assetsBySize[type], false)

    .listing-card(id='slowest')
      .listing-card-header
        h3.listing-card-title Slowest responses
        span.listing-card-meta #{slowestAssets.length} #{slowestAssets.length === 1 ? 'file' : 'files'}
      p.listing-card-help These are the assets that took the longest time to download.
      .responsive
        table(data-sortable)
          +rowHeading(headingsByTime)
          +rows(slowestAssets, true)

    if options.firstParty
      +listingCard('largestThirdParty', '3rd party largest responses', thirdPartyAssetsBySize.length, headingsBySize, thirdPartyAssetsBySize, false)

      .listing-card(id='slowestThirdParty')
        .listing-card-header
          h3.listing-card-title 3rd party slowest responses
          span.listing-card-meta #{thirdPartySlowestAssets.length} #{thirdPartySlowestAssets.length === 1 ? 'file' : 'files'}
        p.listing-card-help These are the 3rd party assets that took the longest time to download.
        .responsive
          table(data-sortable)
            +rowHeading(headingsByTime)
            +rows(thirdPartySlowestAssets, true)
