include ../../_tableMixins

//- Each advice category renders as a collection of `<details>` cards
//- sorted by score ascending — most-urgent first. Native `<details>`
//- gives per-card disclosure with no JS, accessible by default.
//-
//- Per-advice severity chip (error / warn / info) and a category-level
//- severity breakdown next to the score chip surface coach-core's
//- `severity` field on the rule result, so a reader can scan urgency
//- without having to expand every card. Severity is orthogonal to
//- score: a low-weight info finding can have score 80 while a
//- high-weight error finding can have score 50, and the chips make
//- that distinction visible. The numeric score is hidden when severity
//- is `info` — those findings are advisory, the score isn't a useful
//- "how urgent is this?" signal so it just adds noise.
mixin adviceCategory(name, id, perfectMessage, node)
  a(id=id)
  - const advices = Object.entries(node.adviceList).filter(([, a]) => a.score < 100).sort(([, a], [, b]) => a.score - b.score)
  - const severityCounts = { error: 0, warn: 0, info: 0 }
  - advices.forEach(([, a]) => { if (a.severity && severityCounts[a.severity] !== undefined) severityCounts[a.severity]++ })
  .coach-section
    .coach-section-header
      h3.coach-section-title #{name}
      span.label(class=h.scoreLabel(node.score)) #{node.score}
      if advices.length > 0
        .coach-section-severity
          if severityCounts.error > 0
            span.coach-severity.coach-severity--error #{severityCounts.error} #{severityCounts.error === 1 ? 'error' : 'errors'}
          if severityCounts.warn > 0
            span.coach-severity.coach-severity--warn #{severityCounts.warn} #{severityCounts.warn === 1 ? 'warning' : 'warnings'}
          if severityCounts.info > 0
            span.coach-severity.coach-severity--info #{severityCounts.info} info
    if advices.length === 0
      p.coach-section-clear ✓ #{perfectMessage}
    else
      .coach-advices
        each entry in advices
          - const adviceName = entry[0]
          - const advice = entry[1]
          //- The id is the anchor the "What to fix first" strip links
          //- to; prefixed with the category id since coach rule names
          //- are only guaranteed unique within a category.
          details.coach-advice(id='advice-' + id + '-' + adviceName)
            summary.coach-advice-summary
              if advice.severity
                span.coach-severity(class='coach-severity--' + advice.severity) #{advice.severity}
              if advice.severity !== 'info'
                span.coach-advice-score (#{advice.score})
              span.coach-advice-title #{advice.title}
              code.coach-advice-rule #{adviceName}
            .coach-advice-body
              p.coach-advice-text #{advice.advice}
              if advice.description
                p.coach-advice-desc #{advice.description}
              if advice.offending && advice.offending.length > 0
                h5.coach-offenders-title Offenders
                if advice.offending[0].url
                  table.coach-offenders-table
                    thead
                      tr
                        th URL
                        th.number Transfer
                        th.number Content
                    tbody
                      each offender in advice.offending
                        tr
                          td
                            a(href=offender.url) #{h.shortAsset(offender.url, true)}
                          td.number #{h.size.format(offender.transferSize)}
                          td.number #{h.size.format(offender.contentSize)}
                else
                  ul.coach-offenders-list
                    each offender in advice.offending
                      if typeof offender === 'string' && offender.startsWith('http')
                        li
                          a(href=offender) #{h.shortAsset(offender, true)}
                      else
                        li #{offender}

- const advice = pageInfo.data.coach.run ? pageInfo.data.coach.run.advice : pageInfo.data.coach.pageSummary.advice;
- const coachVersion = pageInfo.data.coach.run ? pageInfo.data.coach.run.version : pageInfo.data.coach.pageSummary.version;

small
  if advice
    | |&nbsp;
    a(href='#coach-perf') Performance advice
    | &nbsp;|&nbsp;
    a(href='#coach-bestpractice') Best practice advice
    | &nbsp;|&nbsp;
    a(href='#coach-privacy') Privacy advice
    | &nbsp;|&nbsp;
    a(href='#page-info') Page info
    | &nbsp;|&nbsp;
  if advice.info.technology && advice.info.technology.length > 0 || (advice.info.thirdparty && Object.keys(advice.info.thirdparty.toolsByCategory).length > 0)
    a(href='#technology') Technologies
    | &nbsp;|&nbsp;

h2 Coach
p.small
  a(href='https://github.com/sitespeedio/coach') The coach
  | &nbsp;helps you find performance problems on your web page using web performance best practice rules. And gives you advice on privacy and best practices. Tested using Coach-core version #{coachVersion}.

//- "What to fix first" — the three most urgent advice items across all
//- categories, surfaced above the fold so the reader doesn't have to
//- scroll past the mascot and score tiles to find the actionable bad
//- news. Reuses the worst-first ordering the advice cards use (severity
//- tier, then score ascending) and renders nothing on a perfect score.
//- Same callout idiom as the CPU tab's top-offender banner.
- const sevRank = { error: 0, warn: 1, info: 2 }
- const fixFirst = []
- const collectFixes = (node, categoryId, categoryName) => { for (const [ruleName, a] of Object.entries(node.adviceList)) { if (a.score < 100) fixFirst.push({ ruleName, a, categoryId, categoryName }) } }
- collectFixes(advice.performance, 'coach-perf', 'Performance')
- collectFixes(advice.bestpractice, 'coach-bestpractice', 'Best practice')
- collectFixes(advice.privacy, 'coach-privacy', 'Privacy')
- fixFirst.sort((x, y) => (sevRank[x.a.severity] !== undefined ? sevRank[x.a.severity] : 3) - (sevRank[y.a.severity] !== undefined ? sevRank[y.a.severity] : 3) || x.a.score - y.a.score)
- const topFixes = fixFirst.slice(0, 3)
if topFixes.length > 0
  .cpu-callout.coach-fix-first
    .cpu-callout-icon(aria-hidden='true')
      svg(width='28', height='28', viewbox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
        path(d='m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z')
        path(d='M12 9v4')
        path(d='M12 17h.01')
    .cpu-callout-body
      .cpu-callout-headline What to fix first
      ul.coach-fix-first-list
        each fix in topFixes
          li.coach-fix-first-item
            if fix.a.severity
              span.coach-severity(class='coach-severity--' + fix.a.severity) #{fix.a.severity}
            a.coach-fix-first-link(href='#advice-' + fix.categoryId + '-' + fix.ruleName)= fix.a.title
            span.coach-fix-first-cat= fix.categoryName
  //- The advice cards are collapsed <details> — jumping to the anchor
  //- without opening the card would land the reader on a shut box.
  script.
    (function () {
      const links = document.querySelectorAll('.coach-fix-first-link');
      for (const link of links) {
        link.addEventListener('click', function () {
          const target = document.getElementById(this.getAttribute('href').slice(1));
          if (target && target.tagName === 'DETAILS') target.open = true;
        });
      }
    })();

.coach-summary
  .coach-summary-mascot
    a(href='https://github.com/sitespeedio/coach')
      img.coach-mascot(src= assetsPath + 'img/coach.png', alt='I am the coach')
  .coach-summary-scores
    .coach-score-tile(class=h.scoreLabel(advice.score))
      span.coach-score-label Overall
      span.coach-score-value #{advice.score}
    a.coach-score-tile(class=h.scoreLabel(advice.performance.score), href='#coach-perf')
      span.coach-score-label Performance
      span.coach-score-value #{advice.performance.score}
    a.coach-score-tile(class=h.scoreLabel(advice.bestpractice.score), href='#coach-bestpractice')
      span.coach-score-label Best practice
      span.coach-score-value #{advice.bestpractice.score}
    a.coach-score-tile(class=h.scoreLabel(advice.privacy.score), href='#coach-privacy')
      span.coach-score-label Privacy
      span.coach-score-value #{advice.privacy.score}

+adviceCategory('Performance advice', 'coach-perf', 'You have a perfect Performance score!', advice.performance)
+adviceCategory('Best practice advice', 'coach-bestpractice', 'Your best practice score is perfect!', advice.bestpractice)
+adviceCategory('Privacy advice', 'coach-privacy', 'Your privacy score is perfect!', advice.privacy)

include ./pageInfo.pug
include ./technology.pug
