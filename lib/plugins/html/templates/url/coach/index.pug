include ../../_tableMixins

//- Each advice category renders as a collection of `<details>` cards
//- sorted by score ascending — most-urgent first. Native `<details>`
//- gives per-card disclosure with no JS, accessible by default.
mixin adviceCategory(name, id, perfectMessage, node)
  a(id=id)
  - const advices = Object.entries(node.adviceList).filter(([, a]) => a.score < 100).sort(([, a], [, b]) => a.score - b.score)
  .coach-section
    .coach-section-header
      h3.coach-section-title #{name}
      span.label(class=h.scoreLabel(node.score)) #{node.score}
    if advices.length === 0
      p.coach-section-clear ✓ #{perfectMessage}
    else
      .coach-advices
        each entry in advices
          - const adviceName = entry[0]
          - const advice = entry[1]
          details.coach-advice
            summary.coach-advice-summary
              span.label(class=h.scoreLabel(advice.score)) #{advice.score}
              span.coach-advice-title #{advice.title}
              code.coach-advice-rule #{adviceName}
            .coach-advice-body
              p.coach-advice-text #{advice.advice}
              if advice.description
                p.coach-advice-desc #{advice.description}
              if advice.offending && advice.offending.length > 0
                h5.coach-offenders-title Offenders
                if advice.offending[0].url
                  table.coach-offenders-table
                    thead
                      tr
                        th URL
                        th.number Transfer
                        th.number Content
                    tbody
                      each offender in advice.offending
                        tr
                          td
                            a(href=offender.url) #{h.shortAsset(offender.url, true)}
                          td.number #{h.size.format(offender.transferSize)}
                          td.number #{h.size.format(offender.contentSize)}
                else
                  ul.coach-offenders-list
                    each offender in advice.offending
                      if typeof offender === 'string' && offender.startsWith('http')
                        li
                          a(href=offender) #{h.shortAsset(offender, true)}
                      else
                        li #{offender}

- const advice = pageInfo.data.coach.run ? pageInfo.data.coach.run.advice : pageInfo.data.coach.pageSummary.advice;
- const coachVersion = pageInfo.data.coach.run ? pageInfo.data.coach.run.version : pageInfo.data.coach.pageSummary.version;

small
  if advice
    ||
    a(href='#coach-perf') Performance advice
    | &nbsp;|&nbsp;
    a(href='#coach-bestpractice') Best practice advice
    | &nbsp;|&nbsp;
    a(href='#coach-privacy') Privacy advice
    | &nbsp;|&nbsp;
    a(href='#page-info') Page info
    | &nbsp;|&nbsp;
  if advice.info.technology && advice.info.technology.length > 0 || (advice.info.thirdparty && Object.keys(advice.info.thirdparty.toolsByCategory).length > 0)
    a(href='#technology') Technologies
    | &nbsp;|&nbsp;

h2 Coach
p.small
  a(href='https://github.com/sitespeedio/coach') The coach
  | &nbsp;helps you find performance problems on your web page using web performance best practice rules. And gives you advice on privacy and best practices. Tested using Coach-core version #{coachVersion}.

.coach-summary
  .coach-summary-mascot
    a(href='https://github.com/sitespeedio/coach')
      img.coach-mascot(src= assetsPath + 'img/coach.png', alt='I am the coach')
  .coach-summary-scores
    .coach-score-tile(class=h.scoreLabel(advice.score))
      span.coach-score-label Overall
      span.coach-score-value #{advice.score}
    a.coach-score-tile(class=h.scoreLabel(advice.performance.score), href='#coach-perf')
      span.coach-score-label Performance
      span.coach-score-value #{advice.performance.score}
    a.coach-score-tile(class=h.scoreLabel(advice.bestpractice.score), href='#coach-bestpractice')
      span.coach-score-label Best practice
      span.coach-score-value #{advice.bestpractice.score}
    a.coach-score-tile(class=h.scoreLabel(advice.privacy.score), href='#coach-privacy')
      span.coach-score-label Privacy
      span.coach-score-value #{advice.privacy.score}

+adviceCategory('Performance advice', 'coach-perf', 'You have a perfect Performance score!', advice.performance)
+adviceCategory('Best practice advice', 'coach-bestpractice', 'Your best practice score is perfect!', advice.bestpractice)
+adviceCategory('Privacy advice', 'coach-privacy', 'Your privacy score is perfect!', advice.privacy)

include ./pageInfo.pug
include ./technology.pug
