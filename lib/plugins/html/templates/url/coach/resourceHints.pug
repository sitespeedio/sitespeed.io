- let haveHints = false
each value, key in advice.info.resourceHints
  if value && value.length > 0
    - haveHints = true
if haveHints
  details.iter-group(open)
    summary.iter-group-summary
      span.iter-group-title Resource hints
    .hints-list
      each value, key in advice.info.resourceHints
        if value && value.length > 0
          .hints-group
            span.hints-group-name #{key}
            ul.hints-group-urls
              each url in value
                li.hints-group-url #{url}
