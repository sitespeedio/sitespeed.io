- const coverage = pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary && pageInfo.data.browsertime.pageSummary.coverage
- const covRunIndex = medianRun ? medianRun.runIndex - 1 : 0
- const jsCov = coverage && coverage.js ? coverage.js[covRunIndex] : undefined
- const cssCov = coverage && coverage.css ? coverage.css[covRunIndex] : undefined
- const jsFiles = jsCov && jsCov.files ? jsCov.files : []
- const cssFiles = cssCov && cssCov.files ? cssCov.files : []
- const MAX_ROWS = 25

//- Use pagexray's first-party regex when available so the split lines up
//- with the third-party tab. Falls back to "everything counts as
//- first-party" when pagexray is disabled — the breakdown then just
//- collapses to one bar, which is still honest.
- let fpRegex
- const fpRegexStr = pageInfo.data.pagexray && pageInfo.data.pagexray.pageSummary && pageInfo.data.pagexray.pageSummary.firstPartyRegEx
- if (fpRegexStr) { try { fpRegex = new RegExp(fpRegexStr) } catch (e) { fpRegex = undefined } }
- const docUrl = pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary && pageInfo.data.browsertime.pageSummary.info ? pageInfo.data.browsertime.pageSummary.info.url : undefined
- function isFirstParty(url) {
-   if (!url) return true
-   if (docUrl && url === docUrl) return true
-   if (!fpRegex) return true
-   return fpRegex.test(url)
- }
- function splitParty(files) {
-   let fp = 0, tp = 0
-   for (const f of files) {
-     if (isFirstParty(f.url)) fp += f.unusedBytes
-     else tp += f.unusedBytes
-   }
-   return { fp, tp }
- }
- const jsSplit = splitParty(jsFiles)
- const cssSplit = splitParty(cssFiles)

//- Fold same-URL entries into a single row. V8 reports every inline
//- <script> block as a separate scriptId — they all share the document
//- URL, so cnet's 15+ inline scripts otherwise show up as 15 lookalike
//- rows. Sum bytes, count occurrences, recompute unused-% from the sums
//- (averaging the percentages would weight tiny scripts the same as
//- large bundles).
- function aggregateByUrl(files) {
-   const map = new Map()
-   for (const f of files) {
-     const key = f.url || ''
-     const cur = map.get(key)
-     if (cur) {
-       cur.totalBytes += f.totalBytes
-       cur.usedBytes += f.usedBytes
-       cur.unusedBytes += f.unusedBytes
-       cur.count += 1
-     } else {
-       map.set(key, { url: key, totalBytes: f.totalBytes, usedBytes: f.usedBytes, unusedBytes: f.unusedBytes, count: 1 })
-     }
-   }
-   const out = []
-   for (const entry of map.values()) {
-     entry.unusedPercent = entry.totalBytes > 0 ? (entry.unusedBytes / entry.totalBytes) * 100 : 0
-     out.push(entry)
-   }
-   return out
- }
- const jsAgg = aggregateByUrl(jsFiles)
- const cssAgg = aggregateByUrl(cssFiles)

- const sevClass = (p) => p >= 70 ? 'cov-bar-fill--bad' : (p >= 40 ? 'cov-bar-fill--mid' : 'cov-bar-fill--ok')

a#coverage
h3.pagexray-section-heading Coverage

p
  | JavaScript and CSS coverage from the median iteration (run #{covRunIndex + 1}). For JS, Chrome's V8 profiler reports per-block execution counts — a byte is&nbsp;
  em unused
  | &nbsp;when its innermost containing range executed zero times. For CSS, Chrome's rule tracker flags every selector that no element on the page matched during the iteration. Enable with&nbsp;
  code --chrome.coverage
  | &nbsp;on every run, or&nbsp;
  code --enableProfileRun
  | &nbsp;to keep the main run's timing metrics untouched. Unused bytes still cost network, parse and compile time for no benefit. Expand the section below for the full picture.

details.cov-method
  summary How is "unused" calculated?
  .cov-method-body
    p
      | sitespeed.io drives Chrome's V8 profiler and CSS rule tracker via the DevTools Protocol — the same machinery the DevTools Coverage panel uses. The two columns are populated by two different mechanisms.
    h4 JavaScript
    p
      | Browsertime calls&nbsp;
      code Profiler.startPreciseCoverage
      | &nbsp;with detailed (block-level) mode at the start of the iteration and&nbsp;
      code Profiler.takePreciseCoverage
      | &nbsp;at the end. V8 returns nested ranges per function: an outer range covering the function body and inner ranges for sub-blocks (if/else, switch arms, ternaries). Each range has an execution count. A byte is "used" if the innermost range that covers it has count > 0, "unused" if it has count = 0 — so we catch both functions that never ran AND dead branches inside functions that did.
    h4 CSS
    p
      | Browsertime calls&nbsp;
      code CSS.startRuleUsageTracking
      | &nbsp;at the start of the iteration and&nbsp;
      code CSS.stopRuleUsageTracking
      | &nbsp;at the end. Chrome returns a flat list of rule-text ranges with a&nbsp;
      code used
      | &nbsp;flag — a rule is "used" if at least one element on the page matched it during the iteration. Both inline&nbsp;
      code &lt;style&gt;
      | &nbsp;blocks and external stylesheets are included.
    h4 What "this iteration" means
    p
      | Coverage reflects only what executed during this run. Code behind a button click stays unused unless the iteration clicked the button. The collection window opens before navigation and closes when&nbsp;
      code measure.stop()
      | &nbsp;is reached, so the only way to count interactions is to drive them between&nbsp;
      code measure.start()
      | &nbsp;and&nbsp;
      code measure.stop()
      | &nbsp;inside a&nbsp;
      a(href='https://www.sitespeed.io/documentation/sitespeed.io/scripting/') navigation script
      |  (pass a&nbsp;
      code .js
      | &nbsp;file as the input instead of a plain URL). Clicks, form fills and waits placed there all count toward "used".&nbsp;
      code --preScript
      | &nbsp;runs before the URL is loaded so it can't interact with the page being measured, and&nbsp;
      code --postScript
      | &nbsp;runs after coverage has already been collected, so neither helps here. Detailed coverage also tells V8 to skip some optimisations, which drifts timing metrics like LCP and TBT — that's why&nbsp;
      code --enableProfileRun
      | &nbsp;is the safer option for production measurement (it collects coverage in a separate iteration that doesn't count towards the medians).

if !jsCov && !cssCov
  .listing-card.cov-empty
    p No coverage data was collected for this iteration.
else
  .cov-kpis
    if jsCov
      .cov-kpi
        span.cov-kpi-label JS total
        span.cov-kpi-value #{h.size.format(jsCov.totalBytes)}
      .cov-kpi
        span.cov-kpi-label JS unused
        span.cov-kpi-value #{h.size.format(jsCov.unusedBytes)}
      .cov-kpi
        span.cov-kpi-label JS unused %
        span.cov-kpi-value #{jsCov.unusedPercent.toFixed(1)}%
    if cssCov
      .cov-kpi
        span.cov-kpi-label CSS total
        span.cov-kpi-value #{h.size.format(cssCov.totalBytes)}
      .cov-kpi
        span.cov-kpi-label CSS unused
        span.cov-kpi-value #{h.size.format(cssCov.unusedBytes)}
      .cov-kpi
        span.cov-kpi-label CSS unused %
        span.cov-kpi-value #{cssCov.unusedPercent.toFixed(1)}%

  //- First-party vs third-party unused bytes. The actionable split:
  //- first-party bundles are yours to fix; third-party waste needs a
  //- vendor conversation (or removing the script).
  if (jsCov && (jsSplit.fp || jsSplit.tp)) || (cssCov && (cssSplit.fp || cssSplit.tp))
    .listing-card
      .listing-card-header
        h3.listing-card-title Where the unused bytes live
        if fpRegex
          span.listing-card-meta first-party regex #{fpRegexStr}
        else
          span.listing-card-meta no first-party regex — counted as first-party
      .cov-split
        if jsCov && (jsSplit.fp || jsSplit.tp)
          - const jsTotal = jsSplit.fp + jsSplit.tp
          - const jsFpPct = jsTotal ? (jsSplit.fp / jsTotal * 100) : 0
          - const jsTpPct = jsTotal ? (jsSplit.tp / jsTotal * 100) : 0
          .cov-split-row
            span.cov-split-label JS unused
            .cov-split-track
              if jsFpPct > 0
                span.cov-split-fp(style='width: ' + jsFpPct.toFixed(2) + '%', title='First party: ' + h.size.format(jsSplit.fp))
              if jsTpPct > 0
                span.cov-split-tp(style='width: ' + jsTpPct.toFixed(2) + '%', title='Third party: ' + h.size.format(jsSplit.tp))
            span.cov-split-value
              span.cov-split-chip.cov-split-chip--fp First #{h.size.format(jsSplit.fp)}
              span.cov-split-chip.cov-split-chip--tp Third #{h.size.format(jsSplit.tp)}
        if cssCov && (cssSplit.fp || cssSplit.tp)
          - const cssTotal = cssSplit.fp + cssSplit.tp
          - const cssFpPct = cssTotal ? (cssSplit.fp / cssTotal * 100) : 0
          - const cssTpPct = cssTotal ? (cssSplit.tp / cssTotal * 100) : 0
          .cov-split-row
            span.cov-split-label CSS unused
            .cov-split-track
              if cssFpPct > 0
                span.cov-split-fp(style='width: ' + cssFpPct.toFixed(2) + '%', title='First party: ' + h.size.format(cssSplit.fp))
              if cssTpPct > 0
                span.cov-split-tp(style='width: ' + cssTpPct.toFixed(2) + '%', title='Third party: ' + h.size.format(cssSplit.tp))
            span.cov-split-value
              span.cov-split-chip.cov-split-chip--fp First #{h.size.format(cssSplit.fp)}
              span.cov-split-chip.cov-split-chip--tp Third #{h.size.format(cssSplit.tp)}

  if jsAgg.length > 0
    - const jsSorted = jsAgg.slice().sort((a, b) => b.unusedBytes - a.unusedBytes).slice(0, MAX_ROWS)
    .listing-card
      .listing-card-header
        h3.listing-card-title JavaScript files
        span.listing-card-meta showing #{jsSorted.length} of #{jsAgg.length} URLs (from #{jsFiles.length} scripts), sorted by unused bytes
      table.cov-table.responsive
        thead
          tr
            th URL
            th.cov-num Total
            th.cov-num Used
            th.cov-num Unused
            th.cov-bar Unused %
        tbody
          each f in jsSorted
            - const inline = docUrl && f.url === docUrl
            tr
              td.cov-url
                if inline
                  span.cov-inline (inline)
                else
                  a(href=f.url, title=f.url) #{h.shortAsset(f.url, true)}
                if f.count > 1
                  | &nbsp;
                  span.cov-count #{f.count} scripts
              td.cov-num #{h.size.format(f.totalBytes)}
              td.cov-num #{h.size.format(f.usedBytes)}
              td.cov-num #{h.size.format(f.unusedBytes)}
              td.cov-bar
                .cov-bar-track
                  span.cov-bar-fill(class=sevClass(f.unusedPercent), style='width: ' + f.unusedPercent.toFixed(2) + '%')
                span.cov-bar-value #{f.unusedPercent.toFixed(1)}%

  if cssAgg.length > 0
    - const cssSorted = cssAgg.slice().sort((a, b) => b.unusedBytes - a.unusedBytes).slice(0, MAX_ROWS)
    .listing-card
      .listing-card-header
        h3.listing-card-title CSS files
        span.listing-card-meta showing #{cssSorted.length} of #{cssAgg.length} URLs (from #{cssFiles.length} stylesheets), sorted by unused bytes
      table.cov-table.responsive
        thead
          tr
            th URL
            th.cov-num Total
            th.cov-num Used
            th.cov-num Unused
            th.cov-bar Unused %
        tbody
          each f in cssSorted
            tr
              td.cov-url
                if f.url
                  a(href=f.url, title=f.url) #{h.shortAsset(f.url, true)}
                else
                  span.cov-inline (inline stylesheet)
                if f.count > 1
                  | &nbsp;
                  span.cov-count #{f.count} stylesheets
              td.cov-num #{h.size.format(f.totalBytes)}
              td.cov-num #{h.size.format(f.usedBytes)}
              td.cov-num #{h.size.format(f.unusedBytes)}
              td.cov-bar
                .cov-bar-track
                  span.cov-bar-fill(class=sevClass(f.unusedPercent), style='width: ' + f.unusedPercent.toFixed(2) + '%')
                span.cov-bar-value #{f.unusedPercent.toFixed(1)}%

  .listing-card.cov-advice
    .listing-card-header
      h3.listing-card-title What to do about unused bytes
      span.listing-card-meta one iteration is a sample, not a verdict
    p.listing-card-help
      | A high unused-% on one run means this iteration loaded code that didn't get exercised — typical on first-load journeys before any user interaction. Drive the real flow by passing a&nbsp;
      a(href='https://www.sitespeed.io/documentation/sitespeed.io/scripting/') navigation script
      | &nbsp;as the input instead of a plain URL, with clicks and form fills placed between&nbsp;
      code measure.start()
      | &nbsp;and&nbsp;
      code measure.stop()
      |  — anything in that window counts toward "used". The advice below is for code that's still unused after a representative run.
    .cov-advice-grid
      div
        h4 JavaScript
        ul
          li Route-split and lazy-load below-the-fold features with dynamic&nbsp;
            code import()
            | . Bundlers turn the import boundary into a separate chunk.
          li Audit big bundles for dead exports, legacy polyfills, and feature flags that no longer ship — most modern bundlers tree-shake but only when imports are precise.
          li Question third-party scripts. Tag managers, analytics SDKs and A/B test loaders often ship far more than the page uses and dominate the third-party column above.
          li Move non-critical scripts to&nbsp;
            code defer
            | &nbsp;or&nbsp;
            code async
            |  so the parser doesn't block on code the page doesn't need yet.
      div
        h4 CSS
        ul
          li Strip selectors no shipped HTML matches — PurgeCSS, build-time scoping in your component framework, or your CSS-in-JS extractor.
          li Drop legacy browser fallbacks if your target floor has moved (vendor prefixes, IE hacks, old flexbox syntax).
          li Split route- or component-specific CSS so the home page doesn't carry the checkout's styles.
          li Inline the critical-path CSS (above-the-fold) and lazy-load the rest with&nbsp;
            code media=
            | &nbsp;tricks or&nbsp;
            code rel="preload"
            | &nbsp;swaps.
