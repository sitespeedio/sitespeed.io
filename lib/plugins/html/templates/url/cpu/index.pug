- const browsertime = medianRun ? (pageInfo.data.browsertime ? pageInfo.data.browsertime.pageSummary.browserScripts[medianRun.runIndex - 1]: undefined) : pageInfo.data.browsertime.run
- const cpu = medianRun ? (pageInfo.data.browsertime ? pageInfo.data.browsertime.pageSummary.cpu[medianRun.runIndex - 1]: undefined) : pageInfo.data.browsertime.run.cpu

if cpu
  small
    if cpu.longTasks
      a(href='#long-tasks') Long tasks
      | &nbsp;|&nbsp;
    if browsertime && browsertime.timings && browsertime.timings.firstInput !== undefined
      a(href='#first-input-delay') First Input Delay
      | &nbsp;|&nbsp;
    if cpu.categories
      a(href='#cpu-time-spent') CPU time spent
      | &nbsp;|&nbsp;
    if cpu.urls && cpu.urls.length > 0
      a(href='#cpu-time-spent-per-request') Per request
      | &nbsp;|&nbsp;
    if pageInfo.data.thirdparty
      a(href='#cpu-time-per-tool') Per tool
      | &nbsp;|&nbsp;

a#cpu
h2 CPU

//- Trace download buttons (Chrome / Firefox / extra-run profile).
if cpu && cpu.events && !options.browsertime.enableProfileRun
  p Download the Chrome trace and drag-and-drop it into Performance in DevTools.
  .downloads
    if options.browsertime.chrome && options.browsertime.chrome.timeline
    - const tracePath = 'data/trace-' + (runNumber? runNumber : 1) + '.json.gz'
    a.button.button-download(href=tracePath, download=downloadName + '-timeline.json.gz') Download trace log

if options.browsertime && options.browsertime.firefox && options.browsertime.firefox.geckoProfiler && options.browser === 'firefox' && !options.browsertime.enableProfileRun
  p Download the Firefox Gecko profile and drop it into
    |
    a(href='https://profiler.firefox.com') profiler.firefox.com
    | .
  .downloads
    - const tracePath = 'data/geckoProfile-' + (runNumber? runNumber : 1) + '.json.gz'
    a.button.button-download(href=tracePath, download=downloadName + '-geckoProfile.json.gz') Download trace

if options.browsertime && options.browsertime.enableProfileRun
  if options.browser === 'firefox'
    p Download the extra-run Firefox profile and drop it into
      |
      a(href='https://profiler.firefox.com') profiler.firefox.com
      | .
    .downloads
      - const tracePath = 'data/geckoProfile-1-extra.json.gz'
      a.button.button-download(href=tracePath, download=downloadName + '-geckoProfile.json.gz') Download extra-run trace
  else if options.browser === 'chrome'
    p Download the extra-run Chrome trace.
    - const tracePath = 'data/trace-1-extra-run.json.gz'
    a.button.button-download(href=tracePath, download=downloadName + '-timeline.json.gz') Download extra-run trace

//- Long tasks: KPI tiles for the headline numbers, then the
//- before/after breakdown as a small definition list, and the
//- individual long tasks as a sortable table at the bottom.
if cpu && cpu.longTasks
  a#long-tasks
  h3 Long tasks
  p Tasks ≥ 50 ms blocking the main thread, collected via the Long Task API.
  if cpu.longTasks.tasks > 0
    .cpu-kpis
      - const tbtClass = cpu.longTasks.totalBlockingTime >= 600 ? 'error' : (cpu.longTasks.totalBlockingTime >= 200 ? 'warning' : 'ok')
      .cpu-kpi(class=tbtClass)
        span.cpu-kpi-label TBT
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.totalBlockingTime)}
      .cpu-kpi
        span.cpu-kpi-label Max FID
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.maxPotentialFid)}
      .cpu-kpi
        span.cpu-kpi-label Total long tasks
        span.cpu-kpi-value #{cpu.longTasks.tasks}
      .cpu-kpi
        span.cpu-kpi-label Total time
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.totalDuration.toFixed(0))}
      .cpu-kpi
        span.cpu-kpi-label Last task
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.lastLongTask)}

    h4.cpu-section-heading Long tasks by phase
    dl.cpu-phase-list
      dt Before First Paint
      dd
        span.cpu-phase-count #{cpu.longTasks.beforeFirstPaint.tasks}
        span.cpu-phase-time #{h.time.ms(cpu.longTasks.beforeFirstPaint.totalDuration.toFixed(0))}
      dt Before First Contentful Paint
      dd
        span.cpu-phase-count #{cpu.longTasks.beforeFirstContentfulPaint.tasks}
        span.cpu-phase-time #{h.time.ms(cpu.longTasks.beforeFirstContentfulPaint.totalDuration.toFixed(0))}
      dt Before Largest Contentful Paint
      dd
        span.cpu-phase-count #{cpu.longTasks.beforeLargestContentfulPaint.tasks}
        span.cpu-phase-time #{h.time.ms(cpu.longTasks.beforeLargestContentfulPaint.totalDuration.toFixed(0))}
      dt After Load Event End
      dd
        span.cpu-phase-count #{cpu.longTasks.afterLoadEventEnd.tasks}
        span.cpu-phase-time #{h.time.ms(cpu.longTasks.afterLoadEventEnd.totalDuration.toFixed(0))}

    if browsertime && browsertime.pageinfo && browsertime.pageinfo.longTask
      h4.cpu-section-heading Individual long tasks
      .responsive
        table(data-sortable)
          thead
            tr
              th Name
              th.number Start
              th.number Duration
              th Container
              th Container src
              th Type
          tbody
            each task in browsertime.pageinfo.longTask
              tr
                td #{task.name}
                td.number #{task.startTime.toFixed(0)}
                td.number #{task.duration.toFixed(0)}
                td #{task.attribution[0].containerName}
                td.url.assetsurl #{task.attribution[0].containerSrc}
                td #{task.attribution[0].containerType}
  else
    p.cpu-no-tasks ✓ No long tasks observed during this run.

//- First Input Delay
if browsertime && browsertime.timings && browsertime.timings.firstInput !== undefined
  a#first-input-delay
  h3 First Input Delay
  - const fi = browsertime.timings.firstInput
  .cpu-card
    .cpu-card-header
      span.cpu-card-title #{fi.name}
    dl.cpu-fi-meta
      dt Delay
      dd #{h.time.ms(fi.delay)}
      dt Duration
      dd #{h.time.ms(fi.duration)}
      dt Start time
      dd #{h.time.ms(fi.startTime)}
      dt Processing start
      dd #{h.time.ms(fi.processingStart)}
      dt Processing end
      dd #{h.time.ms(fi.processingEnd)}

//- CPU time spent — categories and event types as horizontal bar lists,
//- replaces the two tiny tables stacked side by side.
if cpu && cpu.categories
  a#cpu-time-spent
  h3 CPU time spent
  p.small Calculated using Tracium.
  - const catTotal = Object.values(cpu.categories).reduce((s, v) => s + v, 0)
  .row
    .one-half.column
      h4.cpu-section-heading Categories
      .cpu-bars
        - const catEntries = Object.entries(cpu.categories).sort((a, b) => b[1] - a[1])
        each entry in catEntries
          - const pct = catTotal > 0 ? (entry[1] / catTotal * 100) : 0
          .cpu-bar-row
            span.cpu-bar-label #{entry[0]}
            .cpu-bar-track
              span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
            span.cpu-bar-value #{entry[1].toFixed(0)} ms
    .one-half.column
      if cpu.events
        h4.cpu-section-heading Events
        - const evTotal = Object.values(cpu.events).reduce((s, v) => s + v, 0)
        - const evEntries = Object.entries(cpu.events).sort((a, b) => b[1] - a[1])
        .cpu-bars
          each entry in evEntries
            - const pct = evTotal > 0 ? (entry[1] / evTotal * 100) : 0
            .cpu-bar-row
              span.cpu-bar-label #{entry[0]}
              .cpu-bar-track
                span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
              span.cpu-bar-value #{entry[1].toFixed(0)} ms

  //- CPU time per request as bar list (sorted desc).
  if cpu.urls && cpu.urls.length > 0
    a#cpu-time-spent-per-request
    h3 CPU time per request
    - const urlMax = Math.max.apply(null, cpu.urls.map(u => u.value))
    .cpu-bars
      each data in cpu.urls
        - const pct = urlMax > 0 ? (data.value / urlMax * 100) : 0
        .cpu-bar-row
          a.cpu-bar-asset(href=data.url)= data.url
          .cpu-bar-track
            span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
          span.cpu-bar-value #{data.value.toFixed(0)} ms

  //- CPU time per third-party tool / domain.
  if pageInfo.data.thirdparty
    - const thirdparty = medianRun ? pageInfo.data.thirdparty.pageSummary.runs[medianRun.runIndex - 1] : pageInfo.data.thirdparty.run
    if thirdparty && thirdparty.cpuPerTool && Object.keys(thirdparty.cpuPerTool).length > 0
      a#cpu-time-per-tool
      h3 CPU time per tool / domain
      - const tools = Object.entries(thirdparty.cpuPerTool).sort((a, b) => b[1] - a[1])
      - const toolMax = tools.length > 0 ? tools[0][1] : 0
      .cpu-bars
        each entry in tools
          - const pct = toolMax > 0 ? (entry[1] / toolMax * 100) : 0
          .cpu-bar-row
            span.cpu-bar-label #{entry[0]}
            .cpu-bar-track
              span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
            span.cpu-bar-value #{entry[1].toFixed(1)} ms
