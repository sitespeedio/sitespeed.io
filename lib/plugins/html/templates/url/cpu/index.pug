include ../includes/_quicklinks

- const browsertime = medianRun ? (pageInfo.data.browsertime ? pageInfo.data.browsertime.pageSummary.browserScripts[medianRun.runIndex - 1]: undefined) : pageInfo.data.browsertime.run
- const cpu = medianRun ? (pageInfo.data.browsertime ? pageInfo.data.browsertime.pageSummary.cpu[medianRun.runIndex - 1]: undefined) : pageInfo.data.browsertime.run.cpu
//- Per-module CPU needs the trace and the coverage-derived bundle
//- boundaries from the same iteration. With --enableProfileRun that
//- only happens in the profile run, whose sample the browsertime
//- plugin publishes as pageSummary.moduleCosts (marked with
//- source: 'profileRun') — fall back to it when the measured
//- iterations have none of their own.
- const profileModuleCosts = medianRun && pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary.moduleCosts ? pageInfo.data.browsertime.pageSummary.moduleCosts.bundles : undefined
//- Bundles where no task resolved to a module (only unattributed
//- otherTime, usually a millisecond or two) would render as empty
//- cards — skip them.
- const moduleCosts = ((cpu && cpu.moduleCosts) || profileModuleCosts || []).filter(bundle => bundle.modules.length > 0)
//- Per-function JS cost needs the V8 sampling profiler, whose trace
//- category only the profile run enables — same marked-sample
//- fallback as the module costs above.
- const profileFunctionCosts = medianRun && pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary.functionCosts ? pageInfo.data.browsertime.pageSummary.functionCosts.functions : undefined
- const functionCosts = (cpu && cpu.functionCosts) || profileFunctionCosts || []
//- Sections showing profile-run data must say so: the numbers come
//- from one extra instrumented run, not the timed iterations the
//- rest of the page reports on.
- const moduleCostsFromProfileRun = !(cpu && cpu.moduleCosts) && !!(profileModuleCosts && profileModuleCosts.length)
- const functionCostsFromProfileRun = !(cpu && cpu.functionCosts) && !!(profileFunctionCosts && profileFunctionCosts.length)
- const profileRunExplanation = 'Collected in the single extra profile run made by --enableProfileRun, not in the timed iterations the rest of this page reports on.'
//- Timers follow the same marked-sample fallback
//- (pageSummary.timers = { source, data }). Selector stats and style
//- invalidations render on the Rendering tab, next to the visual
//- story they explain.
- const profileCpuAnalysis = key => medianRun && pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary[key] ? pageInfo.data.browsertime.pageSummary[key].data : undefined
//- With --cpu the measured runs carry timers too, but only the
//- profile run has the coverage bundles that resolve install sites
//- to modules — prefer whichever sample carries that attribution.
- const measuredTimers = cpu && cpu.timers
- const profileTimers = profileCpuAnalysis('timers')
- const timersHaveModules = t => !!(t && t.sites && t.sites.some(site => site.module))
- const useProfileTimers = !!profileTimers && (!measuredTimers || (timersHaveModules(profileTimers) && !timersHaveModules(measuredTimers)))
- const timers = useProfileTimers ? profileTimers : measuredTimers
- const timersFromProfileRun = useProfileTimers

//- Inline SVG glyph mixin — small Lucide-style stroke icons next to
//- each h3 section heading. Stroke colour inherits from the heading
//- so light/dark themes follow without per-icon overrides. viewBox
//- lowercased because pug-lint rejects camelCase attributes; HTML5's
//- inline-SVG attribute-adjustment table normalises it back to
//- viewBox at parse time. Argument is one of:
//-   clock | ban | piechart | refresh | layout | filecode | globe |
//-   activity | pointer
mixin cpuIcon(name)
  svg.cpu-h-icon(width='18', height='18', viewbox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='2', stroke-linecap='round', stroke-linejoin='round', aria-hidden='true')
    case name
      when 'clock'
        circle(cx='12', cy='12', r='10')
        polyline(points='12 6 12 12 16 14')
      when 'ban'
        circle(cx='12', cy='12', r='10')
        line(x1='4.93', y1='4.93', x2='19.07', y2='19.07')
      when 'piechart'
        path(d='M21.21 15.89A10 10 0 1 1 8 2.83')
        path(d='M22 12A10 10 0 0 0 12 2v10z')
      when 'refresh'
        path(d='M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8')
        path(d='M3 3v5h5')
        path(d='M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16')
        path(d='M16 16h5v5')
      when 'layout'
        rect(x='3', y='3', width='18', height='18', rx='2')
        line(x1='3', y1='9', x2='21', y2='9')
        line(x1='9', y1='21', x2='9', y2='9')
      when 'filecode'
        path(d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z')
        polyline(points='14 2 14 8 20 8')
        polyline(points='10 13 8 15 10 17')
        polyline(points='14 17 16 15 14 13')
      when 'globe'
        circle(cx='12', cy='12', r='10')
        line(x1='2', y1='12', x2='22', y2='12')
        path(d='M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z')
      when 'activity'
        polyline(points='22 12 18 12 15 21 9 3 6 12 2 12')
      when 'pointer'
        path(d='m9 9 5 12 1.774-5.226L21 14 9 9z')
        path(d='m16.071 16.071 4.243 4.243')
        path(d='m7.188 2.239.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122')

//- Quicklinks ordered by importance and reading flow — the verdict
//- first (long tasks / TBT), then who blocked the main thread, then
//- the broad "where the time went" orientation, then the cost
//- drill-down ladder (script → module → function), bug patterns
//- (forced reflows/layout), context (third party), and niche
//- signals (frames, animations, FID) at the bottom because they're
//- either rare or supplanted by INP. Body sections follow the same
//- order.
if cpu
  - const cpuLinks = []
  if cpu.longTasks
    - cpuLinks.push({href: '#long-tasks', label: 'Long tasks'})
  if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
    - cpuLinks.push({href: '#cpu-loaf-blocking', label: 'Per script blocking'})
  if cpu.blocking && cpu.blocking.urls && cpu.blocking.urls.length > 0
    - cpuLinks.push({href: '#cpu-blocking', label: 'TBT per script'})
  if cpu.categories
    - cpuLinks.push({href: '#cpu-time-spent', label: 'Where time went'})
  if cpu.urls && cpu.urls.length > 0
    - cpuLinks.push({href: '#cpu-time-spent-per-request', label: 'Per script'})
  if moduleCosts && moduleCosts.length > 0
    - cpuLinks.push({href: '#cpu-module-costs', label: 'Per module'})
  if functionCosts && functionCosts.length > 0
    - cpuLinks.push({href: '#cpu-function-costs', label: 'Per function'})
  if timers && timers.fires > 0
    - cpuLinks.push({href: '#cpu-timers', label: 'Timers'})
  if cpu.forcedReflows && cpu.forcedReflows.length > 0
    - cpuLinks.push({href: '#cpu-forced-reflows', label: 'Forced reflows'})
  if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
    - cpuLinks.push({href: '#cpu-forced-layout-per-script', label: 'Forced layout/script'})
  if cpu.domains
    - cpuLinks.push({href: '#cpu-first-third-party', label: 'First vs third party'})
  if pageInfo.data.thirdparty
    - cpuLinks.push({href: '#cpu-time-per-tool', label: 'Per domain/tool'})
  if cpu.frames && cpu.frames.presented !== undefined
    - cpuLinks.push({href: '#cpu-frames', label: 'Frames'})
  if cpu.nonCompositedAnimations && cpu.nonCompositedAnimations.length > 0
    - cpuLinks.push({href: '#cpu-animations', label: 'Animations'})
  if browsertime && browsertime.timings && browsertime.timings.firstInput !== undefined
    - cpuLinks.push({href: '#first-input-delay', label: 'First Input Delay'})
  +quicklinks(cpuLinks)

a#cpu
h2 CPU

//- Top-offender callout — the page's verdict, so it comes first.
//- Derived from LoAF blocking-per-script when the page has LoAF
//- data, otherwise from the trace's TBT attribution (cpu.blocking).
//- Only renders when the data is unambiguous: total blocking
//- ≥ 100 ms AND the top single script accounts for ≥ 30 % of it.
//- Skips when work is evenly distributed (because then "fix script
//- X" isn't really the answer) or when the page barely blocked at
//- all (no clear win available).
- let calloutTopOffender, calloutTotal
if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
  - const calloutByScript = new Map()
  - for (const loaf of browsertime.pageinfo.loaf) { const blockingDur = loaf.blockingDuration || 0; if (blockingDur === 0) continue; const firstScript = loaf.scripts && loaf.scripts[0]; const url = (firstScript && firstScript.sourceURL) || ''; if (!url) continue; const entry = calloutByScript.get(url) || { url, blocking: 0 }; entry.blocking += blockingDur; calloutByScript.set(url, entry) }
  - const calloutSorted = Array.from(calloutByScript.values()).sort((a, b) => b.blocking - a.blocking)
  - calloutTopOffender = calloutSorted[0]
  - calloutTotal = calloutSorted.reduce((s, e) => s + e.blocking, 0)
else if cpu && cpu.blocking && cpu.blocking.urls && cpu.blocking.urls.length > 0
  - const attributed = cpu.blocking.urls.filter(u => u.url !== 'unknown')
  - if (attributed.length > 0) { calloutTopOffender = { url: attributed[0].url, label: attributed[0].label, blocking: attributed[0].value }; calloutTotal = cpu.blocking.totalBlockingTime }
if calloutTopOffender && calloutTotal >= 100 && (calloutTopOffender.blocking / calloutTotal) >= 0.3
  .cpu-callout
    .cpu-callout-icon(aria-hidden='true')
      svg(width='28', height='28', viewbox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
        path(d='m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z')
        path(d='M12 9v4')
        path(d='M12 17h.01')
    .cpu-callout-body
      .cpu-callout-headline
        a(href=calloutTopOffender.url, title=calloutTopOffender.url)= calloutTopOffender.label || h.shortAsset(calloutTopOffender.url, true)
        | &nbsp;is responsible for #{Math.round(calloutTopOffender.blocking / calloutTotal * 100)}% of blocking time
      .cpu-callout-detail
        | #{calloutTopOffender.blocking.toFixed(0)} ms of #{calloutTotal.toFixed(0)} ms total. Defer it, replace it with a lighter alternative, or move its work off the main thread to recover most of your TBT.

//- When the run has no trace-derived CPU data and the profile run is
//- off, tell the reader what enabling it adds — otherwise this tab is
//- just the long-task counters and they may never learn the deeper
//- data exists.
if options.browser === 'chrome' && (!cpu || !cpu.categories) && !(options.browsertime && options.browsertime.enableProfileRun)
  .cpu-callout
    .cpu-callout-icon(aria-hidden='true')
      svg(width='28', height='28', viewbox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='2', stroke-linecap='round', stroke-linejoin='round')
        path(d='M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5')
        path(d='M9 18h6')
        path(d='M10 22h4')
    .cpu-callout-body
      .cpu-callout-headline Get deeper CPU insight with one extra run
      .cpu-callout-detail
        | Run with&nbsp;
        code --enableProfileRun
        | &nbsp;to see where main-thread time went, blocking time and CPU cost per script, module and function, forced reflows and frame stability. The data is collected in one extra run, so the timing metrics of your measured runs stay untouched.

//- Long tasks: KPI tiles for the headline numbers, then the
//- before/after breakdown as a small definition list, and the
//- individual long tasks as a sortable table at the bottom.
if cpu && cpu.longTasks
  a#long-tasks
  h3
    +cpuIcon('clock')
    | Long tasks
  p Tasks ≥ 50 ms blocking the main thread, collected via the Long Task API.
  if cpu.longTasks.tasks > 0
    .cpu-kpis
      - const tbtClass = cpu.longTasks.totalBlockingTime >= 600 ? 'error' : (cpu.longTasks.totalBlockingTime >= 200 ? 'warning' : 'ok')
      .cpu-kpi(class=tbtClass)
        span.cpu-kpi-label TBT
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.totalBlockingTime)}
      .cpu-kpi
        span.cpu-kpi-label Max FID
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.maxPotentialFid)}
      .cpu-kpi
        span.cpu-kpi-label Total long tasks
        span.cpu-kpi-value #{cpu.longTasks.tasks}
      .cpu-kpi
        span.cpu-kpi-label Total time
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.totalDuration.toFixed(0))}
      .cpu-kpi
        span.cpu-kpi-label Last task at
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.lastLongTask)}

    //- Long tasks by phase as a second KPI row — answers "WHEN was
    //- the page busy?" at a glance. Pre-FCP work delays first paint;
    //- before-LCP work delays the LCP candidate; post-load work is
    //- typically third-party / hydration; combined they tell you
    //- which slice of the page-load timeline to attack first. Each
    //- tile is colour-coded by total duration so a reader spots the
    //- problem phase without reading the numbers — green when the
    //- phase had zero blocking, yellow up to 200 ms, red above.
    - const phaseClass = (ms) => ms === 0 ? 'ok' : (ms <= 200 ? 'warning' : 'error')
    .cpu-kpis.cpu-kpis-secondary
      .cpu-kpi(class=phaseClass(cpu.longTasks.beforeFirstPaint.totalDuration))
        span.cpu-kpi-label Before FP
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.beforeFirstPaint.totalDuration.toFixed(0))}
        span.cpu-kpi-sub #{cpu.longTasks.beforeFirstPaint.tasks} #{cpu.longTasks.beforeFirstPaint.tasks === 1 ? 'task' : 'tasks'}
      .cpu-kpi(class=phaseClass(cpu.longTasks.beforeFirstContentfulPaint.totalDuration))
        span.cpu-kpi-label Before FCP
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.beforeFirstContentfulPaint.totalDuration.toFixed(0))}
        span.cpu-kpi-sub #{cpu.longTasks.beforeFirstContentfulPaint.tasks} #{cpu.longTasks.beforeFirstContentfulPaint.tasks === 1 ? 'task' : 'tasks'}
      .cpu-kpi(class=phaseClass(cpu.longTasks.beforeLargestContentfulPaint.totalDuration))
        span.cpu-kpi-label Before LCP
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.beforeLargestContentfulPaint.totalDuration.toFixed(0))}
        span.cpu-kpi-sub #{cpu.longTasks.beforeLargestContentfulPaint.tasks} #{cpu.longTasks.beforeLargestContentfulPaint.tasks === 1 ? 'task' : 'tasks'}
      .cpu-kpi(class=phaseClass(cpu.longTasks.afterLoadEventEnd.totalDuration))
        span.cpu-kpi-label After load
        span.cpu-kpi-value #{h.time.ms(cpu.longTasks.afterLoadEventEnd.totalDuration.toFixed(0))}
        span.cpu-kpi-sub #{cpu.longTasks.afterLoadEventEnd.tasks} #{cpu.longTasks.afterLoadEventEnd.tasks === 1 ? 'task' : 'tasks'}
  else
    p.cpu-no-tasks ✓ No long tasks observed during this run.

//- Blocking time per script — derived from the Long Animation Frame
//- API. The Long Task API deliberately doesn't expose script-level
//- attribution (privacy: cross-origin script identity), so it's
//- the wrong source for "which script caused TBT". LoAF was
//- designed to fix that gap and ships per-script attribution
//- (sourceURL, sourceFunctionName, sourceCharPosition).
//-
//- Each LoAF's `blockingDuration` is credited to its **first**
//- entry in `scripts[]` — Chrome lists scripts in execution order,
//- so the first one is the script that started the long frame
//- (typically the trigger). LoAFs without a script attribution
//- (e.g. browser-internal work) are skipped.
if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
  - const loafByScript = new Map()
  - for (const loaf of browsertime.pageinfo.loaf) { const blockingDur = loaf.blockingDuration || 0; if (blockingDur === 0) continue; const firstScript = loaf.scripts && loaf.scripts[0]; const url = (firstScript && firstScript.sourceURL) || ''; if (!url) continue; const entry = loafByScript.get(url) || { url, blocking: 0, count: 0, worst: 0, fn: firstScript.sourceFunctionName || '' }; entry.blocking += blockingDur; entry.count++; if (blockingDur > entry.worst) entry.worst = blockingDur; if (!entry.fn && firstScript.sourceFunctionName) entry.fn = firstScript.sourceFunctionName; loafByScript.set(url, entry) }
  - const loafEntries = Array.from(loafByScript.values()).sort((a, b) => b.blocking - a.blocking).slice(0, 10)
  if loafEntries.length > 0
    - const loafBlockingMax = loafEntries[0].blocking
    a#cpu-loaf-blocking
    h3
      +cpuIcon('ban')
      | Blocking time per script
    p How much each script blocked the main thread, derived from the Long Animation Frame API. The script that started each long frame is credited with the frame's blocking time, the closest answer to "which script should I fix to improve TBT" the platform exposes.
    .listing-card
      .listing-card-header
        h3.listing-card-title Top scripts blocking the main thread
        span.listing-card-meta #{loafEntries.length} of #{loafByScript.size} #{loafByScript.size === 1 ? 'script' : 'scripts'}
      .cpu-bars
        each entry in loafEntries
          - const pct = loafBlockingMax > 0 ? (entry.blocking / loafBlockingMax * 100) : 0
          .cpu-bar-row
            a.cpu-bar-asset(href=entry.url, title=entry.url)= h.shortAsset(entry.url, true)
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{entry.blocking.toFixed(0)} ms
              span.cpu-bar-sub  · #{entry.count} #{entry.count === 1 ? 'frame' : 'frames'} · worst #{entry.worst.toFixed(0)} ms

//- The per-script LoAF sections above/below need script attribution,
//- which page-load frames often lack — but the frame-level story
//- (work vs render split, blocking per frame) always renders on the
//- Metrics tab. Point there so the LoAF data isn't invisible from
//- this tab when attribution is missing. Same cross-tab link pattern
//- as the Rendering tab's why-section.
if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
  p.small
    a(href='#longAnimationFrames', onclick='const metricsTab = document.querySelector("#tabs #metrics"); if (metricsTab) selectTab(metricsTab, false)') See the frame-by-frame long animation frame breakdown on the Metrics tab

//- Blocking time per script from the Chrome trace (cpu.blocking).
//- Complements the LoAF list above: LoAF is the browser's own
//- attribution of long animation frames, while this walks the
//- trace's main-thread tasks (Lighthouse's TBT definition) and
//- credits each blocking task to the URL that contributed the most
//- self-time. 'unknown' is browser-internal work (GC, style, layout)
//- no script owns.
if cpu && cpu.blocking && cpu.blocking.urls && cpu.blocking.urls.length > 0
  a#cpu-blocking
  h3
    +cpuIcon('ban')
    | Blocking time per script (trace)
  p Total Blocking Time attributed per script from the Chrome trace: every main-thread task longer than 50 ms blocks input for the remainder, and each blocking task is credited to the script that contributed the most self-time.
  .cpu-kpis
    - const traceTbtClass = cpu.blocking.totalBlockingTime >= 600 ? 'error' : (cpu.blocking.totalBlockingTime >= 200 ? 'warning' : 'ok')
    .cpu-kpi(class=traceTbtClass)
      span.cpu-kpi-label TBT
      span.cpu-kpi-value #{h.time.ms(cpu.blocking.totalBlockingTime)}
    .cpu-kpi
      span.cpu-kpi-label Blocking tasks
      span.cpu-kpi-value #{cpu.blocking.tasks}
    if cpu.blocking.beforeLargestContentfulPaint
      .cpu-kpi
        span.cpu-kpi-label TBT before LCP
        span.cpu-kpi-value #{h.time.ms(cpu.blocking.beforeLargestContentfulPaint.totalBlockingTime)}
        span.cpu-kpi-sub #{cpu.blocking.beforeLargestContentfulPaint.tasks} #{cpu.blocking.beforeLargestContentfulPaint.tasks === 1 ? 'task' : 'tasks'}
  //- What KIND of work blocked (cpu.blocking.kinds) — script blocking
  //- needs code changes, parse blocking needs a smaller document,
  //- style/layout blocking needs cheaper CSS. Reuses the category-bar
  //- segments so the colors match "Where the time went".
  if cpu.blocking.kinds && Object.keys(cpu.blocking.kinds).length > 0
    - const blockingKinds = Object.entries(cpu.blocking.kinds)
    - const blockingKindTotal = blockingKinds.reduce((s, e) => s + e[1], 0)
    .listing-card
      .listing-card-header
        h3.listing-card-title What kind of work blocked
        span.listing-card-meta #{h.time.ms(blockingKindTotal.toFixed(0))} total
      .cpu-cat-bar
        each entry in blockingKinds
          - const pct = blockingKindTotal > 0 ? (entry[1] / blockingKindTotal * 100) : 0
          if pct >= 1.5
            span.cpu-cat-seg(class='cpu-cat-seg--' + entry[0], style='flex: ' + pct.toFixed(3) + ' 0 0', title=entry[0] + ' · ' + entry[1].toFixed(1) + ' ms · ' + pct.toFixed(1) + '%')
      .cpu-cat-legend
        each entry in blockingKinds
          - const pct = blockingKindTotal > 0 ? (entry[1] / blockingKindTotal * 100) : 0
          .cpu-cat-legend-item
            span.cpu-cat-swatch(class='cpu-cat-seg--' + entry[0])
            span.cpu-cat-name #{entry[0]}
            span.cpu-cat-value #{h.time.ms(entry[1].toFixed(1))}
            span.cpu-cat-pct #{pct.toFixed(1)}%
  - const blockingUrls = cpu.blocking.urls.slice(0, 10)
  - const blockingMax = blockingUrls[0].value
  .listing-card
    .listing-card-header
      h3.listing-card-title Blocking time by script
      span.listing-card-meta #{blockingUrls.length} of #{cpu.blocking.urls.length} #{cpu.blocking.urls.length === 1 ? 'script' : 'scripts'}
    .cpu-bars
      each entry in blockingUrls
        - const pct = blockingMax > 0 ? (entry.value / blockingMax * 100) : 0
        .cpu-bar-row
          if entry.url === 'unknown'
            span.cpu-bar-asset
              span.cpu-bar-anon Browser internal / unattributed
          else if entry.url === daurl
            //- Blocking HTML-parse tasks are attributed to the
            //- document itself — name it so nobody hunts for a
            //- "script" with the page's own URL.
            a.cpu-bar-asset(href=entry.url, title=entry.url) The HTML document (this page)
          else
            a.cpu-bar-asset(href=entry.url, title=entry.url)= entry.label || h.shortAsset(entry.url, true)
          .cpu-bar-track
            span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
          span.cpu-bar-value
            | #{entry.value.toFixed(0)} ms
            span.cpu-bar-sub  · #{entry.tasks} #{entry.tasks === 1 ? 'task' : 'tasks'}

//- "Where the time went" — the broad orientation that anchors the
//- drill-down ladder below (script → module → function).
if cpu && cpu.categories
  a#cpu-time-spent
  h3
    +cpuIcon('piechart')
    | Where the time went
  p.small Calculated from the Chrome trace.
  - const catTotal = Object.values(cpu.categories).reduce((s, v) => s + v, 0)
  - const catEntries = Object.entries(cpu.categories).filter(e => e[1] > 0).sort((a, b) => b[1] - a[1])
  .listing-card
    .listing-card-header
      h3.listing-card-title Categories
      span.listing-card-meta #{h.time.ms(catTotal.toFixed(0))} total
    //- One wide horizontal bar with each category as a coloured
    //- segment sized by its share of total CPU. Replaces the old
    //- vertical bar list — same data, much more visual at a glance.
    //- Tiny segments (< 1.5 % of total) are merged into the legend
    //- only, so the bar isn't speckled with hairlines.
    .cpu-cat-bar
      each entry in catEntries
        - const pct = catTotal > 0 ? (entry[1] / catTotal * 100) : 0
        if pct >= 1.5
          span.cpu-cat-seg(class='cpu-cat-seg--' + entry[0], style='flex: ' + pct.toFixed(3) + ' 0 0', title=entry[0] + ' · ' + entry[1].toFixed(0) + ' ms · ' + pct.toFixed(1) + '%')
    //- 'other' is almost entirely Chrome's task-scheduling overhead
    //- (RunTask-family self time: per-task entry/exit cost plus
    //- thousands of sub-millisecond scheduler ticks) — say so instead
    //- of leaving a fifth of the bar as mystery time. The RunTask
    //- totals live in cpu.events, which only reports events > 10 ms,
    //- so on quiet pages the note simply doesn't render.
    - const schedulingEventNames = ['RunTask', 'ThreadControllerImpl::RunTask', 'ThreadControllerImpl::DoWork', 'MessageLoop::RunTask', 'TaskQueueManager::ProcessTaskFromWorkQueue']
    - const schedulingMs = cpu.events ? schedulingEventNames.reduce((s, n) => s + (cpu.events[n] || 0), 0) : 0
    - const schedulingTitle = 'Mostly Chrome task-scheduling overhead: per-task entry/exit cost and thousands of sub-millisecond scheduler ticks (RunTask self time), not attributable page work.'
    .cpu-cat-legend
      each entry in catEntries
        - const pct = catTotal > 0 ? (entry[1] / catTotal * 100) : 0
        .cpu-cat-legend-item(title=entry[0] === 'other' && schedulingMs > 0 ? schedulingTitle : undefined)
          span.cpu-cat-swatch(class='cpu-cat-seg--' + entry[0])
          span.cpu-cat-name #{entry[0] === 'other' && schedulingMs > 0 ? 'other (browser scheduling)' : entry[0]}
          span.cpu-cat-value #{h.time.ms(entry[1].toFixed(0))}
          span.cpu-cat-pct #{pct.toFixed(1)}%
  //- Folded explainer for the category names — short, plain-language
  //- definitions so the legend doesn't need to carry them. Reuses the
  //- .cov-method details/summary card from the coverage tab (generic
  //- chevron-card styling despite the name). The per-page RunTask
  //- number lives inside the 'other' definition.
  details.cov-method
    summary What do these categories mean?
    .cov-method-body
      dl.cpu-cat-defs
        dt
          span.cpu-cat-swatch.cpu-cat-seg--parseHTML
          | parseHTML
        dd Reading the HTML and CSS and building the page structure. Grows with document size — a big server-rendered page costs more here.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--styleLayout
          | styleLayout
        dd Working out which CSS rules apply and where every element goes on the page. Grows with DOM size and selector complexity.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--scriptParseCompile
          | scriptParseCompile
        dd Parsing and compiling JavaScript before it can run — the cost of shipping bytes of JS, even unused ones.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--scriptEvaluation
          | scriptEvaluation
        dd Running JavaScript: event handlers, timers, promise callbacks and script execution.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--paintCompositeRender
          | paintCompositeRender
        dd Painting pixels and assembling layers into the frames you see on screen.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--garbageCollection
          | garbageCollection
        dd Reclaiming memory JavaScript no longer uses. A lot of it means allocation-heavy code.
        dt
          span.cpu-cat-swatch.cpu-cat-seg--other
          | other (browser scheduling)
        dd
          | Chrome’s own task management: per-task overhead and thousands of sub-millisecond scheduler ticks — not page work you can attribute or optimize away.
          if schedulingMs > 0
            |  On this page #{h.time.ms(schedulingMs.toFixed(0))} of it is RunTask self time.

//- CPU time per script — the top of the drill-down ladder: which
//- URL is costing main thread. Capped at top 10 because longer
//- lists become wallpaper.
if cpu && cpu.urls && cpu.urls.length > 0
  a#cpu-time-spent-per-request
  h3
    +cpuIcon('filecode')
    | CPU time per script
  - const topUrls = cpu.urls.slice(0, 10)
  - const urlMax = topUrls[0].value
  .listing-card
    .listing-card-header
      h3.listing-card-title Scripts by main-thread time
      span.listing-card-meta
        | #{topUrls.length} of #{cpu.urls.length} #{cpu.urls.length === 1 ? 'script' : 'scripts'}
    .cpu-bars
      each data in topUrls
        - const pct = urlMax > 0 ? (data.value / urlMax * 100) : 0
        .cpu-bar-row
          //- `label` is browsertime's stable name for bundled URLs
          //- (e.g. load.php[startup]) whose query strings churn
          //- between runs — the full URL stays in href/title.
          a.cpu-bar-asset(href=data.url, title=data.url)= data.label || h.shortAsset(data.url, true)
          .cpu-bar-track
            span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
          span.cpu-bar-value #{data.value.toFixed(0)} ms

//- CPU time per module inside concatenated bundles (cpu.moduleCosts,
//- MediaWiki ResourceLoader): which modules in a load.php batch the
//- main-thread time actually went to. '(other)' is bundle time that
//- couldn't be resolved to a single module. The bundle entries don't
//- carry their own stable label (yet), so reuse the labels the same
//- URLs got in cpu.urls / the coverage files.
if moduleCosts && moduleCosts.length > 0
  - const bundleLabels = new Map()
  - if (cpu && cpu.urls) { for (const u of cpu.urls) { if (u.label) bundleLabels.set(u.url, u.label) } }
  - const covForLabels = medianRun && pageInfo.data.browsertime ? pageInfo.data.browsertime.pageSummary.coverage : undefined
  - const covJsForLabels = covForLabels && covForLabels.js ? (covForLabels.source === 'profileRun' ? covForLabels.js : covForLabels.js[medianRun.runIndex - 1] || covForLabels.js[0]) : undefined
  - if (covJsForLabels && covJsForLabels.files) { for (const f of covJsForLabels.files) { if (f.label) bundleLabels.set(f.url, f.label) } }
  a#cpu-module-costs
  h3
    +cpuIcon('filecode')
    | CPU time per module
    if moduleCostsFromProfileRun
      span.profile-run-badge(title=profileRunExplanation) Profile run
  p Main-thread CPU time attributed to the individual modules inside concatenated JavaScript bundles (MediaWiki ResourceLoader), so a heavy bundle can be traced to the modules that actually cost the time.
  if moduleCostsFromProfileRun
    p.small The data comes from the extra profile run, not from the timed iterations.
  each bundle in moduleCosts
    - const shownModules = bundle.modules.slice(0, 15)
    - const bundleTotal = bundle.modules.reduce((s, m) => s + m.selfTime, 0) + bundle.otherTime
    .listing-card
      .listing-card-header
        h3.listing-card-title
          a(href=bundle.url, title=bundle.url)= bundle.label || bundleLabels.get(bundle.url) || h.shortAsset(bundle.url, true)
        span.listing-card-meta #{h.time.ms(bundleTotal.toFixed(0))} across #{bundle.modules.length} #{bundle.modules.length === 1 ? 'module' : 'modules'}
      .responsive
        table
          thead
            tr
              th Module
              th Version
              th.number Self time
          tbody
            each m in shownModules
              tr
                td
                  code= m.name
                td= m.version || '–'
                td.number #{m.selfTime.toFixed(1)} ms
            if bundle.otherTime > 0
              tr
                td
                  span.cpu-bar-anon (other)
                td –
                td.number #{bundle.otherTime.toFixed(1)} ms

//- Slowest JS functions (cpu.functionCosts) — from the V8 sampling
//- profiler, one level deeper than per-script/per-module: WHICH
//- function the main-thread time was spent in. Self time is time in
//- the function's own code; a small self but large total marks an
//- orchestrator (loader, event dispatcher) whose callees do the work.
//- Rows without a URL are engine/DOM work (querySelectorAll et al.)
//- sampled without a script position.
if functionCosts && functionCosts.length > 0
  - const shownFunctions = functionCosts.slice(0, 15)
  a#cpu-function-costs
  h3
    +cpuIcon('filecode')
    | Slowest JS functions
    if functionCostsFromProfileRun
      span.profile-run-badge(title=profileRunExplanation) Profile run
  p The functions where main-thread JavaScript time was actually spent, sampled by the V8 profiler. Self time is spent in the function itself; total time includes the functions it called. For loader/dispatcher functions whose total dwarfs their self time, the #[em runs] line shows the top functions and modules (up to five, ≥ 1 ms) the total was actually spent running.
  if functionCostsFromProfileRun
    p.small The data comes from the extra profile run, not from the timed iterations.
  .listing-card
    .listing-card-header
      h3.listing-card-title Functions by self time
      span.listing-card-meta #{shownFunctions.length} of #{functionCosts.length} #{functionCosts.length === 1 ? 'function' : 'functions'}
    .responsive
      table
        thead
          tr
            th Function
            th Where
            th.number Self time
            th.number Total time
        tbody
          each fn in shownFunctions
            tr
              td
                code(title=fn.url && fn.line ? fn.url + ':' + fn.line + ':' + fn.column : undefined)= fn.functionName
                //- Orchestrators (loaders, dispatchers) have a small
                //- self time but a big total — the callees say what
                //- the total was actually spent running.
                if fn.callees && fn.callees.length > 0
                  //- Several distinct (often anonymous) functions in
                  //- the same module display identically — merge them
                  //- by display name so "jquery (2 ms), jquery (1 ms)"
                  //- becomes one entry.
                  - const calleesByName = new Map()
                  - for (const callee of fn.callees) { const calleeName = callee.module || callee.label || callee.functionName; calleesByName.set(calleeName, (calleesByName.get(calleeName) || 0) + callee.value) }
                  .cpu-fn-callees
                    | runs:
                    each pair, index in [...calleesByName.entries()]
                      | #{index > 0 ? ', ' : ' '}#{pair[0]} (#{pair[1].toFixed(1)} ms)
              td
                if fn.module
                  code= fn.module
                else if fn.url
                  a(href=fn.url, title=fn.url)= fn.label || h.shortAsset(fn.url, true)
                else
                  span.cpu-bar-anon Browser / engine
              td.number #{fn.selfTime.toFixed(1)} ms
              td.number #{fn.totalTime.toFixed(1)} ms

//- Timer pressure (cpu.timers): setTimeout/setInterval churn per
//- script. Fire cost is attributed to the installer, so polling
//- loops and timeout-0 slicing have an owner even with anonymous
//- callbacks.
if timers && timers.fires > 0
  a#cpu-timers
  h3
    +cpuIcon('clock')
    | Timers
    if timersFromProfileRun
      span.profile-run-badge(title=profileRunExplanation) Profile run
  p How much setTimeout/setInterval work the page runs, credited to the script that scheduled each timer. Many timeout-0 installs mean work sliced into a machine-gun of tiny tasks; recurring installs are polling.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Installs
      span.cpu-kpi-value #{timers.installs}
    .cpu-kpi
      span.cpu-kpi-label Fires
      span.cpu-kpi-value #{timers.fires}
    .cpu-kpi
      span.cpu-kpi-label Fire time
      span.cpu-kpi-value #{h.time.ms(timers.fireTime)}
    .cpu-kpi
      span.cpu-kpi-label Timeout 0
      span.cpu-kpi-value #{timers.timeoutZeroInstalls}
    .cpu-kpi
      span.cpu-kpi-label Recurring
      span.cpu-kpi-value #{timers.recurringInstalls}
  if timers.byUrl && timers.byUrl.length > 0
    - const timerMax = timers.byUrl[0].fireTime
    .listing-card
      .listing-card-header
        h3.listing-card-title Timer cost by script
        span.listing-card-meta #{timers.byUrl.length} #{timers.byUrl.length === 1 ? 'script' : 'scripts'}
      .cpu-bars
        each entry in timers.byUrl
          - const pct = timerMax > 0 ? (entry.fireTime / timerMax * 100) : 0
          .cpu-bar-row
            if entry.url === 'unknown'
              span.cpu-bar-asset
                span.cpu-bar-anon Unattributed
            else
              a.cpu-bar-asset(href=entry.url, title=entry.url)= entry.label || h.shortAsset(entry.url, true)
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{entry.fireTime.toFixed(0)} ms
              span.cpu-bar-sub  · #{entry.installs} #{entry.installs === 1 ? 'install' : 'installs'} · #{entry.fires} #{entry.fires === 1 ? 'fire' : 'fires'}
  //- The individual timers, identified by install site (source
  //- position + timeout + kind). A polling loop reinstalling from
  //- the same line collapses into one row, so "45 installs,
  //- timeout 0" reads as one offender, not 45.
  if timers.sites && timers.sites.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title The timers themselves
        span.listing-card-meta top #{timers.sites.length} by fire time
      .responsive
        table
          thead
            tr
              th Installed by
              th.number Timeout
              th Type
              th.number Installs
              th.number Fires
              th.number Fire time
          tbody
            each site in timers.sites
              tr
                td
                  if site.url === 'unknown'
                    span.cpu-bar-anon Unattributed
                  else
                    //- `module` is the resolved ResourceLoader module
                    //- owning the install position — far more useful
                    //- than a line number inside a bundle. Full
                    //- url:line:column stays in the title.
                    a.cpu-site-link(href=site.url, title=site.url + (site.line ? ':' + site.line + ':' + site.column : ''))
                      if site.functionName
                        code= site.functionName
                        |  in&nbsp;
                      if site.module
                        code= site.module
                      else
                        | #{site.label || h.shortAsset(site.url, true)}#{site.line ? ':' + site.line : ''}
                td.number #{site.timeout} ms
                td= site.recurring ? 'recurring' : 'once'
                td.number #{site.installs}
                td.number #{site.fires}
                td.number #{site.fireTime.toFixed(1)} ms

//- Forced reflows — bug-pattern signal, ranked by which script is
//- causing them. Aggregated and filtered to ≥ 2 ms per individual
//- reflow so the busy-trace noise (100+ sub-ms layout events) gets
//- collapsed into a top-N actionable list.
if cpu && cpu.forcedReflows && cpu.forcedReflows.length > 0
  - const significant = cpu.forcedReflows.filter(r => r.duration >= 2)
  if significant.length > 0
    - const reflowGroups = {}
    - for (const r of significant) { const key = r.triggeredByUrl || '__anonymous__'; if (!reflowGroups[key]) { reflowGroups[key] = { url: r.triggeredByUrl, label: r.triggeredByUrlLabel, count: 0, total: 0, max: 0 } } const g = reflowGroups[key]; g.count++; g.total += r.duration; if (r.duration > g.max) g.max = r.duration }
    - const reflowEntries = Object.values(reflowGroups).sort((a, b) => b.total - a.total).slice(0, 10)
    - const reflowMax = reflowEntries[0].total
    a#cpu-forced-reflows
    h3
      +cpuIcon('refresh')
      | Forced reflows
    p A forced reflow happens when JavaScript reads a layout-triggering property (offsetTop, getBoundingClientRect, …) inside a handler, forcing the browser to synchronously recompute layout. The scripts below caused most of the page's reflows. Fix them in priority order.
    .listing-card
      .listing-card-header
        h3.listing-card-title Scripts causing reflows
        span.listing-card-meta #{significant.length} #{significant.length === 1 ? 'reflow' : 'reflows'} ≥ 2 ms across #{reflowEntries.length} #{reflowEntries.length === 1 ? 'script' : 'scripts'}
      .cpu-bars
        each entry in reflowEntries
          - const pct = reflowMax > 0 ? (entry.total / reflowMax * 100) : 0
          .cpu-bar-row
            span.cpu-bar-asset
              if entry.url
                a(href=entry.url, title=entry.url)= entry.label || h.shortAsset(entry.url, true)
              else
                span.cpu-bar-anon Anonymous / inline
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{entry.total.toFixed(0)} ms
              span.cpu-bar-sub  · #{entry.count} #{entry.count === 1 ? 'reflow' : 'reflows'} · worst #{entry.max.toFixed(0)} ms

//- Forced layout per script (from LoAF). Each LoAF script entry
//- carries `forcedStyleAndLayoutDuration` — the time spent inside
//- that script forcing synchronous style/layout work. This is
//- direct, browser-reported data; complements the trace-derived
//- forced-reflows above (which counts events, not durations).
if browsertime && browsertime.pageinfo && browsertime.pageinfo.loaf && browsertime.pageinfo.loaf.length > 0
  - const fsByScript = new Map()
  - for (const loaf of browsertime.pageinfo.loaf) { for (const s of (loaf.scripts || [])) { const dur = s.forcedStyleAndLayoutDuration || 0; if (dur === 0) continue; const url = s.sourceURL || ''; if (!url) continue; const entry = fsByScript.get(url) || { url, total: 0, count: 0 }; entry.total += dur; entry.count++; fsByScript.set(url, entry) } }
  - const fsEntries = Array.from(fsByScript.values()).filter(e => e.total >= 1).sort((a, b) => b.total - a.total).slice(0, 10)
  if fsEntries.length > 0
    - const fsMax = fsEntries[0].total
    a#cpu-forced-layout-per-script
    h3
      +cpuIcon('layout')
      | Forced layout per script
    p Each long animation frame reports how much time each script spent forcing synchronous style and layout, i.e. JavaScript reading layout-triggering properties mid-execution. Same actionable answer as forced reflows above but measured directly by the browser instead of inferred from the trace.
    .listing-card
      .listing-card-header
        h3.listing-card-title Scripts forcing layout
        span.listing-card-meta #{fsEntries.length} of #{fsByScript.size} #{fsByScript.size === 1 ? 'script' : 'scripts'}
      .cpu-bars
        each entry in fsEntries
          - const pct = fsMax > 0 ? (entry.total / fsMax * 100) : 0
          .cpu-bar-row
            a.cpu-bar-asset(href=entry.url, title=entry.url)= h.shortAsset(entry.url, true)
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{entry.total.toFixed(0)} ms
              span.cpu-bar-sub  · across #{entry.count} #{entry.count === 1 ? 'frame' : 'frames'}

//- First vs third party main-thread time (cpu.domains). Just the
//- headline split — the per-domain breakdown below (from the
//- thirdparty plugin) already lists individual domains/tools, so
//- repeating cpu.domains.domains here would be redundant.
if cpu && cpu.domains
  a#cpu-first-third-party
  h3
    +cpuIcon('globe')
    | First vs third party CPU time
  p Main-thread CPU time from the Chrome trace split by domain. First party is #{cpu.domains.firstPartyDomain}.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label First party
      span.cpu-kpi-value #{h.time.ms(cpu.domains.firstParty.toFixed(0))}
    .cpu-kpi
      span.cpu-kpi-label Third party
      span.cpu-kpi-value #{h.time.ms(cpu.domains.thirdParty.toFixed(0))}
    if cpu.domains.domains && cpu.domains.domains.length > 0
      .cpu-kpi
        span.cpu-kpi-label Domains
        span.cpu-kpi-value #{cpu.domains.domains.length}

//- CPU time per third-party tool / domain — context for the per-script
//- list above.
if pageInfo.data.thirdparty
  - const thirdparty = medianRun ? pageInfo.data.thirdparty.pageSummary.runs[medianRun.runIndex - 1] : pageInfo.data.thirdparty.run
  if thirdparty && thirdparty.cpuPerTool && Object.keys(thirdparty.cpuPerTool).length > 0
    a#cpu-time-per-tool
    h3
      +cpuIcon('globe')
      | CPU time per domain/tool
    - const tools = Object.entries(thirdparty.cpuPerTool).sort((a, b) => b[1] - a[1])
    - const toolMax = tools.length > 0 ? tools[0][1] : 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Domain / tool breakdown
        span.listing-card-meta #{tools.length} #{tools.length === 1 ? 'entity' : 'entities'}
      .cpu-bars
        each entry in tools
          - const pct = toolMax > 0 ? (entry[1] / toolMax * 100) : 0
          .cpu-bar-row
            span.cpu-bar-label #{entry[0]}
            .cpu-bar-track
              span.cpu-bar-fill(style='width: ' + pct.toFixed(2) + '%')
            span.cpu-bar-value #{entry[1].toFixed(1)} ms

//- Frame stability (cpu.frames) — how smoothly the compositor
//- produced frames during the traced window. Dropped frames and long
//- gaps between visual updates are invisible in load metrics.
//- effectiveFps and longestGap are omitted by browsertime when fewer
//- than two frames were presented.
if cpu && cpu.frames && cpu.frames.presented !== undefined
  a#cpu-frames
  h3
    +cpuIcon('activity')
    | Frames
  p Frame delivery from the Chrome trace. Dropped counts only frames Chrome flags as affecting smoothness. On mostly-static pages the longest gap includes idle time where there was simply nothing to draw.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Presented
      span.cpu-kpi-value #{cpu.frames.presented}
    .cpu-kpi
      span.cpu-kpi-label Partial
      span.cpu-kpi-value #{cpu.frames.partial}
    .cpu-kpi(class=cpu.frames.dropped === 0 ? 'ok' : (cpu.frames.dropped <= 5 ? 'warning' : 'error'))
      span.cpu-kpi-label Dropped
      span.cpu-kpi-value #{cpu.frames.dropped}
    if cpu.frames.effectiveFps !== undefined
      .cpu-kpi
        span.cpu-kpi-label Effective FPS
        span.cpu-kpi-value #{cpu.frames.effectiveFps}
    if cpu.frames.longestGap
      .cpu-kpi
        span.cpu-kpi-label Longest gap
        span.cpu-kpi-value #{h.time.ms(cpu.frames.longestGap.duration.toFixed(0))}
        span.cpu-kpi-sub at #{h.time.ms(cpu.frames.longestGap.startTime.toFixed(0))}

//- Non-composited animations — niche but actionable. Aggregated by
//- unsupported property since one bad animation on N elements
//- emits N events, and the actionable thing is "swap this property",
//- not "see all 9 instances". Chrome doesn't always report WHICH
//- property blocked compositing (compositeFailed set but no
//- unsupportedProperties) — those render as a plain list of the
//- animations instead, so the quicklink and the Rendering tab's
//- cross-link never point at a section that didn't render.
if cpu && cpu.nonCompositedAnimations && cpu.nonCompositedAnimations.length > 0
  - const propCounts = {}
  - for (const a of cpu.nonCompositedAnimations) { for (const p of (a.unsupportedProperties || [])) { propCounts[p] = (propCounts[p] || 0) + 1 } }
  - const propEntries = Object.entries(propCounts).sort((a, b) => b[1] - a[1])
  a#cpu-animations
  h3
    +cpuIcon('activity')
    | Non-composited animations
  p Animations that fell back from the compositor to the main thread, blocking each frame instead of running on the GPU.
  if propEntries.length > 0
    p Each chip below is a CSS property the page tried to animate that Chrome couldn't hand to the compositor. Swap it for a transform or opacity equivalent where you can.
    .listing-card
      .listing-card-header
        h3.listing-card-title Properties to fix
        span.listing-card-meta #{propEntries.length} #{propEntries.length === 1 ? 'property' : 'properties'} · #{cpu.nonCompositedAnimations.length} #{cpu.nonCompositedAnimations.length === 1 ? 'animation' : 'animations'}
      ul.cpu-anim-list
        each entry in propEntries
          li.cpu-anim-prop
            code= entry[0]
            span.cpu-anim-prop-count #{entry[1]}×
  else
    //- Chrome didn't say which property — but browsertime decodes the
    //- compositeFailed bitmask into failureReasons, and the reason
    //- decides the action: "animation has no visible change" is
    //- benign, "unsupported CSS property" is a fix. Older browsertime
    //- data has no failureReasons — fall back to listing the
    //- animations.
    - const reasonCounts = {}
    - for (const a of cpu.nonCompositedAnimations) { for (const r of (a.failureReasons || [])) { reasonCounts[r] = (reasonCounts[r] || 0) + 1 } }
    - const reasonEntries = Object.entries(reasonCounts).sort((a, b) => b[1] - a[1])
    .listing-card
      .listing-card-header
        h3.listing-card-title #{reasonEntries.length > 0 ? 'Why they could not be composited' : 'Animations on the main thread'}
        span.listing-card-meta #{cpu.nonCompositedAnimations.length} #{cpu.nonCompositedAnimations.length === 1 ? 'animation' : 'animations'}
      ul.cpu-anim-list
        if reasonEntries.length > 0
          each entry in reasonEntries
            li.cpu-anim-prop
              | #{entry[0]}
              span.cpu-anim-prop-count #{entry[1]}×
        else
          each animation in cpu.nonCompositedAnimations.slice(0, 10)
            li.cpu-anim-prop
              code= animation.name || '(unnamed animation)'
    if reasonEntries.length > 0
      p.small The reason decides the action: “animation has no visible change” means Chrome skipped compositing because nothing visible moves — harmless. Property-related reasons mean the keyframes animate something other than transform or opacity.
    else
      p.small Chrome flagged these as unable to run on the compositor but didn't report which CSS property caused it. Check their keyframes for properties other than transform and opacity.

//- First Input Delay — relegated to the bottom because it's an
//- older signal that's largely been superseded by INP, and on
//- automated test runs (no real user input) it's almost always
//- empty. Kept for completeness when scripted clicks are present.
if browsertime && browsertime.timings && browsertime.timings.firstInput !== undefined
  a#first-input-delay
  h3
    +cpuIcon('pointer')
    | First Input Delay
  - const fi = browsertime.timings.firstInput
  .cpu-card
    .cpu-card-header
      span.cpu-card-title #{fi.name}
    dl.cpu-fi-meta
      dt Delay
      dd #{h.time.ms(fi.delay)}
      dt Duration
      dd #{h.time.ms(fi.duration)}
      dt Start time
      dd #{h.time.ms(fi.startTime)}
      dt Processing start
      dd #{h.time.ms(fi.processingStart)}
      dt Processing end
      dd #{h.time.ms(fi.processingEnd)}

//- Trace download buttons (Chrome / Firefox / extra-run profile),
//- last on the tab — the raw data for readers who want to go deeper
//- than the sections above, not the first thing to look at.
//- Per-run buttons are gated on the per-run data existing (cpu.events /
//- geckoProfiler), not on enableProfileRun — with --cpu both the
//- measured-run trace and the extra-run trace exist side by side and
//- share one downloads row.
- const hasChromeTrace = cpu && cpu.events
- const hasChromeExtraTrace = options.browsertime && options.browsertime.enableProfileRun && options.browser === 'chrome'
if hasChromeTrace || hasChromeExtraTrace
  p Want to dig deeper? Download the Chrome trace and drag-and-drop it into Performance in DevTools.
  .downloads
    if hasChromeTrace
      - const tracePath = 'data/trace-' + (runNumber? runNumber : 1) + '.json.gz'
      a.button.button-download(href=tracePath, download=downloadName + '-timeline.json.gz') Download trace log
    if hasChromeExtraTrace
      a.button.button-download(href='data/trace-1-extra-run.json.gz', download=downloadName + '-extra-run-timeline.json.gz') Download extra-run trace

- const hasGeckoProfile = options.browsertime && options.browsertime.firefox && options.browsertime.firefox.geckoProfiler && options.browser === 'firefox'
- const hasGeckoExtraProfile = options.browsertime && options.browsertime.enableProfileRun && options.browser === 'firefox'
if hasGeckoProfile || hasGeckoExtraProfile
  p Want to dig deeper? Download the Firefox Gecko profile and drop it into&nbsp;
    a(href='https://profiler.firefox.com') profiler.firefox.com
    | .
  .downloads
    if hasGeckoProfile
      - const tracePath = 'data/geckoProfile-' + (runNumber? runNumber : 1) + '.json.gz'
      a.button.button-download(href=tracePath, download=downloadName + '-geckoProfile.json.gz') Download trace
    if hasGeckoExtraProfile
      a.button.button-download(href='data/geckoProfile-1-extra.json.gz', download=downloadName + '-extra-geckoProfile.json.gz') Download extra-run trace
