extends ../../layout.pug

block content
  - const d = pageInfo.data
  - runNumber = iteration
  - const daTitle = daurlAlias ? daurlAlias : daurl
  - const downloadName = (daTitle + '-' + runNumber + '-' + options.browser + '-' + timestamp).replace(/(https?\:\/\/)|( )|(:)/ig, '')

  h1 Run #{runNumber} summary
  h5.url
    a(href=daurl) #{decodeURIComponent(daTitle)}

  include ../includes/pageRunInfo

  if d.browsertime && d.browsertime.run
    b #{d.browsertime.run.title}
    p !{d.browsertime.run.description}

  p
    .large#pageNavigation All runs:&nbsp;
      each val, index in runPages
        - value = Number(index) + 1
        if (runNumber === value)
          span.label.normal.info #{value}
        else
          a(href='./' + value + '.html') #{value}
        if (value !== Object.keys(runPages).length)
          | &nbsp;-
          |

  if d.browsertime && d.browsertime.run.errors  && d.browsertime.run.errors.length > 0
    .errors
      b Errors
      ul
        each error in d.browsertime.run.errors
          li #{error}

  .index-link
    a.button.button--primary(href=urlLink) Back to summary

  //- Video and filmstrip are one merged Rendering tab/section. The old
  //- #video and #filmstrip anchors stay alive inside it (see
  //- rendering/index.pug and the alias mapping in tabScripts.js).
  - const hasRendering = !!(options.browsertime.video || ((options.browsertime.video || options.browsertime.visualMetrics) && options.videoParams && options.videoParams.createFilmstrip) || (options.browsertime.chrome && options.browsertime.chrome.enableTraceScreenshots))

  include ./tabs.pug

  #tabSections
    section#summary-panel
      h2 Summary

      //- Pull all values once up front so the markup below is just rendering.
      - performanceScore = get(d, 'coach.run.advice.performance.score')
      - totalTransferSize = get(d, 'pagexray.run.transferSize')
      - memory = get(d, 'browsertime.run.memory')
      - cpuConsumption = get(d, 'browsertime.run.cpuConsumption')
      - requests = get(d, 'pagexray.run.requests')
      - ttfb = get(d, 'browsertime.run.timings.pageTimings.backEndTime')
      - firstPaint = get(d, 'browsertime.run.timings.firstPaint')
      - fullyLoaded = get(d, 'browsertime.run.fullyLoaded')
      - fcp = get(d, 'browsertime.run.timings.paintTiming["first-contentful-paint"]')
      - lcp = get(d, 'browsertime.run.timings.largestContentfulPaint.renderTime')
      - cls = get(d, 'browsertime.run.pageinfo.cumulativeLayoutShift')
      - inp = get(d, 'browsertime.run.timings.interactionToNextPaint')
      - tbt = get(d, 'browsertime.run.cpu.longTasks.totalBlockingTime')
      - mpFID = get(d, 'browsertime.run.cpu.longTasks.maxPotentialFid')
      - longTasks = get(d, 'browsertime.run.cpu.longTasks.tasks')
      - maxLongTask = get(d, 'browsertime.run.cpu.longTasks.durations.max')
      - lastLongTask = get(d, 'browsertime.run.cpu.longTasks.lastLongTask')
      - firstVisualChange = get(d, 'browsertime.run.visualMetrics.FirstVisualChange')
      - speedIndex = get(d, 'browsertime.run.visualMetrics.SpeedIndex')
      - visualComplete85 = get(d, 'browsertime.run.visualMetrics.VisualComplete85')
      - visualComplete99 = get(d, 'browsertime.run.visualMetrics.VisualComplete99')
      - lastVisualChange = get(d, 'browsertime.run.visualMetrics.LastVisualChange')

      //- Threshold helpers shared by the hero band and inline badges.
      - lcpClass = (v) => v == null ? '' : (v >= 4000 ? 'error' : (v >= 2500 ? 'warning' : 'ok'))
      - fcpClass = (v) => v == null ? '' : (v >= 3000 ? 'error' : (v >= 1800 ? 'warning' : 'ok'))
      - clsClass = (v) => v == null ? '' : (v >= 0.25 ? 'error' : (v >= 0.1 ? 'warning' : 'ok'))
      - inpClass = (v) => v == null ? '' : (v >= 500 ? 'error' : (v >= 200 ? 'warning' : 'ok'))
      - perfClass = (v) => v == null ? '' : (typeof h.scoreLabel === 'function' ? h.scoreLabel(v) : 'info')

      //- Render-phase gap bar — full-width row above the hero KPIs and
      //- the per-section breakdowns. Splits the page-load timeline into
      //- phases the user can act on:
      //-   0     → TTFB   network (DNS + connect + server)
      //-   TTFB  → FCP    render-blocking (parse + CSS + critical JS)
      //-   FCP   → LCP    largest paint (image / text)
      //-   LCP   → loaded tail
      //- Renders only when we have at least TTFB + FCP + LCP for this run.
      if ttfb && fcp && lcp
        - const rpEnd = fullyLoaded && fullyLoaded > lcp ? fullyLoaded : lcp
        - const rpSegments = []
        - rpSegments.push({label: 'Network', short: '0 → TTFB', ms: ttfb, color: 'rgb(185,28,28)', help: 'Time spent in DNS, TCP, TLS and waiting for the server to start sending bytes.'})
        - rpSegments.push({label: 'Render-blocking', short: 'TTFB → FCP', ms: fcp - ttfb, color: 'rgb(217,119,6)', help: 'Time spent parsing HTML, fetching and parsing render-blocking CSS and critical JS before any pixel was painted.'})
        - rpSegments.push({label: 'Largest paint', short: 'FCP → LCP', ms: lcp - fcp, color: 'rgb(0, 149, 210)', help: 'Time between the first paint and the largest contentful paint — usually waiting on the hero image or a large block of text.'})
        - if (fullyLoaded && fullyLoaded > lcp) rpSegments.push({label: 'Tail', short: 'LCP → loaded', ms: fullyLoaded - lcp, color: 'rgb(124,58,237)', help: 'Time after LCP until the load event fires. Doesn\'t affect Web Vitals but still uses bandwidth and CPU.'})
        .listing-card.render-phase
          .listing-card-header
            h3.listing-card-title Where the time went
            span.listing-card-meta 0 → #{h.time.ms(rpEnd.toFixed(0))}
          .render-phase-body
            .render-phase-bar
              each seg in rpSegments
                - const w = (seg.ms / rpEnd * 100).toFixed(2)
                .render-phase-segment(style='width: ' + w + '%; --rp-color: ' + seg.color + ';', title=seg.label + ': ' + seg.ms.toFixed(0) + ' ms — ' + seg.help)
                  if Number(w) >= 8
                    span.render-phase-segment-label #{seg.label} #{h.time.ms(seg.ms.toFixed(0))}
            ul.render-phase-legend
              each seg in rpSegments
                li
                  span.render-phase-swatch(style='background: ' + seg.color + ';')
                  strong #{seg.label}
                  span.render-phase-legend-meta &nbsp;#{seg.short} · #{h.time.ms(seg.ms.toFixed(0))} (#{(seg.ms / rpEnd * 100).toFixed(0)}%)

      .row
        .one-half.column
          //- Hero KPIs (Core Web Vitals + Coach perf score). Matches the
          //- index page's hero treatment so per-iteration scanning feels
          //- the same as the executive summary.
          .iter-kpis
            if fcp
              .iter-kpi(class=fcpClass(fcp))
                span.iter-kpi-label FCP
                span.iter-kpi-value #{h.time.ms(fcp)}
            if lcp
              .iter-kpi(class=lcpClass(lcp))
                span.iter-kpi-label LCP
                span.iter-kpi-value #{h.time.ms(lcp)}
            if cls || cls === 0
              .iter-kpi(class=clsClass(cls))
                span.iter-kpi-label CLS
                span.iter-kpi-value #{cls.toFixed(3)}
            if typeof performanceScore === 'number'
              .iter-kpi(class=perfClass(performanceScore))
                span.iter-kpi-label Coach
                span.iter-kpi-value #{performanceScore}

          //- Grouped metric sections. Each is a card with a title and a
          //- 2-column dl; only renders when at least one of its metrics
          //- is present. <details open> lets readers collapse a group
          //- without losing the at-a-glance default view.
          if ttfb || firstPaint || fullyLoaded || inp || tbt || mpFID
            details.iter-group(open)
              summary.iter-group-summary
                span.iter-group-title Loading & responsiveness
              dl.iter-group-list
                if ttfb
                  dt TTFB
                  dd #{h.time.ms(ttfb)}
                if firstPaint
                  dt First Paint
                  dd #{h.time.ms(firstPaint)}
                if fullyLoaded
                  dt Fully Loaded
                  dd #{h.time.ms(fullyLoaded.toFixed(0))}
                if inp
                  dt Interaction to Next Paint
                  dd
                    span.label(class=inpClass(inp)) #{h.time.ms(inp)}
                if tbt
                  dt Total Blocking Time
                  dd #{h.time.ms(tbt)}
                if mpFID
                  dt Max Potential FID
                  dd #{h.time.ms(mpFID)}

          if totalTransferSize || memory || cpuConsumption || requests
            details.iter-group(open)
              summary.iter-group-summary
                span.iter-group-title Page weight & requests
              dl.iter-group-list
                if totalTransferSize
                  dt Total transfer size
                  dd #{h.size.format(totalTransferSize)}
                if requests
                  dt Requests
                  dd #{requests}
                if memory
                  dt Memory
                  dd #{h.size.format(memory)}
                if cpuConsumption
                  dt Firefox CPU power
                  dd #{(cpuConsumption * 1000).toFixed(1)} mWh

          if longTasks || maxLongTask || lastLongTask
            details.iter-group(open)
              summary.iter-group-summary
                span.iter-group-title CPU
              dl.iter-group-list
                if longTasks
                  dt CPU long tasks
                  dd #{longTasks}
                if maxLongTask
                  dt CPU longest task duration
                  dd #{h.time.ms(maxLongTask)}
                if lastLongTask
                  dt CPU last long task at
                  dd #{h.time.ms(lastLongTask)}

          if firstVisualChange || speedIndex || visualComplete85 || visualComplete99 || lastVisualChange
            details.iter-group(open)
              summary.iter-group-summary
                span.iter-group-title Visual progress
              dl.iter-group-list
                if firstVisualChange
                  dt First Visual Change
                  dd #{h.time.ms(firstVisualChange)}
                if speedIndex
                  dt Speed Index
                  dd #{h.time.ms(speedIndex)}
                if visualComplete85
                  dt Visual Complete 85%
                  dd #{h.time.ms(visualComplete85)}
                if visualComplete99
                  dt Visual Complete 99%
                  dd #{h.time.ms(visualComplete99)}
                if lastVisualChange
                  dt Last Visual Change
                  dd #{h.time.ms(lastVisualChange)}

        .one-half.column
          if hasScreenShots
            - screenshotName = 'data/screenshots/' + iteration + '/afterPageCompleteCheck.' + screenShotType
            - const width = options.mobile ? 150 : '100%';
            a(href=screenshotName)
              img.screenshot.iter-screenshot(src=screenshotName, width=width, alt='Screenshot')
      .downloads
        include ./downloads.pug
        include ./tcpdump.pug
    if d.browsertime && d.browsertime.run && d.browsertime.run.har
      section#waterfall-panel
        include ../waterfall/index.pug

    if hasRendering
      section#rendering-panel
        include ../rendering/index.pug

    if d.coach && d.coach.run
      section#coach-panel
        include ../coach/index.pug

    if d.browsertime && d.browsertime.run
      section#metrics-panel
        include ../metrics/index.pug

    if d.pagexray && d.pagexray.run
      section#pagexray-panel
        include ../pagexray/index.pug

    if options.cpu || (options.browsertime && options.browsertime.chrome && options.browsertime.chrome.collectLongTasks) || (options.browsertime && options.browsertime.firefox && options.browsertime.firefox.geckoProfiler || options.browsertime &&options.browsertime.enableProfileRun)
      section#cpu-panel
        include ../cpu/index.pug

    if d.thirdparty && d.thirdparty.run
      section#thirdparty-panel
        include ../thirdparty/index.pug

    if d.browsertime && d.browsertime.run
      section#screenshots-panel
        include ../screenshots/index.pug

    each pageRun in pageRuns
      - panelName = pageRun.id + '-panel'
      section(id=panelName)
        p !{pugs[pageRun.id]}
