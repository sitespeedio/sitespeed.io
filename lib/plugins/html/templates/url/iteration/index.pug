extends ../../layout.pug

block content
  - const d = pageInfo.data
  - runNumber = iteration
  - const daTitle = daurlAlias ? daurlAlias : daurl
  - const downloadName = (daTitle + '-' + runNumber + '-' + options.browser + '-' + timestamp).replace(/(https?\:\/\/)|( )|(:)/ig, '')

  h1 Run #{runNumber} summary
  p.url
    a(href=daurl) #{decodeURIComponent(daTitle)}

  include ../includes/pageRunInfo

  if d.browsertime && d.browsertime.run
    b #{d.browsertime.run.title}
    p !{d.browsertime.run.description}

  //- Run navigation: number-only chips (the current run highlighted)
  //- plus the side-by-side comparison page — no Summary pill here, the
  //- "Back to summary" button below already covers it. Keep the
  //- #pageNavigation id — tabScripts.js forwards the active tab hash
  //- when any link in it is clicked.
  nav.run-nav#pageNavigation(aria-label='Runs')
    span.run-nav-label Runs
    ul.run-nav-chips
      each val, index in runPages
        - value = Number(index) + 1
        li
          if (runNumber === value)
            span.run-nav-chip.run-nav-chip--current(aria-label='Run ' + value, aria-current='page') #{value}
          else
            a.run-nav-chip(href='./' + value + '.html', aria-label='Run ' + value) #{value}
    span.run-nav-sep
    a.run-nav-link(href='metrics.html') Side by side

  if d.browsertime && d.browsertime.run.errors  && d.browsertime.run.errors.length > 0
    .errors
      b Errors
      ul
        each error in d.browsertime.run.errors
          li #{error}

  .index-link
    a.button.button--primary(href=urlLink) Back to summary

  //- The Rendering tab exists whenever there is a render story to tell:
  //- video or filmstrip, this run's screenshots, render-blocking
  //- requests from the HAR, or recalculate-style data from the Chrome
  //- trace. The old #video, #filmstrip, #screenshots and
  //- #requests-render-blocking anchors stay alive inside it (see
  //- rendering/index.pug and the alias mapping in tabScripts.js).
  - const hasRenderingMedia = !!(options.browsertime.video || ((options.browsertime.video || options.browsertime.visualMetrics) && options.videoParams && options.videoParams.createFilmstrip) || (options.browsertime.chrome && options.browsertime.chrome.enableTraceScreenshots))
  - const runRecalculateStyle = d.browsertime && d.browsertime.run && d.browsertime.run.renderBlocking ? d.browsertime.run.renderBlocking.recalculateStyle : undefined
  //- The trace-derived CPU signals (forced reflows before first paint,
  //- non-composited animations) can exist while the recalculate-style
  //- data is empty — recalc needs an FCP/LCP event in the trace, the
  //- other trace analyses don't — so they get their own gate clause.
  //- Forced reflows only count when the run has an FCP: the why-section
  //- windows them to before first paint and hides them otherwise.
  - const runCpu = d.browsertime && d.browsertime.run ? d.browsertime.run.cpu : undefined
  - const runCpuFcp = d.browsertime && d.browsertime.run && d.browsertime.run.timings && d.browsertime.run.timings.paintTiming ? d.browsertime.run.timings.paintTiming['first-contentful-paint'] : undefined
  - const runCpuLcp = d.browsertime && d.browsertime.run && d.browsertime.run.timings && d.browsertime.run.timings.largestContentfulPaint ? d.browsertime.run.timings.largestContentfulPaint.renderTime : undefined
  //- Reflows are windowed to the latest paint milestone (LCP can land
  //- before FCP) — mirrors the why-section's prePaintReflows window.
  - const runCpuPaintEnd = Math.max(runCpuFcp || 0, runCpuLcp || 0) || undefined
  - const hasCpuRenderSignals = !!(runCpu && ((runCpuPaintEnd && runCpu.forcedReflows && runCpu.forcedReflows.filter(r => r.startTime < runCpuPaintEnd).reduce((total, r) => total + r.duration, 0) >= 10) || (runCpu.nonCompositedAnimations && runCpu.nonCompositedAnimations.length > 0) || (runCpu.frames && runCpu.frames.presented !== undefined)))
  //- A slow server delays everything that renders after it, so a TTFB
  //- past the Web Vitals good threshold (800 ms, same cutoff as the
  //- why-section's ttfbSlow — keep in sync) earns the tab on its own.
  - const runTtfbSlow = !!(d.browsertime && d.browsertime.run && d.browsertime.run.timings && d.browsertime.run.timings.ttfb && d.browsertime.run.timings.ttfb >= 800)
  - const hasRendering = hasRenderingMedia || runTtfbSlow || !!(d.browsertime && d.browsertime.run && d.browsertime.run.screenshots && d.browsertime.run.screenshots.length > 0) || !!(d.pagexray && d.pagexray.run && d.pagexray.run.renderBlocking) || !!(runRecalculateStyle && (runRecalculateStyle.beforeFCP || runRecalculateStyle.beforeLCP)) || hasCpuRenderSignals

  include ./tabs.pug

  #tabSections
    section#summary-panel
      h2 Summary

      //- Pull all values once up front so the markup below is just rendering.
      - performanceScore = get(d, 'coach.run.advice.performance.score')
      - totalTransferSize = get(d, 'pagexray.run.transferSize')
      - totalContentSize = get(d, 'pagexray.run.contentSize')
      - memory = get(d, 'browsertime.run.memory')
      - powerConsumption = get(d, 'browsertime.run.cpuConsumption')
      - requests = get(d, 'pagexray.run.requests')
      - ttfb = get(d, 'browsertime.run.timings.pageTimings.backEndTime')
      - firstPaint = get(d, 'browsertime.run.timings.firstPaint')
      - fullyLoaded = get(d, 'browsertime.run.fullyLoaded')
      - fcp = get(d, 'browsertime.run.timings.paintTiming["first-contentful-paint"]')
      - lcp = get(d, 'browsertime.run.timings.largestContentfulPaint.renderTime')
      - cls = get(d, 'browsertime.run.pageinfo.cumulativeLayoutShift')
      - inp = get(d, 'browsertime.run.timings.interactionToNextPaint')
      - tbt = get(d, 'browsertime.run.cpu.longTasks.totalBlockingTime')
      - mpFID = get(d, 'browsertime.run.cpu.longTasks.maxPotentialFid')
      - longTasks = get(d, 'browsertime.run.cpu.longTasks.tasks')
      - maxLongTask = get(d, 'browsertime.run.cpu.longTasks.durations.max')
      - lastLongTask = get(d, 'browsertime.run.cpu.longTasks.lastLongTask')
      - firstVisualChange = get(d, 'browsertime.run.visualMetrics.FirstVisualChange')
      - speedIndex = get(d, 'browsertime.run.visualMetrics.SpeedIndex')
      - visualComplete85 = get(d, 'browsertime.run.visualMetrics.VisualComplete85')
      - visualComplete99 = get(d, 'browsertime.run.visualMetrics.VisualComplete99')
      - lastVisualChange = get(d, 'browsertime.run.visualMetrics.LastVisualChange')

      - const overviewIsMedian = false
      include ../includes/_renderPhase

      //- The run's fullyLoaded is a float — show it without decimals.
      //- Convert after the render-phase bar so the bar keeps the exact
      //- value for its proportions.
      - if (fullyLoaded) fullyLoaded = Number(fullyLoaded.toFixed(0))

      .row
        .one-half.column
          include ../includes/_metricsKpis

        .one-half.column
          if hasScreenShots
            - screenshotName = 'data/screenshots/' + iteration + '/afterPageCompleteCheck.' + screenShotType
            - const width = options.mobile ? 150 : '100%';
            figure.shot-card
              a(href=screenshotName)
                img.iter-screenshot(src=screenshotName, width=width, alt='Screenshot')
              figcaption
                b Run #{iteration}
                |  · after page complete
      .downloads
        include ./downloads.pug
        include ./tcpdump.pug
    if d.browsertime && d.browsertime.run && d.browsertime.run.har
      section#waterfall-panel
        include ../waterfall/index.pug

    if hasRendering
      section#rendering-panel
        include ../rendering/index.pug

    if d.coach && d.coach.run
      section#coach-panel
        include ../coach/index.pug

    if d.browsertime && d.browsertime.run
      section#metrics-panel
        include ../metrics/index.pug

    if d.pagexray && d.pagexray.run
      section#pagexray-panel
        include ../pagexray/index.pug

    if options.cpu || (options.browsertime && options.browsertime.chrome && options.browsertime.chrome.collectLongTasks) || (options.browsertime && options.browsertime.firefox && options.browsertime.firefox.geckoProfiler || options.browsertime &&options.browsertime.enableProfileRun)
      section#cpu-panel
        include ../cpu/index.pug

    if d.thirdparty && d.thirdparty.run
      section#thirdparty-panel
        include ../thirdparty/index.pug

    each pageRun in pageRuns
      - panelName = pageRun.id + '-panel'
      section(id=panelName)
        p !{pugs[pageRun.id]}
