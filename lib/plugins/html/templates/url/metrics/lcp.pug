if timings.largestContentfulPaint
  - const lcp = timings.largestContentfulPaint
  - const lcpRender = lcp.renderTime || 0
  - const lcpLabel = (() => { if (lcpRender >= 4000) return 'error'; if (lcpRender >= 2500) return 'warning'; return 'ok'; })()
  - const phases = [{ key: 'ttfb', name: 'TTFB', value: lcp.ttfb || 0 }, { key: 'resource-delay', name: 'Resource load delay', value: lcp.resourceLoadDelay || 0 }, { key: 'resource-load', name: 'Resource load duration', value: lcp.resourceLoadDuration || 0 }, { key: 'render-delay', name: 'Element render delay', value: lcp.elementRenderDelay || 0 }]
  - const phaseTotal = phases.reduce((s, p) => s + p.value, 0)
  a#largestContentfulPaint
  h3 Largest Contentful Paint
  p When the page main content is rendered, collected via the Largest Contentful Paint API. Read more about
    |
    a(href='https://web.dev/largest-contentful-paint') Largest Contentful Paint
    | .
  .lcp-card
    .row
      .one-half.column
        .lcp-headline
          span.lcp-render-time(class=lcpLabel) #{h.time.ms(lcpRender)}
          span.lcp-headline-sub LCP render time
        if phaseTotal > 0
          h4.lcp-phases-heading Phase breakdown
          .lcp-bar
            each phase in phases
              if phase.value > 0
                - const pct = (phase.value / phaseTotal * 100)
                span.lcp-bar-segment(class='lcp-' + phase.key, style='flex: ' + pct.toFixed(2) + ' 0 0', title=phase.name + ': ' + h.time.ms(phase.value))
          ul.lcp-legend
            each phase in phases
              li
                span.lcp-legend-swatch(class='lcp-' + phase.key)
                span.lcp-legend-label= phase.name
                span.lcp-legend-value #{h.time.ms(phase.value)}

        h4.lcp-section-heading Element
        dl.lcp-meta
          if lcp.tagName
            dt Element type
            dd
              code &lt;#{lcp.tagName.toLowerCase()}&gt;
          if lcp.id !== ''
            dt Element id
            dd
              code= lcp.id
          if lcp.size
            dt Size (w × h)
            dd #{lcp.size}
          if lcp.url !== ''
            dt URL
            dd
              a(href=lcp.url) #{h.shortAsset(lcp.url)}
          dt Load time
          dd #{h.time.ms(lcp.loadTime)}
          if renderBlocking && renderBlocking.recalculateStyle.beforeLCP
            dt Recalculate-style elements before LCP
            dd #{renderBlocking.recalculateStyle.beforeLCP.elements} (#{h.time.ms(renderBlocking.recalculateStyle.beforeLCP.durationInMillis)})

        if lcp.domPath
          h4.lcp-section-heading DOM path
          pre.lcp-dompath
            code= lcp.domPath

      .one-half.column
        - const screenshotNo = medianRun ? medianRun.runIndex : (Number(runIndex) + 1)
        - const screenshotName = 'data/screenshots/' + screenshotNo + '/largestContentfulPaint.' + screenShotType
        a(href=screenshotName)
          img.screenshot.lcp-screenshot(src=screenshotName, alt='LCP')
        p.small The LCP element is highlighted in the screenshot. If nothing is highlighted the element was removed before the screenshot or the LCP API couldn't find it.
        if lcp.url !== ''
          p.small The Largest Contentful Paint API matched this image:
          a(href=lcp.url)
            img.screenshot.lcp-screenshot(src=lcp.url, alt='LCP element')
