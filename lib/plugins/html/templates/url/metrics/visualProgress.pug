//- Visual-progress curve as a self-contained inline SVG. The previous
//- implementation used chartist; pulling in the chartist runtime + 3
//- plugins on every per-page report just for this one chart wasn't
//- worth the ~50 KB. Same shape (filled area under the line) without
//- the JS dependency.

- const vpData = (visualMetrics && visualMetrics.VisualProgress) || []

if vpData.length > 0
  - const vpMax = Math.max(vpData[vpData.length - 1].timestamp, 100)
  - let vpFill = 'M 0 100'
  - let vpStroke = ''
  - let vpLastPercent = 0
  - for (let i = 0; i < vpData.length; i++) { const r = vpData[i]; const x = (r.timestamp / vpMax * 100).toFixed(2); const y = (100 - r.percent).toFixed(2); vpFill += ' L ' + x + ' ' + y; vpStroke += (i === 0 ? 'M ' : 'L ') + x + ' ' + y + ' '; vpLastPercent = r.percent }
  - const vpFinalY = (100 - vpLastPercent).toFixed(2)
  - vpFill += ' L 100 ' + vpFinalY + ' L 100 100 Z'
  - vpStroke += 'L 100 ' + vpFinalY
  - const vpTicks = Array.from({length: 6}, (_, i) => ({ pct: i * 20, sec: (i * 20 / 100 * vpMax) / 1000 }))

  .vp-chart
    svg.vp-svg(aria-hidden='true')&attributes({viewBox: '0 0 100 100', preserveAspectRatio: 'none'})
      path.vp-fill(d=vpFill)
      path.vp-stroke(d=vpStroke, fill='none')
    .vp-axis
      each tick in vpTicks
        span.vp-axis-tick(style='left: ' + tick.pct + '%') #{tick.sec.toFixed(1)}s
