include ../../_tableMixins
include ../includes/_quicklinks

- const pagexray = pageInfo.data.pagexray.run || pageInfo.data.pagexray.pageSummary;
- const _btCov = pageInfo.data.browsertime && pageInfo.data.browsertime.pageSummary && pageInfo.data.browsertime.pageSummary.coverage
- const hasCoverage = _btCov && ((_btCov.js && _btCov.js.length) || (_btCov.css && _btCov.css.length))

- const pagexrayLinks = []
- pagexrayLinks.push({href: '#pagexray-summary', label: 'Summary'})
- pagexrayLinks.push({href: '#largest-assets', label: 'Largest responses'})
- pagexrayLinks.push({href: '#requests-and-sizes-per-content-type', label: 'Per content type'})
- pagexrayLinks.push({href: '#data-per-domain', label: 'Per domain'})
- pagexrayLinks.push({href: '#expires-and-last-modified-stats', label: 'Expires & last-modified'})
if pageInfo.data.browsertime && pageInfo.data.browsertime.console
  - pagexrayLinks.push({href: '#console-log', label: 'Console'})
if pagexray.afterOnLoad.requests > 0
  - pagexrayLinks.push({href: '#requests-after-onload', label: 'After onLoad'})
if hasCoverage
  - pagexrayLinks.push({href: '#coverage', label: 'Coverage'})
+quicklinks(pagexrayLinks)

a
h2 PageXray
p.small How the page is built.

a#pagexray-summary

//- Summary stats as KPI tiles instead of two side-by-side tables.
- const cookieCount = pagexray.cookies != null ? pagexray.cookies : 0
- const thirdPartyCookies = pagexray.cookieNamesThirdParties ? pagexray.cookieNamesThirdParties.length : 0
//- Console errors are otherwise buried below five tables in the
//- Console log card — surface a count in the KPI row that jumps
//- there. SEVERE is the level the console log aggregator counts as
//- an error (see lib/plugins/browsertime/consoleLogAggregator.js).
- const consoleLog = (pageInfo.data.browsertime && pageInfo.data.browsertime.console) || []
- const consoleErrors = consoleLog.filter((entry) => entry.level === 'SEVERE').length
.pagexray-kpis
  .pagexray-kpi.info
    span.pagexray-kpi-label HTTP version
    span.pagexray-kpi-value-text #{pagexray.httpVersion}
  .pagexray-kpi
    span.pagexray-kpi-label Total requests
    span.pagexray-kpi-value #{pagexray.requests}
  .pagexray-kpi
    span.pagexray-kpi-label Total domains
    span.pagexray-kpi-value #{pagexray.totalDomains}
  .pagexray-kpi
    span.pagexray-kpi-label Transfer size
    span.pagexray-kpi-value #{h.size.format(pagexray.transferSize)}
  .pagexray-kpi
    span.pagexray-kpi-label Content size
    span.pagexray-kpi-value #{h.size.format(pagexray.contentSize)}
  if pagexray.missingCompression !== undefined
    .pagexray-kpi(class=pagexray.missingCompression > 0 ? 'warning' : 'ok')
      span.pagexray-kpi-label Missing compression
      span.pagexray-kpi-value #{pagexray.missingCompression}
  if cookieCount > 0
    .pagexray-kpi(class=thirdPartyCookies > 0 ? 'warning' : 'info')
      span.pagexray-kpi-label Cookies
      span.pagexray-kpi-value #{cookieCount}
      span.pagexray-kpi-sub #{thirdPartyCookies} third-party
  if consoleErrors > 0
    a.pagexray-kpi.error(href='#console-log')
      span.pagexray-kpi-label Console errors
      span.pagexray-kpi-value #{consoleErrors}
      span.pagexray-kpi-sub see the console log ↓

//- Response codes as a bar list — bigger codes (errors / redirects)
//- read at a glance against 2xx counts.
- const responseTotal = Object.values(pagexray.responseCodes).reduce((s, v) => s + v, 0)
- const codeClass = (code) => { const c = String(code); if (c.startsWith('5') || c === '0') return 'error'; if (c.startsWith('4')) return 'warning'; if (c.startsWith('3')) return 'info'; return 'ok'; }
if responseTotal > 0
  h3.pagexray-section-heading Response codes
  .pagexray-codes
    each total, code in pagexray.responseCodes
      - const pct = responseTotal > 0 ? (total / responseTotal * 100) : 0
      .pagexray-code-row
        span.pagexray-code-pill(class=codeClass(code)) #{code}
        .pagexray-code-track
          span.pagexray-code-fill(class=codeClass(code), style='width: ' + pct.toFixed(2) + '%')
        span.pagexray-code-value #{total}
        span.pagexray-code-pct #{pct.toFixed(1)}%

include ./largest.pug

include ./perContentType.pug

include ./perDomain.pug

a#expires-and-last-modified-stats
- expire = pagexray.expireStats
- lastModified = pagexray.lastModifiedStats
.listing-card
  .listing-card-header
    h3.listing-card-title Expires & last-modified statistics
  .responsive
    table(data-sortable)
      +rowHeading(['type', 'min', 'median', 'max'])
      if expire
        tr
          td(data-title='Type') Expires
          +durationCell('min', expire.min)
          +durationCell('median', expire.median)
          +durationCell('max', expire.max)
      if lastModified
        tr
          td(data-title='Type') Last modified
          +durationCell('min', lastModified.min)
          +durationCell('median', lastModified.median)
          +durationCell('max', lastModified.max)

if pageInfo.data.browsertime && pageInfo.data.browsertime.console
  include ./console.pug

include ./after.pug

//- The render-blocking requests card lives on the Rendering tab
//- (rendering/blocking.pug) — it is part of the render story, not of
//- how the page is built.

if hasCoverage
  include ../coverage/index.pug
