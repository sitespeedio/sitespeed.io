- const whyBt = pageInfo.data.browsertime
- const whyCpu = whyBt ? (isSummary ? (whyBt.pageSummary && whyBt.pageSummary.cpu ? whyBt.pageSummary.cpu[medianRun.runIndex - 1] : undefined) : (whyBt.run ? whyBt.run.cpu : undefined)) : undefined
- const whyTimings = whyBt ? (isSummary ? (whyBt.pageSummary && whyBt.pageSummary.browserScripts && whyBt.pageSummary.browserScripts[medianRun.runIndex - 1] ? whyBt.pageSummary.browserScripts[medianRun.runIndex - 1].timings : undefined) : (whyBt.run ? whyBt.run.timings : undefined)) : undefined
- const whyFcp = whyTimings && whyTimings.paintTiming ? whyTimings.paintTiming['first-contentful-paint'] : undefined
- const whyLcp = whyTimings && whyTimings.largestContentfulPaint ? whyTimings.largestContentfulPaint.renderTime : undefined
