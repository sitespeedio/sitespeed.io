  //- a trailing slash (www.cnet.com → www.cnet.com/) — compare with it
  //- stripped or the document row silently disappears.
  const rbSameUrl = (a, b) => !!a && !!b && (a === b || a.replace(/\/$/, '') === b.replace(/\/$/, ''))
  let rbHarPage
  let rbHarAware = false
  if (whyHar && whyHar.log && whyHar.log.pages && whyHar.log.entries) {
    //- Multi-page scripts store one HAR page per visited URL per run, so
    //- match on _url first and only then index by run; a single-page HAR
    //- without _url (older browsertime) still resolves.
    const candidates = whyHar.log.pages.filter(p => rbSameUrl(p._url, daurl))
    rbHarPage = isSummary ? candidates[medianRun.runIndex - 1] : (candidates.length === 1 ? candidates[0] : candidates[iteration - 1])
    if (!rbHarPage && whyHar.log.pages.length === 1) rbHarPage = whyHar.log.pages[0]
    rbHarAware = whyHar.log.entries.some(e => e._renderBlocking !== undefined)
  }
  let rbRows = []
  let rbFontRows = []
  let rbDocRow
  let rbLcpRow
  const rbLcpElement = whyTimings ? whyTimings.largestContentfulPaint : undefined
  //- Some servers ship fonts as application/octet-stream — fall back to
  //- the file extension so those fonts still get a context row.
  const rbIsFont = (type, url) => type === 'font' || /\.(woff2?|otf|ttf)([#?]|$)/i.test(url.split('?')[0])
  if (rbHarAware && rbHarPage) {
    const rbPageStart = Date.parse(rbHarPage.startedDateTime)
    const rbEntries = whyHar.log.entries.filter(e => e.pageref === rbHarPage.id)
    for (const entry of rbEntries) {
      const status = entry._renderBlocking
      const start = Date.parse(entry.startedDateTime) - rbPageStart
      const transfer = entry.response ? (entry.response._transferSize > 0 ? entry.response._transferSize : Math.max(entry.response.bodySize || 0, 0)) : 0
      const row = { url: entry.request.url, start, end: start + entry.time, duration: entry.time, transfer, type: rbShortType(entry.response && entry.response.content ? entry.response.content.mimeType : '') }
      if (!rbDocRow && rbSameUrl(entry.request.url, rbHarPage._url || daurl)) rbDocRow = row
      if (!rbLcpRow && rbLcpElement && rbLcpElement.url && entry.request.url === rbLcpElement.url) rbLcpRow = row
      if (status && !RB_NOT_BLOCKING.includes(rbNorm(status))) {
