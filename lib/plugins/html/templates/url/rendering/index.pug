//- slower devices) but keeps the trivial cases out. The page-level
//- hasRendering gates mirror this constant — keep them in sync.
- const prePaintReflowTotal = Math.round(prePaintReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
- const reflowsMaterial = prePaintReflowTotal >= 10
- const nonCompositedCount = whyCpu && whyCpu.nonCompositedAnimations ? whyCpu.nonCompositedAnimations.length : 0

