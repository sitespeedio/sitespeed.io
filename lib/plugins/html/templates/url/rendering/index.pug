              each frame, index in frames
                - const frameTitle = frame.timings && frame.timings.length > 0 ? frame.timings.map(timing => String(timing.name || timing.metric).replace(/<[^>]*>/g, '') + ' ' + h.time.ms(timing.duration || timing.value)).join(', ') : undefined
                .rendering-frame(class=frame.changed ? 'rendering-frame--changed' : null, data-t=frame.t, data-index=index, title=frameTitle, data-diff=frame.diff ? filmstripPath + frame.diff.file : undefined, data-diff-changed=frame.diff ? frame.diff.changedPixels : undefined, data-diff-share=frame.diff ? frame.diff.changedShare : undefined)
                  img(src=filmstripPath + frame.file, alt='Frame at ' + h.time.ms(frame.t), loading='lazy')
                  button.rendering-frame-zoom(type='button', aria-label='Enlarge frame') ⤢
                  .rendering-frame-time #{h.time.ms(frame.t)}
                  if frame.pct !== undefined
                    .rendering-frame-pct #{frame.pct} %
          p.rendering-strip-help
            if hasVideo
              | Click a frame to seek the video to that moment. The dot marks frames where the page changed visually.
            else
              | No video in this result. Click a frame to preview it, use the frame buttons or arrow keys to step, play replays the strip at its real pace. The dot marks frames where the page changed visually.

    //- Instability heatmap: browsertime's instability.png (written by
    //- create_frame_diffs under --videoParams.filmstripDiff) is the
    //- final frame ghosted with every pixel that changed during the
    //- recording, amber for a few changes up to red for many. The
    //- FrameInstability summary carries the shares; the image lives next
    //- to the filmstrip frames, so gate on hasFilmstrip.
    if hasFilmstrip && visualMetrics && visualMetrics.FrameInstability
      - const instability = visualMetrics.FrameInstability
      a#instability
      .listing-card.rendering-instability-card
        .listing-card-header
          h3.listing-card-title Visual instability
          span.listing-card-meta #{instability.changedShare} % of pixels ever changed · #{instability.repeatedlyChangedShare} % changed 5+ times
        .rendering-instability
          img(src=filmstripPath + 'instability.png', alt='Heatmap of how often each pixel changed while the page loaded', loading='lazy')
          .rendering-instability-notes
            p.rendering-why-note The whole recording in one image: every pixel is tinted by how often it changed. Amber changed once, deep red changed ten or more times. The scale is fixed, so heatmaps from different runs compare directly.
            p.rendering-why-note Flat amber is a page that painted once and stayed put. Red speckle in the shape of the text means the same pixels repainted over and over, usually invisible rendering noise that inflates Last Visual Change and Speed Index. A solid red block is a genuinely restless area, like an ad or a carousel.
    if frames.length > 0
      .rendering-lightbox#rendering-lightbox(hidden)
        .rendering-lightbox-backdrop#rendering-lightbox-backdrop
        figure.rendering-lightbox-figure
          img.rendering-lightbox-img#rendering-lightbox-img(alt='Filmstrip frame')
          //- The diff view: the frame dimmed with every pixel that
          //- changed since the previous filmstrip frame highlighted.
          //- Same sizing as the img; only one of the two is visible.
          canvas.rendering-lightbox-img#rendering-lightbox-canvas(hidden, aria-label='Difference against the previous frame')
          //- file:// fallback: canvas pixel access is blocked there
          //- (tainted canvas), so the diff is approximated in pure
          //- CSS — the current frame blended over the previous in
          //- difference mode, amplified and inverted so changes read
          //- as dark marks on white. No changed-pixel counts in this
          //- mode; the canvas path stays primary on http(s).
          .rendering-lightbox-img.rendering-lightbox-blend#rendering-lightbox-blend(hidden, aria-label='Approximate difference against the previous frame')
            img#rendering-lightbox-blend-base(alt='')
            img#rendering-lightbox-blend-top(alt='')
          figcaption.rendering-lightbox-bar
            button.rendering-button#rendering-lightbox-prev(type='button', aria-label='Previous frame') ⟨
            span.rendering-lightbox-meta#rendering-lightbox-meta
            button.rendering-button#rendering-lightbox-next(type='button', aria-label='Next frame') ⟩
            button.rendering-button#rendering-lightbox-diff(type='button', aria-pressed='false', title='Highlight what changed since the previous frame') Diff
            a.rendering-lightbox-original#rendering-lightbox-original(href='#', target='_blank', rel='noopener') Open original
            button.rendering-button#rendering-lightbox-close(type='button', aria-label='Close') ✕

  script(type='text/javascript')
    include ../includes/renderingView.js

//- Screenshots — the automatic (and user generated) screenshots from
//- this run. They exist without video, so the card is gated on the
//- data, not on the playback options.
if screenshots.length > 0
  a#screenshots
  .listing-card
    .listing-card-header
      h3.listing-card-title Screenshots
      span.listing-card-meta #{screenshots.length} #{screenshots.length === 1 ? 'screenshot' : 'screenshots'}
    //- Responsive thumbnail grid; click a card to open the full-size
    //- screenshot in a new tab. Auto-fit columns adapt to whatever
    //- viewport size the report is opened in, instead of stacking each
    //- screenshot at full width.
    .screenshots-gallery
      each screenshot in screenshots
        - const filename = screenshot.substring(screenshot.lastIndexOf('/') + 1, screenshot.length)
        - const screenshotName = rootPath + screenshot
        a.screenshot-card(id=filename, href=screenshotName)
          .screenshot-card-thumb-wrap
            img.screenshot-card-thumb(src=screenshotName, alt=filename, loading='lazy')
          .screenshot-card-caption #{filename}

//- Frame delivery (cpu.frames) — how smoothly the compositor produced
//- frames during the traced window. Dropped frames and long gaps
//- between visual updates are invisible in the load metrics but very
//- visible on screen. effectiveFps and longestGap are omitted by
//- browsertime when fewer than two frames were presented.
if hasFrames
  a#frames
  h3 Frames
  p How smoothly Chrome delivered frames to the screen during the test. Dropped counts only frames Chrome flags as affecting smoothness. On mostly-static pages the longest gap includes idle time where there was simply nothing to draw.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Frames shown
      span.cpu-kpi-value #{whyCpu.frames.presented}
    .cpu-kpi(title='Frames where only part of the screen updated in time')
      span.cpu-kpi-label Partial
      span.cpu-kpi-value #{whyCpu.frames.partial}
    .cpu-kpi(class=whyCpu.frames.dropped === 0 ? 'ok' : (whyCpu.frames.dropped <= 5 ? 'warning' : 'error'))
      span.cpu-kpi-label Dropped
      span.cpu-kpi-value #{whyCpu.frames.dropped}
    if whyCpu.frames.effectiveFps !== undefined
      .cpu-kpi
        span.cpu-kpi-label Effective FPS
        span.cpu-kpi-value #{whyCpu.frames.effectiveFps}
    if whyCpu.frames.longestGap
      .cpu-kpi
        span.cpu-kpi-label Longest gap
        span.cpu-kpi-value #{h.time.ms(whyCpu.frames.longestGap.duration.toFixed(0))}
        span.cpu-kpi-sub at #{h.time.ms(whyCpu.frames.longestGap.startTime.toFixed(0))}

//- Why was rendering delayed — the diagnostic half of the story.
if ttfbSlow || hasRecalculateStyle || hasRenderBlockingCard || showRecalculateHint || reflowsMaterial || nonCompositedCount > 0
  h3 Why was rendering delayed?

//- The verdict answers the section heading before the cards do, built
//- from milestones rather than sums (the document and the blocking
//- requests overlap — adding their durations double-counts): first
//- byte, last blocking request done, first paint; whatever first paint
//- time those leave unexplained is style and layout work. It absorbs
//- the old standalone slow-TTFB note (same 800 ms Web Vitals cutoff as
//- the Metrics tab's TTFB tile, same waterfall cross-link), so the
//- #slow-ttfb anchor now lands here. The FCP cutoff is Web Vitals'
//- good boundary. Only two tones on purpose: a warning names the
//- dominant cause, everything else is calm — it is a summary, not a
//- grade, so no red.
- const fcpSlow = !!(whyFcp && whyFcp > 1800)
- const verdictTone = (ttfbSlow || fcpSlow) ? 'warning' : 'ok'
//- The residual window is not only style and layout: web fonts can be
//- downloading through it (smashingmagazine: fonts loading until 94 %
//- of the paint clock while the old copy claimed pure style work),
//- and the trace has real numbers for part of it — recalc time before
//- FCP and pre-FCP forced reflows. Say what is known instead of
//- hand-waving; skip the parenthesis when the measured sum would
//- exceed the residual (overlap accounting can under throttle). With
//- nothing blocking, the residual anchors on the document instead —
//- the zero-blocking pages are exactly where the doc→paint gap begs
//- for an explanation.
- const rbResidualStart = !whyFcp ? undefined : (rbBlockingDone ? Math.max(rbBlockingDone, whyTtfb || 0) : (rbDocRow ? Math.max(Math.round(rbDocRow.end), whyTtfb || 0) : undefined))
- const rbResidual = rbHarAware && rbResidualStart !== undefined && rbResidualStart < whyFcp ? Math.round(whyFcp - rbResidualStart) : undefined
- const rbResidualFonts = rbResidualStart === undefined ? [] : rbFontRows.filter(f => f.end > rbResidualStart && f.end <= whyFcp)
- const rbResidualReflowMs = preFcpReflows.reduce((total, r) => total + r.duration, 0)
- const rbResidualMeasuredMs = Math.round(((recalculateStyle && recalculateStyle.beforeFCP && recalculateStyle.beforeFCP.durationInMillis) || 0) + rbResidualReflowMs)
- const rbLateBlocking = whyFcp && whyLcp && whyLcp - whyFcp > 100 ? rbRows.filter(r => r.status === 'blocking' && r.end !== undefined && r.end > whyFcp && r.end <= whyLcp) : []
if whyFcp || ttfbSlow
  a#slow-ttfb
  .rendering-verdict(class='rendering-verdict--' + verdictTone)
    span.rendering-verdict-dot
    p.rendering-verdict-text
      if ttfbSlow
        b The server dominated the wait.
        |  The first byte took&nbsp;
        b #{h.time.ms(whyTtfb)}
        if whyFcp
          |  (#{Math.round(whyTtfb / whyFcp * 100)} % of the time to First Contentful Paint)
        | . Nothing can render before it arrives, and Google Web Vitals considers a TTFB over 800 ms in need of improvement.
        if whyHar
          | &nbsp;
          a(href='#waterfall', onclick='const waterfallTab = document.querySelector("#tabs #waterfall"); if (waterfallTab) selectTab(waterfallTab, false)') See the request timing on the Waterfall tab
          | .
      else if fcpSlow
        b First paint took #{h.time.ms(whyFcp)}.
      else
        b Rendering was not meaningfully delayed.
      if whyFcp
        |  First paint landed at&nbsp;
        b #{h.time.ms(whyFcp)}
        if !ttfbSlow && whyTtfb
          |  on a #{h.time.ms(whyTtfb)} first byte
        if rbHarAware && rbRows.length === 0
          | , with no render-blocking requests
          if rbResidual !== undefined && rbResidual > 100
            | : the ~#{h.time.ms(rbResidual)} after the document is style#{rbResidualFonts.length > 0 ? ', layout and web-font loading' : ' and layout work'}
            if rbResidualMeasuredMs >= 5 && rbResidualMeasuredMs <= rbResidual
              |  (#{h.time.ms(rbResidualMeasuredMs)} of it measured style recalculation#{rbResidualReflowMs >= 1 ? ' and forced reflows' : ''})
        else if rbBlockingDone
          | ; the #{rbBlockingBeforeFcp.length} render-blocking #{rbBlockingBeforeFcp.length === 1 ? 'request was' : 'requests were'} done by #{h.time.ms(rbBlockingDone)}
          if rbResidual !== undefined && rbResidual > 100
            |  and the remaining ~#{h.time.ms(rbResidual)} is style#{rbResidualFonts.length > 0 ? ', layout and web-font loading' : ' and layout work'}
            if rbResidualMeasuredMs >= 5 && rbResidualMeasuredMs <= rbResidual
              |  (#{h.time.ms(rbResidualMeasuredMs)} of it measured style recalculation#{rbResidualReflowMs >= 1 ? ' and forced reflows' : ''})
        else if rbHarAware && rbBlockingRows.length > 0 && rbBlockingRows.every(r => r.end !== undefined)
          | ; none of the #{rbBlockingRows.length} render-blocking #{rbBlockingRows.length === 1 ? 'request' : 'requests'} held it up: #{rbBlockingRows.length === 1 ? 'it' : 'they'} loaded after the paint
        | .
      if whyFcp && whyLcp && whyLcp - whyFcp > 100
        |  The largest paint followed at&nbsp;
        b #{h.time.ms(whyLcp)}
        | .
        if rbLateBlocking.length > 0
          |  Note #{h.assetName(rbLateBlocking[0].url).name} finished at #{h.time.ms(Math.round(rbLateBlocking[0].end))}, between first and largest paint.
        if rbLcpElement && rbLcpElement.url && rbLcpElement.loadTime && whyLcp - rbLcpElement.loadTime > 300
          |  The LCP image itself was downloaded by #{h.time.ms(Math.round(rbLcpElement.loadTime))}; the wait was render work, not the network.

if hasRecalculateStyle
  a#recalculate-style
  .listing-card
    .listing-card-header
      h3.listing-card-title Style recalculation
      span.listing-card-meta measured by Chrome during this run
    p.listing-card-help
      | Style the browser had to recalculate before it could paint: many elements or a lot of time spent here points at expensive CSS on the critical rendering path. The recalculation count and the largest single one tell the two problems apart: one massive style change touching most of the page (few recalculations, the largest close to the total) needs different medicine than thousands of tiny ones (many recalculations, each tiny).
    //- Verdict up front: does this recalculation actually need attention,
    //- and if so which of the two shapes is it. Share of the paint it
    //- precedes is the materiality signal (reused in the note below);
    //- the largest single recalculation as a fraction of the total tells
    //- one big restyle apart from many small ones, which need different
    //- fixes. Numbers rounded to whole ms so the verdict stays readable.
    - const rcPrimary = recalculateStyle.beforeFCP || recalculateStyle.beforeLCP
    - const rcPaint = recalculateStyle.beforeFCP ? whyFcp : whyLcp
    - const rcThrottle = (options.browsertime && options.browsertime.chrome && options.browsertime.chrome.CPUThrottlingRate) || 1
    - const rcShare = rcPrimary && rcPaint ? Math.round(rcPrimary.durationInMillis / rcPaint * 1000) / 10 : undefined
    - const rcRealMs = rcPrimary ? rcPrimary.durationInMillis / rcThrottle : 0
    - const rcMaterial = !!rcPrimary && (rcShare === undefined ? rcRealMs >= 20 : (rcShare >= 5 && rcRealMs >= 10))
    - const rcBigShare = rcPrimary && rcPrimary.maxDurationInMillis !== undefined && rcPrimary.durationInMillis > 0 ? rcPrimary.maxDurationInMillis / rcPrimary.durationInMillis : 0
    - const rcShareWords = rcShare !== undefined ? rcShare + ' % of the time to ' + (recalculateStyle.beforeFCP ? 'First' : 'Largest') + ' Contentful Paint' : undefined
    if rcPrimary
      .rendering-verdict(class=rcMaterial ? 'rendering-verdict--warning' : 'rendering-verdict--ok')
        span.rendering-verdict-dot
        p.rendering-verdict-text
          if !rcMaterial
            b Style recalculation is not holding up your paint.
            |  #{h.time.ms(Math.round(rcPrimary.durationInMillis))} of restyling before the page painted#{rcShareWords ? ', ' + rcShareWords : ''}. Nothing here needs attention.
          else if rcBigShare >= 0.5
            b One large recalculation dominates.
            |  Restyling #{rcPrimary.elements.toLocaleString('sv-SE')} elements cost #{h.time.ms(Math.round(rcPrimary.durationInMillis))} before the page painted#{rcShareWords ? ' (' + rcShareWords + ')' : ''}, and a single recalculation of #{rcPrimary.maxElements.toLocaleString('sv-SE')} elements accounts for #{h.time.ms(Math.round(rcPrimary.maxDurationInMillis))} of it. Look for one class or inline-style change on a large container near the top of the DOM that restyles the whole subtree at once.
            if styleInvalidations
              |  The changes driving it are listed under Style invalidations below.
          else if rcPrimary.count !== undefined && rcPrimary.count >= 12
            b Style recalculation is spread across #{rcPrimary.count} restyles.
            |  #{h.time.ms(Math.round(rcPrimary.durationInMillis))} before the page painted#{rcShareWords ? ' (' + rcShareWords + ')' : ''}, in many small recalculations rather than one big one, the signature of JavaScript changing styles in a loop. Batch the DOM writes so the browser restyles once instead of every change.
            if styleInvalidations
              |  The changes driving it are listed under Style invalidations below.
          else
            b Style recalculation cost #{h.time.ms(Math.round(rcPrimary.durationInMillis))} before the page painted#{rcShareWords ? ' (' + rcShareWords + ')' : ''}.
            if styleInvalidations
              |  The changes driving it are listed under Style invalidations below.
    //- count / maxElements / maxDurationInMillis are additive fields
    //- (Browsertime PR #2496) — guard each so older browsertime data
    //- still renders the totals. One tile row per phase with a small
    //- heading, so the tile labels stay short and every tile keeps the
    //- same shape (value + sub-line where there is one).
    //- FCP and LCP are routinely the same paint on text pages, and the
    //- two windows then carry identical numbers — printed twice they
    //- read like a template bug. Collapse into one combined block when
    //- every field matches; windows that differ render separately.
    - const recalcSame = !!(recalculateStyle.beforeFCP && recalculateStyle.beforeLCP && ['count', 'elements', 'durationInMillis', 'maxElements', 'maxDurationInMillis'].every(key => recalculateStyle.beforeFCP[key] === recalculateStyle.beforeLCP[key]))
    - const recalcSamePaint = !!(whyFcp && whyLcp && Math.abs(whyLcp - whyFcp) <= 100)
    - const recalcPhases = []
    - if (recalcSame) recalcPhases.push(['Before first & largest contentful paint' + (recalcSamePaint ? ' (same paint, ' + h.time.ms(Math.round(Math.max(whyFcp, whyLcp))) + ')' : ''), recalculateStyle.beforeFCP])
    - if (!recalcSame && recalculateStyle.beforeFCP) recalcPhases.push(['Before first contentful paint', recalculateStyle.beforeFCP])
    - if (!recalcSame && recalculateStyle.beforeLCP) recalcPhases.push(['Before largest contentful paint', recalculateStyle.beforeLCP])
    each phase in recalcPhases
      - const phaseName = phase[0]
      - const recalc = phase[1]
      h4.rendering-phase-heading= phaseName
      .metric-tiles
        if recalc.count !== undefined
          .metric-tile
            span.metric-tile-label Recalculations
            span.metric-tile-value #{recalc.count}
        .metric-tile
          span.metric-tile-label Elements
          span.metric-tile-value #{recalc.elements}
        .metric-tile
          span.metric-tile-label Total time
          span.metric-tile-value #{h.time.ms(recalc.durationInMillis)}
        if recalc.maxElements !== undefined
          //- One value line like the neighbouring tiles — a sub-line
          //- here made this the only two-row tile in the row.
          .metric-tile
            span.metric-tile-label Largest recalculation
            span.metric-tile-value #{recalc.maxElements} elements#{recalc.maxDurationInMillis !== undefined ? ' · ' + h.time.ms(recalc.maxDurationInMillis) : ''}
    //- Scale for the numbers, mirroring the forced-reflows share note:
    //- milliseconds alone don't say whether recalculation mattered.
    - const recalcFcpShare = recalculateStyle.beforeFCP && whyFcp ? Math.round(recalculateStyle.beforeFCP.durationInMillis / whyFcp * 1000) / 10 : undefined
    if recalcFcpShare !== undefined
      p.rendering-why-note The recalculation work before first paint is #{recalcFcpShare} % of the time to First Contentful Paint.
else if showRecalculateHint
  //- The recalculate-style counts come from parsing a Chrome timeline
  //- trace, gated on --cpu / --chrome.timeline. The matching Firefox
  //- Gecko profile doesn't carry the same `UpdateLayoutTree.elementCount`
  //- events, so the hint is Chromium-only — pointing Firefox or Safari
  //- users at --cpu would be misleading.
  p.metrics-cpu-hint
    | Want to see how much CSS style-recalculation work delayed FCP and LCP, plus CPU long tasks? Run with&nbsp;
    code --cpu
    | .

if reflowsMaterial
  a#reflows-before-paint
  //- The totals count every pre-paint reflow, but the offender list drops
  //- sub-millisecond ones: a busy trace easily carries dozens of sub-ms
  //- layout events that are individually noise (they round to 0 ms) and
  //- would bury the reflows worth fixing — while leaving them out of the
  //- totals would under-report the aggregate cost.
  //- Round the float sums to one decimal so the tiles never show the
  //- 51.900000000000006-style floating point residue.
  - const preFcpTotal = Math.round(preFcpReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
  - const preLcpTotal = Math.round(preLcpReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
  - const topReflows = prePaintReflows.filter(r => r.duration >= 1).sort((a, b) => b.duration - a.duration).slice(0, 5)
  - const topReflowMax = topReflows.length > 0 ? topReflows[0].duration : 0
  .listing-card
    .listing-card-header
      h3.listing-card-title Forced reflows before the page painted
      span.listing-card-meta measured by Chrome during this run
    p.listing-card-help
      | JavaScript read a layout value (offsetTop, getBoundingClientRect, …) while the page was mid-change, so the browser had to re-layout synchronously, work that blocks rendering. Reflows before First Contentful Paint delayed the first pixels; reflows before Largest Contentful Paint delayed the main content.
    .metric-tiles
      if whyFcp
        .metric-tile
          span.metric-tile-label Forced reflows before FCP
          span.metric-tile-value #{preFcpReflows.length}
        .metric-tile
          span.metric-tile-label Time spent in forced reflows before FCP
          span.metric-tile-value #{h.time.ms(preFcpTotal)}
      if whyLcp
        .metric-tile
          span.metric-tile-label Forced reflows before LCP
          span.metric-tile-value #{preLcpReflows.length}
        .metric-tile
          span.metric-tile-label Time spent in forced reflows before LCP
          span.metric-tile-value #{h.time.ms(preLcpTotal)}
    //- Share of the milestone so the reader can judge scale — many small
    //- reflows are a thrashing pattern worth fixing, but the milliseconds
    //- alone rarely explain a slow paint.
    - const shareBase = whyLcp || whyFcp
    - const shareTotal = whyLcp ? preLcpTotal : preFcpTotal
    - const reflowShare = shareBase ? Math.round(shareTotal / shareBase * 1000) / 10 : undefined
    if reflowShare !== undefined
      p.rendering-why-note That is #{reflowShare} % of the time to #{whyLcp ? 'Largest' : 'First'} Contentful Paint. The number of reflows matters more than the milliseconds: layout thrashing multiplies on slower devices.
    if topReflows.length > 0
      .cpu-bars
        each reflow in topReflows
          - const pct = topReflowMax > 0 ? (reflow.duration / topReflowMax * 100) : 0
          .cpu-bar-row
            span.cpu-bar-asset
              if reflow.triggeredByUrl
                a(href=reflow.triggeredByUrl, title=reflow.triggeredByUrl)= h.shortAsset(reflow.triggeredByUrl, true)
              else
                span.cpu-bar-anon Inline or unnamed script
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{reflow.duration.toFixed(0)} ms
              span.cpu-bar-sub  · at #{h.time.ms(reflow.startTime)}
    p.listing-card-help
      a(href='#cpu-forced-reflows', onclick='const cpuTab = document.querySelector("#tabs #cpu"); if (cpuTab) selectTab(cpuTab, false)') See every forced reflow for the whole page load on the CPU tab

include ./blocking.pug

//- Slowest CSS selectors (cpu.selectorStats, profile run): the only
//- signal that says WHICH selectors the style-recalc time goes to.
//- Wasted selectors (thousands of match attempts, zero matches) get
//- their own list — they're pure removable cost.
//- The tables live in a mixin because they render in two states: open
//- as today when the totals matter, folded into a details element when
//- they don't. Mixins compile to standalone functions and can't see
//- block consts — the stats travel as the argument.
mixin selectorTables(stats)
  .listing-card
    .listing-card-header
      h3.listing-card-title Selectors by matching time
      span.listing-card-meta top #{stats.selectors.length}
    .responsive
      table
        thead
          tr
            th Selector
            th.number Time
            th.number Attempts
            th.number Matches
        tbody
          each s in stats.selectors.slice(0, 10)
            tr
              td.selector-cell
                code= s.selector
              td.number #{s.elapsed.toFixed(2)} ms
              td.number #{s.matchAttempts.toLocaleString('sv-SE')}
              td.number #{s.matchCount.toLocaleString('sv-SE')}
  if stats.wastedSelectors && stats.wastedSelectors.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Wasted selector work: attempts that never match
        span.listing-card-meta top #{stats.wastedSelectors.length}
      .responsive
        table
          thead
            tr
              th Selector
              th.number Attempts
              th.number Time
          tbody
            each s in stats.wastedSelectors.slice(0, 10)
              tr
                td.selector-cell
                  code= s.selector
                td.number #{s.matchAttempts.toLocaleString('sv-SE')}
                td.number #{s.elapsed.toFixed(2)} ms

if selectorStats && selectorStats.selectors && selectorStats.selectors.length > 0
  a#css-selectors
  h3
    | Slowest CSS selectors
    if selectorStatsFromProfileRun
      span.profile-run-badge(title=renderingProfileRunExplanation) Profile run
  p How long Chrome spent testing each CSS selector against the page while recalculating styles. A selector with many match attempts and zero matches is evaluated against the document over and over for rules that never apply.
  //- Micro-totals invite someone to spend an afternoon refactoring
  //- 0.07 ms selectors, so the card says whether acting on it can move
  //- anything. The threshold is on REAL time (the CPU throttle rate
  //- divided out): below ~50 ms of selector matching across the whole
  //- load, no paint metric can move enough to notice. Above it, the
  //- tables open and the verdict points at the wasted-work list.
  - const selectorThrottle = (options.browsertime && options.browsertime.chrome && options.browsertime.chrome.CPUThrottlingRate) || 1
  - const selectorRealMs = selectorStats.totalElapsed / selectorThrottle
  - const selectorsQuiet = selectorRealMs < 50
  .rendering-verdict(class=selectorsQuiet ? 'rendering-verdict--ok' : 'rendering-verdict--warning')
    span.rendering-verdict-dot
    p.rendering-verdict-text
      if selectorsQuiet
        b Not worth optimizing on this page.
        |  All selector matching cost&nbsp;
        b #{h.time.ms(selectorStats.totalElapsed.toFixed(0))}
        if selectorThrottle > 1
          |  under the #{selectorThrottle}× CPU throttle, roughly #{h.time.ms(Math.round(selectorRealMs))} real time
        | , and the worst single selector #{selectorStats.selectors[0].elapsed.toFixed(2)} ms. The tables are kept for reference.
      else
        b Selector matching cost #{h.time.ms(selectorStats.totalElapsed.toFixed(0))}#{selectorThrottle > 1 ? ' (roughly ' + h.time.ms(Math.round(selectorRealMs)) + ' without the ' + selectorThrottle + '× CPU throttle)' : ''}.
        |  The wasted-work list below (selectors tried thousands of times that never match) is the place to start.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Matching time
      span.cpu-kpi-value #{h.time.ms(selectorStats.totalElapsed.toFixed(0))}
    .cpu-kpi
      span.cpu-kpi-label Match attempts
      span.cpu-kpi-value #{selectorStats.totalMatchAttempts.toLocaleString('sv-SE')}
    .cpu-kpi
      span.cpu-kpi-label Matches
      span.cpu-kpi-value #{selectorStats.totalMatchCount.toLocaleString('sv-SE')}
  if selectorsQuiet
    details.rendering-details
      summary Show the selector tables anyway
      +selectorTables(selectorStats)
  else
    +selectorTables(selectorStats)

//- Style invalidations (cpu.styleInvalidations): why style/layout is
//- recalculated — which class/attribute changes keep invalidating
//- and which script causes it. The counts side of the
//- recalculate-style durations above.
if styleInvalidations
  a#style-invalidations
  h3
    | Style invalidations
    if styleInvalidationsFromProfileRun
      span.profile-run-badge(title=renderingProfileRunExplanation) Profile run
  p Why the browser had to recalculate style and layout: every DOM/style change invalidates some set of nodes, and the same class or attribute churning over and over is the pattern to hunt. Counts, not milliseconds: the time is in the style recalculation numbers above.
  //- Verdict: hand the developer the single biggest lever. When the
  //- trace carried paint timestamps we can say how much churned AFTER
  //- first paint (the actionable half, jank on a page the user already
  //- saw); otherwise we name the top trigger and point at the scripts
  //- list. Warning tone when there is a clear thing to look at, ok tone
  //- when it is almost all first-render work.
  - const siTopTrigger = styleInvalidations.triggers && styleInvalidations.triggers[0]
  - const siTimed = styleInvalidations.styleRecalcsAfterFirstPaint !== undefined || styleInvalidations.layoutInvalidationsAfterFirstPaint !== undefined
  - const siAfterRecalc = styleInvalidations.styleRecalcsAfterFirstPaint || 0
  - const siAfterLayout = styleInvalidations.layoutInvalidationsAfterFirstPaint || 0
  - const siTotal = styleInvalidations.styleRecalcs + styleInvalidations.layoutInvalidations
  - const siChurnLow = siTimed && siTotal > 0 && (siAfterRecalc + siAfterLayout) / siTotal < 0.15
  .rendering-verdict(class=siChurnLow ? 'rendering-verdict--ok' : 'rendering-verdict--warning')
    span.rendering-verdict-dot
    p.rendering-verdict-text
      if siChurnLow
        b Most of this is the page being built.
        |  Only #{siAfterRecalc.toLocaleString('sv-SE')} style recalculations and #{siAfterLayout.toLocaleString('sv-SE')} layout invalidations happened after first paint; the rest is the first render. Not much to chase here.
      else if siTimed
        b Chase what keeps changing after the page is up.
        |  #{siAfterRecalc.toLocaleString('sv-SE')} style recalculations and #{siAfterLayout.toLocaleString('sv-SE')} layout invalidations fired after first paint, on a page the user was already looking at.
        if siTopTrigger
          |  The biggest driver is #{siTopTrigger.kind}&nbsp;#[code= siTopTrigger.name] (#{siTopTrigger.count.toLocaleString('sv-SE')}×).
        |  Start with the script under "Scripts causing invalidations" that keeps triggering it.
      else if siTopTrigger
        b Start with what changes most.
        |  The biggest single driver is #{siTopTrigger.kind}&nbsp;#[code= siTopTrigger.name], changing #{siTopTrigger.count.toLocaleString('sv-SE')} times. Find the script that keeps doing it under "Scripts causing invalidations" and change it once, or move it off the load path.
      else
        b #{styleInvalidations.styleRecalcs.toLocaleString('sv-SE')} style recalculations and #{styleInvalidations.layoutInvalidations.toLocaleString('sv-SE')} layout invalidations.
        |  See which changes and scripts drive them below.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Style recalculations
      span.cpu-kpi-value #{styleInvalidations.styleRecalcs.toLocaleString('sv-SE')}
      if styleInvalidations.styleRecalcsAfterFirstPaint !== undefined
        span.cpu-kpi-sub #{styleInvalidations.styleRecalcsAfterFirstPaint.toLocaleString('sv-SE')} after first paint
    .cpu-kpi
      span.cpu-kpi-label Layout invalidations
      span.cpu-kpi-value #{styleInvalidations.layoutInvalidations.toLocaleString('sv-SE')}
      if styleInvalidations.layoutInvalidationsAfterFirstPaint !== undefined
        span.cpu-kpi-sub #{styleInvalidations.layoutInvalidationsAfterFirstPaint.toLocaleString('sv-SE')} after first paint
  if styleInvalidations.triggers && styleInvalidations.triggers.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Changes that keep invalidating
        span.listing-card-meta top #{styleInvalidations.triggers.length}
      ul.cpu-anim-list
        each trigger in styleInvalidations.triggers
          li.cpu-anim-prop
            code #{trigger.kind}: #{trigger.name}
            span.cpu-anim-prop-count #{trigger.count}×
  if styleInvalidations.recalcReasons && styleInvalidations.recalcReasons.length > 0
    //- Two splits, best data wins. Browsertime 28.2+ stamps every
    //- reason with afterFirstPaint from the trace timestamps — the
    //- honest boundary: what invalidated after the user saw content is
    //- churn, what came before is the page being built. Older data
    //- falls back to guessing by reason CATEGORY ("Added to layout",
    //- "Node was inserted into tree" are mostly construction) — an
    //- approximation the whisper copy admits: post-load script
    //- insertions land in the construction bucket too.
    - const invalidationsTimed = styleInvalidations.recalcReasons.some(r => r.afterFirstPaint !== undefined) || (styleInvalidations.layoutReasons || []).some(r => r.afterFirstPaint !== undefined)
    - const INVALIDATION_CONSTRUCTION = ['Added to layout', 'Node was inserted into tree']
    -
      const invalidationGroups = []
      if (invalidationsTimed) {
        const recalcList = styleInvalidations.recalcReasons
        const layoutList = styleInvalidations.layoutReasons || []
        const winOf = (list, pick) => list.map(r => ({ reason: r.reason, count: pick(r) })).filter(r => r.count > 0)
        const afterFcpOf = r => r.afterFirstPaint || 0
        const afterLcpOf = r => r.afterLargestContentfulPaint || 0
        //- Three windows when the LCP boundary is there and usable:
        //- invalidations BETWEEN the paints delayed the largest paint —
        //- the sharpest bucket on a "why was rendering delayed" tab.
        //- LCP can land before FCP in real traces; the between-window
        //- is then not derivable by subtraction, so those runs keep the
        //- plain first-paint split (the totals reveal the ordering).
        const lcpTimed = recalcList.some(r => r.afterLargestContentfulPaint !== undefined) || layoutList.some(r => r.afterLargestContentfulPaint !== undefined)
        const lcpUsable = lcpTimed && (styleInvalidations.styleRecalcsAfterLargestContentfulPaint || 0) <= (styleInvalidations.styleRecalcsAfterFirstPaint || 0) && (styleInvalidations.layoutInvalidationsAfterLargestContentfulPaint || 0) <= (styleInvalidations.layoutInvalidationsAfterFirstPaint || 0)
        let between
        if (lcpUsable) {
          between = { title: 'Between first and largest paint', help: 'Invalidations while the largest paint was still pending, so these delayed it.', quiet: false, recalc: winOf(recalcList, r => Math.max(0, afterFcpOf(r) - afterLcpOf(r))), layout: winOf(layoutList, r => Math.max(0, afterFcpOf(r) - afterLcpOf(r))) }
          if (between.recalc.length > 0 || between.layout.length > 0) invalidationGroups.push(between)
          else between = undefined
        }
        invalidationGroups.push(
          between
            ? { title: 'After the largest paint', help: 'Churn on the fully rendered page: wasted work and possible jank, but no paint delay.', quiet: false, recalc: winOf(recalcList, afterLcpOf), layout: winOf(layoutList, afterLcpOf) }
            : { title: 'After first paint', help: 'Invalidations on a page the user was already looking at, the actionable half.', quiet: false, recalc: winOf(recalcList, afterFcpOf), layout: winOf(layoutList, afterFcpOf) },
          { title: 'Before first paint: building the page', help: 'The page being constructed and styled for the first render. Expected work, shown for scale.', quiet: true, recalc: winOf(recalcList, r => r.count - afterFcpOf(r)), layout: winOf(layoutList, r => r.count - afterFcpOf(r)) }
        )
      } else {
        const split = (list, construction) => list.filter(r => INVALIDATION_CONSTRUCTION.includes(r.reason) === construction)
        invalidationGroups.push(
          { title: 'Churn after the page was built', help: 'Invalidations from styles and scripts changing things that already existed, the actionable half.', quiet: false, recalc: split(styleInvalidations.recalcReasons, false), layout: split(styleInvalidations.layoutReasons || [], false) },
          { title: 'Building the page', help: 'Nodes being added to the document and its layout: expected work for the initial render (scripts inserting content later land here too). Shown for scale, not as a problem.', quiet: true, recalc: split(styleInvalidations.recalcReasons, true), layout: split(styleInvalidations.layoutReasons || [], true) }
        )
      }
    //- Chrome's raw invalidation reason strings are internal jargon.
    //- Translate the ones we are sure of to plain language (raw string
    //- kept on hover), and attach a one-line fix to the few reasons a
    //- developer can actually act on. Unknown or unverified reasons
    //- (e.g. "Related style rule", "Attribute", "List value change")
    //- fall through to the raw string, so nothing is mislabelled and
    //- new Chrome reasons never vanish.
    -
      const INVALIDATION_REASON_LABELS = {
        'Affected by :has()': 'A :has() selector was re-evaluated',
        'Inline CSS style declaration was mutated': 'JavaScript changed an inline style',
        'Animation': 'An animation updated styles',
        '@keyframes rule change': 'An @keyframes rule changed',
        'Style rule change': 'A stylesheet rule changed',
        'PseudoClass': 'A pseudo-class state changed (:hover, :focus, …)',
        'Zoom': 'Page zoom changed',
        'Node was inserted into tree': 'A node was inserted into the page',
        'Fonts changed': 'A web font finished loading',
        'Added to layout': 'An element entered layout',
        'Removed from layout': 'An element left layout',
        'Size changed': "An element's size changed",
        'Style changed': 'A style change forced layout',
        'SVG changed': 'An SVG element changed'
      }
      const INVALIDATION_REASON_HINTS = {
        'Affected by :has()': ':has() re-checks a whole subtree on any change inside it. Scope it tightly, or toggle a class in JavaScript instead.',
        'Inline CSS style declaration was mutated': 'Set a class instead of writing element.style, so the browser can batch the work.',
        'Animation': 'Animate transform and opacity so the compositor can run it off the main thread.',
        'Fonts changed': 'Preload the font or use font-display so a late swap does not re-style the page.'
      }
      const reasonLabel = raw => INVALIDATION_REASON_LABELS[raw] || raw
      const reasonHint = raw => INVALIDATION_REASON_HINTS[raw]
    //- Pass the resolved label/hint as arguments: this partial is
    //- included into block content, so a mixin body cannot see the maps
    //- above (pug mixins compile to standalone functions).
    mixin invalidationReasonCell(label, hint, raw)
      td
        span.invalidation-reason(title=label === raw ? undefined : raw)= label
        if hint
          span.invalidation-reason-hint= hint
    .listing-card
      .listing-card-header
        h3.listing-card-title Invalidation reasons
        if invalidationsTimed
          span.listing-card-meta split at first paint
      each group in invalidationGroups
        if group.recalc.length > 0 || group.layout.length > 0
          h4.rendering-phase-heading= group.title
          p.listing-card-help= group.help
          .responsive(class=group.quiet ? 'invalidation-build' : undefined)
            table
              thead
                tr
                  th Reason
                  th.number Style recalculations
                  th.number Layout
              tbody
                each reason in group.recalc
                  tr
                    +invalidationReasonCell(reasonLabel(reason.reason), reasonHint(reason.reason), reason.reason)
                    td.number #{reason.count.toLocaleString('sv-SE')}
                    td.number –
                each reason in group.layout
                  tr
                    +invalidationReasonCell(reasonLabel(reason.reason), reasonHint(reason.reason), reason.reason)
                    td.number –
                    td.number #{reason.count.toLocaleString('sv-SE')}
  if styleInvalidations.sources && styleInvalidations.sources.length > 0
    - const invalidationMax = styleInvalidations.sources[0].count
    .listing-card
      .listing-card-header
        h3.listing-card-title Scripts causing invalidations
        span.listing-card-meta top #{styleInvalidations.sources.length}
      .cpu-bars
        each entry in styleInvalidations.sources
          - const pct = invalidationMax > 0 ? (entry.count / invalidationMax * 100) : 0
          .cpu-bar-row
            //- `module` is the resolved ResourceLoader module owning
            //- the source position — one giant load.php row split
            //- into the modules that actually churn the DOM.
            a.cpu-bar-asset(href=entry.url, title=entry.url)
              if entry.module
                code= entry.module
              else
                | #{entry.label || h.shortAsset(entry.url, true)}
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{entry.count.toLocaleString('sv-SE')}
              //- "230 · 230 after first paint" reads clumsily — say
              //- all/none when the split is one-sided.
              if entry.afterFirstPaint !== undefined
                - let afterWords = entry.afterFirstPaint.toLocaleString('sv-SE')
                - if (entry.afterFirstPaint === entry.count) afterWords = 'all'
                - if (entry.afterFirstPaint === 0) afterWords = 'none'
                span.cpu-bar-sub  · #{afterWords} after first paint

//- Non-composited animations are a jank signal, not a first-paint
//- delay — one quiet cross-link is enough, the CPU tab owns the detail.
if nonCompositedCount > 0
  a#main-thread-animations
  p.rendering-why-note
    | #{nonCompositedCount} #{nonCompositedCount === 1 ? 'animation runs' : 'animations run'} on the main thread instead of on the browser's fast path that animates without blocking other page work (the compositor); they can make the rendering you see above janky.&nbsp;
    a(href='#cpu-animations', onclick='const cpuTab = document.querySelector("#tabs #cpu"); if (cpuTab) selectTab(cpuTab, false)') See them on the CPU tab
    | .
