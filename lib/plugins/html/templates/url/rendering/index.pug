//- Rendering — the full render story on one tab. In reading order:
//- what the user saw (video player and/or filmstrip, or the
//- per-run screenshot gallery), then why rendering was delayed
//- (recalculate-style work and forced reflows before first paint from
//- the Chrome trace, the render-blocking requests from the HAR, and a
//- cross-link to the CPU tab when animations run on the main thread).
//-
//- The playback view degrades by configuration, never by file sniffing:
//-   video + filmstrip : player + transport + HUD + timeline + strip
//-   filmstrip only    : a large frame preview replaces the player,
//-                       frames/arrow keys drive it, play steps through
//-                       the frames, speed buttons and the download
//-                       link disappear
//-   video only        : player + timeline + HUD, no strip
//-   neither           : no player, preview, transport or strip at all —
//-                       the tab can still exist for the screenshots and
//-                       the why-was-rendering-delayed cards (page gating)
//-
//- #video, #filmstrip, #screenshots and #requests-render-blocking stay
//- as anchors inside this section so old deep links keep working — the
//- tab script maps them all to #rendering.

include ../includes/_quicklinks
include ../../_tableMixins

- const isSummary = !!medianRun
- const runIndex = isSummary ? medianRun.runIndex : iteration
- const videoIndex = options.browsertime.enableVideoRun ? '1' : runIndex
- const videoSrc = 'data/video/' + videoIndex + '.mp4'
- const filmstripPath = 'data/filmstrip/' + runIndex + '/'
- const hasVideo = !!(options.browsertime.video || (isSummary && options.browsertime.enableVideoRun))
- const hasFilmstrip = !!(((options.browsertime.video || options.browsertime.visualMetrics) && options.videoParams && options.videoParams.createFilmstrip) || (options.browsertime.chrome && options.browsertime.chrome.enableTraceScreenshots))

//- Why-section data. `pagexray` mirrors how the PageXray tab picks its
//- shape (run on iteration pages, pageSummary on the summary page) and
//- the recalculate-style block mirrors how the Metrics tab picks the
//- browsertime renderBlocking data for the same run.
- const pagexray = pageInfo.data.pagexray ? (pageInfo.data.pagexray.run || pageInfo.data.pagexray.pageSummary) : undefined
- const btRenderBlocking = pageInfo.data.browsertime ? (isSummary ? (pageInfo.data.browsertime.pageSummary && pageInfo.data.browsertime.pageSummary.renderBlocking ? pageInfo.data.browsertime.pageSummary.renderBlocking[medianRun.runIndex - 1] : undefined) : (pageInfo.data.browsertime.run ? pageInfo.data.browsertime.run.renderBlocking : undefined)) : undefined
- const recalculateStyle = btRenderBlocking ? btRenderBlocking.recalculateStyle : undefined
- const hasRecalculateStyle = !!(recalculateStyle && (recalculateStyle.beforeFCP || recalculateStyle.beforeLCP))
//- Screenshots are stored per iteration, so the gallery only exists on
//- the run pages — the summary page never had a screenshot gallery.
- const screenshots = (pageInfo.data.browsertime && pageInfo.data.browsertime.run && pageInfo.data.browsertime.run.screenshots) || []
- const showRecalculateHint = !hasRecalculateStyle && (options.browser === 'chrome' || options.browser === 'edge')

//- CPU-trace signals for the why-section: forced reflows before first
//- paint and non-composited animations. `whyCpu` follows the CPU tab's
//- run picking (per-run indexed array on the summary page, the run
//- object on iteration pages) and FCP comes from the same run, so the
//- before-first-paint window lines up with that run's trace.
- const whyBt = pageInfo.data.browsertime
- const whyCpu = whyBt ? (isSummary ? (whyBt.pageSummary && whyBt.pageSummary.cpu ? whyBt.pageSummary.cpu[medianRun.runIndex - 1] : undefined) : (whyBt.run ? whyBt.run.cpu : undefined)) : undefined
- const whyTimings = whyBt ? (isSummary ? (whyBt.pageSummary && whyBt.pageSummary.browserScripts && whyBt.pageSummary.browserScripts[medianRun.runIndex - 1] ? whyBt.pageSummary.browserScripts[medianRun.runIndex - 1].timings : undefined) : (whyBt.run ? whyBt.run.timings : undefined)) : undefined
- const whyFcp = whyTimings && whyTimings.paintTiming ? whyTimings.paintTiming['first-contentful-paint'] : undefined
- const whyLcp = whyTimings && whyTimings.largestContentfulPaint ? whyTimings.largestContentfulPaint.renderTime : undefined
//- A slow server delays every render milestone that follows, so it
//- belongs in the why-section. Same field and cutoff as the Metrics
//- tab's TTFB tile (gwvTtfbClass): 800 ms is where Web Vitals stops
//- calling a TTFB good.
- const whyTtfb = whyTimings && whyTimings.ttfb ? Math.round(whyTimings.ttfb) : undefined
- const ttfbSlow = !!(whyTtfb && whyTtfb >= 800)
//- Reflows are windowed to before the page painted — a reflow between
//- FCP and LCP still delays the largest paint (pages that paint early
//- and then thrash layout would otherwise show nothing here). The
//- window ends at the LATEST known paint milestone (LCP can land
//- before FCP in real runs). Whole-load reflow numbers live on the
//- CPU tab; without any paint milestone there is no window, so the
//- block stays hidden instead of falling back to whole-load numbers.
- const whyPaintEnd = Math.max(whyFcp || 0, whyLcp || 0) || undefined
- const preFcpReflows = whyCpu && whyCpu.forcedReflows && whyFcp ? whyCpu.forcedReflows.filter(r => r.startTime < whyFcp) : []
- const preLcpReflows = whyCpu && whyCpu.forcedReflows && whyLcp ? whyCpu.forcedReflows.filter(r => r.startTime < whyLcp) : []
- const prePaintReflows = whyCpu && whyCpu.forcedReflows && whyPaintEnd ? whyCpu.forcedReflows.filter(r => r.startTime < whyPaintEnd) : []
//- Materiality floor: a handful of milliseconds of pre-paint reflow on
//- a paint measured in hundreds is noise — showing it as a "why" card
//- oversells it. 10 ms is deliberately low (thrashing multiplies on
//- slower devices) but keeps the trivial cases out. The page-level
//- hasRendering gates mirror this constant — keep them in sync.
- const prePaintReflowTotal = Math.round(prePaintReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
- const reflowsMaterial = prePaintReflowTotal >= 10
- const nonCompositedCount = whyCpu && whyCpu.nonCompositedAnimations ? whyCpu.nonCompositedAnimations.length : 0

//- Selector stats and style invalidations belong to the rendering
//- story (they explain the style/layout work behind it). With
//- --enableProfileRun the samples come marked from the profile run
//- (pageSummary.<key> = { source, data }) — same fallback pattern as
//- the CPU tab's profile-run data.
- const renderingProfileAnalysis = key => isSummary && whyBt && whyBt.pageSummary && whyBt.pageSummary[key] ? whyBt.pageSummary[key].data : undefined
- const selectorStats = (whyCpu && whyCpu.selectorStats) || renderingProfileAnalysis('selectorStats')
- const selectorStatsFromProfileRun = !(whyCpu && whyCpu.selectorStats) && !!renderingProfileAnalysis('selectorStats')
//- With --cpu the measured runs carry invalidations too, but only
//- the profile run has the coverage bundles that resolve sources to
//- modules — prefer whichever sample carries that attribution.
- const measuredInvalidations = whyCpu && whyCpu.styleInvalidations
- const profileInvalidations = renderingProfileAnalysis('styleInvalidations')
- const invalidationsHaveModules = t => !!(t && t.sources && t.sources.some(source => source.module))
- const useProfileInvalidations = !!profileInvalidations && (!measuredInvalidations || (invalidationsHaveModules(profileInvalidations) && !invalidationsHaveModules(measuredInvalidations)))
- const styleInvalidations = useProfileInvalidations ? profileInvalidations : measuredInvalidations
- const styleInvalidationsFromProfileRun = useProfileInvalidations
- const renderingProfileRunExplanation = 'Collected in the single extra profile run made by --enableProfileRun, not in the timed iterations the rest of this page reports on.'

- const renderingLinks = []
//- Frame delivery lives here, not on the CPU tab: dropped frames and
//- long gaps are the smoothness half of "what did the user see".
- const hasFrames = !!(whyCpu && whyCpu.frames && whyCpu.frames.presented !== undefined)
- if (hasVideo || hasFilmstrip) renderingLinks.push({href: '#video', label: 'Playback'})
- if (hasFilmstrip) renderingLinks.push({href: '#filmstrip', label: 'Filmstrip'})
- if (screenshots.length > 0) renderingLinks.push({href: '#screenshots', label: 'Screenshots'})
- if (hasFrames) renderingLinks.push({href: '#frames', label: 'Frames'})
- if (ttfbSlow) renderingLinks.push({href: '#slow-ttfb', label: 'TTFB'})
- if (hasRecalculateStyle) renderingLinks.push({href: '#recalculate-style', label: 'Recalculate style'})
- if (reflowsMaterial) renderingLinks.push({href: '#reflows-before-paint', label: 'Forced reflows'})
- if (pagexray && pagexray.renderBlocking) renderingLinks.push({href: '#requests-render-blocking', label: 'Render-blocking requests'})
- if (selectorStats && selectorStats.selectors && selectorStats.selectors.length > 0) renderingLinks.push({href: '#css-selectors', label: 'CSS selectors'})
- if (styleInvalidations) renderingLinks.push({href: '#style-invalidations', label: 'Invalidations'})
- if (nonCompositedCount > 0) renderingLinks.push({href: '#main-thread-animations', label: 'Animations'})
//- A lone Playback pill is just noise — only show jump links when the
//- tab has more than one section to jump between.
if renderingLinks.length > 1
  +quicklinks(renderingLinks)

a#rendering

//- Runs without any playback media still land here for the why-section —
//- tell the reader what a video/visual-metrics run adds instead of
//- silently showing a smaller tab.
if !(hasVideo || hasFilmstrip) && (ttfbSlow || hasRecalculateStyle || (pagexray && pagexray.renderBlocking) || showRecalculateHint || screenshots.length > 0 || reflowsMaterial || nonCompositedCount > 0)
  p.rendering-nomedia
    | This test ran without&nbsp;
    code --video
    | &nbsp;and&nbsp;
    code --visualMetrics
    | , so there is no video, filmstrip or milestone timeline of how the page rendered. Add them to your run to see the page paint over time and to get visual metrics like First Visual Change and Speed Index.

if hasVideo || hasFilmstrip
  //- Milestones come from the run the video/filmstrip was recorded for
  //- (the median run on the summary page), not from the cross-run
  //- medians — the flags must line up with what the recording shows.
  - const bt = pageInfo.data.browsertime
  - const btRun = isSummary ? (bt && bt.pageSummary && bt.pageSummary.browserScripts ? bt.pageSummary.browserScripts[medianRun.runIndex - 1] : undefined) : (bt ? bt.run : undefined)
  - const timings = btRun ? btRun.timings : undefined
  - const visualMetrics = isSummary ? (bt && bt.pageSummary && bt.pageSummary.visualMetrics ? bt.pageSummary.visualMetrics[medianRun.runIndex - 1] : undefined) : (btRun ? btRun.visualMetrics : undefined)

  - const milestones = []
  - const addMilestone = (name, value) => { if (typeof value === 'number' && value > 0) milestones.push({ name, t: Math.round(value) }) }
  - if (timings && timings.pageTimings) addMilestone('TTFB', timings.pageTimings.backEndTime)
  - if (timings && timings.paintTiming) addMilestone('FCP', timings.paintTiming['first-contentful-paint'])
  - if (timings && timings.largestContentfulPaint) addMilestone('LCP', Math.max(timings.largestContentfulPaint.loadTime || 0, timings.largestContentfulPaint.renderTime || 0))
  - if (visualMetrics) { addMilestone('First visual', visualMetrics.FirstVisualChange); addMilestone('85% complete', visualMetrics.VisualComplete85); addMilestone('Speed Index', visualMetrics.SpeedIndex); addMilestone('Last visual', visualMetrics.LastVisualChange) }
  //- Sorted by when they actually happened — LCP can legitimately land
  //- before First Visual Change. Never reorder to the "expected" order
  //- and never clamp a value to make the timeline look tidy.
  - milestones.sort((a, b) => a.t - b.t)
  - const firstVisual = visualMetrics && visualMetrics.FirstVisualChange > 0 ? Math.round(visualMetrics.FirstVisualChange) : 0

  //- Per-frame completeness. VisualProgress samples are event-based —
  //- a sample is emitted only when the similarity-to-final-frame
  //- percent changes, so a frame's completeness is the most recent
  //- sample at or before its timestamp: stepped, never interpolated.
  - const frames = []
  - const vpSamples = (visualMetrics && visualMetrics.VisualProgress) || []
  - if (hasFilmstrip && typeof filmstrip !== 'undefined' && filmstrip) {
  -   let vpIndex = -1
  -   let previousFile = ''
  -   for (const frame of filmstrip) {
  -     const t = Math.round(frame.time * 1000)
  -     while (vpIndex + 1 < vpSamples.length && vpSamples[vpIndex + 1].timestamp <= t) vpIndex++
  -     const pct = vpIndex >= 0 ? vpSamples[vpIndex].percent : (vpSamples.length > 0 ? 0 : undefined)
  -     frames.push({ t, file: frame.file, pct, changed: previousFile !== '' && frame.file !== previousFile, timings: frame.timings })
  -     previousFile = frame.file
  -   }
  - }

  - const lastFrameT = frames.length > 0 ? frames[frames.length - 1].t : 0
  - const lastMilestoneT = milestones.length > 0 ? milestones[milestones.length - 1].t : 0
  - const renderingEnd = Math.max(Math.ceil(Math.max(lastFrameT, lastMilestoneT) * 1.05), 100)
  - const tickStep = renderingEnd <= 2000 ? 500 : (renderingEnd <= 6000 ? 1000 : (renderingEnd <= 15000 ? 2000 : 5000))
  - const ticks = []
  - for (let t = 0; t <= renderingEnd; t += tickStep) ticks.push(t)

  #rendering-view
    a#video
    .listing-card.rendering-card
      .listing-card-header
        h3.listing-card-title Rendering
        span.listing-card-meta
          | Run #{runIndex}
          if isSummary
            |  · median
          if hasVideo && options.browsertime.enableVideoRun
            |  · --enableVideoRun
          if !hasVideo
            |  · no video: the filmstrip drives the preview

      .rendering-stage
        if hasVideo
          video.rendering-video(preload='metadata', playsinline)
            source(src=videoSrc, type='video/mp4')
        else if frames.length > 0
          img.rendering-preview(src=filmstripPath + frames[0].file, alt='Selected filmstrip frame', title='Click to enlarge')

      .rendering-transport
        button.rendering-button.rendering-button--primary#rendering-play(type='button') ▶ Play
        if hasVideo
          button.rendering-button.rendering-speed.rendering-speed--active(type='button', data-speed='1') 1×
          button.rendering-button.rendering-speed(type='button', data-speed='0.5') 0.5×
          button.rendering-button.rendering-speed(type='button', data-speed='0.25') 0.25×
        if frames.length > 0
          button.rendering-button#rendering-step-back(type='button', aria-label='Previous frame') ⟨ frame
          button.rendering-button#rendering-step-forward(type='button', aria-label='Next frame') frame ⟩
        if firstVisual > 0
          button.rendering-button#rendering-jump(type='button', data-t=firstVisual) Jump to first visual change
        span.rendering-clock#rendering-clock 0.000 s

      if milestones.length > 0
        .rendering-hud
          each m in milestones
            button.rendering-chip(type='button', data-t=m.t)
              | #{m.name}&nbsp;
              b #{h.time.ms(m.t)}

        .rendering-timeline#rendering-timeline(data-end=renderingEnd)
          .rendering-axis#rendering-axis
          .rendering-axis-fill#rendering-fill
          .rendering-playhead#rendering-playhead
          - let lastFlagPct = -100
          - let lowLane = false
          each m in milestones
            - const flagPct = m.t / renderingEnd * 100
            - lowLane = (flagPct - lastFlagPct < 7) ? !lowLane : false
            - lastFlagPct = flagPct
            button.rendering-flag(type='button', class=lowLane ? 'rendering-flag--low' : null, style='left: ' + flagPct.toFixed(2) + '%', data-t=m.t)
              span.rendering-flag-label #{m.name} #{h.time.ms(m.t)}
              span.rendering-flag-stem
          each t in ticks
            span.rendering-tick(style='left: ' + (t / renderingEnd * 100).toFixed(2) + '%') #{t / 1000}s

      if hasVideo
        a.button.button-download.rendering-download(href=videoSrc, download=downloadName + '-video.mp4') Download video

    if hasFilmstrip
      a#filmstrip
      .listing-card.rendering-strip-card
        .listing-card-header
          h3.listing-card-title Filmstrip
          span.listing-card-meta #{frames.length} #{frames.length === 1 ? 'frame' : 'frames'}
          if frames.length > 0
            label.rendering-zoom
              | Zoom
              input#rendering-zoom(type='range', min='70', max='260', value='104', aria-label='Filmstrip frame size')
        if (options.filmstrip && options.filmstrip.showAll)
          p.listing-card-help
            | Showing all filmstrips. Set&nbsp;
            code --filmstrip.showAll
            | &nbsp;to false to only show the ones that contain a change.
        else
          p.listing-card-help
            | Use&nbsp;
            code --filmstrip.showAll
            | &nbsp;to show all filmstrips.
        if frames.length > 0
          .rendering-strip-scroll
            .rendering-strip#rendering-strip
              each frame, index in frames
                - const frameTitle = frame.timings && frame.timings.length > 0 ? frame.timings.map(timing => String(timing.name || timing.metric).replace(/<[^>]*>/g, '') + ' ' + h.time.ms(timing.duration || timing.value)).join(', ') : undefined
                .rendering-frame(class=frame.changed ? 'rendering-frame--changed' : null, data-t=frame.t, data-index=index, title=frameTitle)
                  img(src=filmstripPath + frame.file, alt='Frame at ' + h.time.ms(frame.t), loading='lazy')
                  button.rendering-frame-zoom(type='button', aria-label='Enlarge frame') ⤢
                  .rendering-frame-time #{h.time.ms(frame.t)}
                  if frame.pct !== undefined
                    .rendering-frame-pct #{frame.pct} %
          p.rendering-strip-help
            if hasVideo
              | Click a frame to seek the video to that moment. The dot marks frames where the page changed visually.
            else
              | No video in this result. Click a frame to preview it, use the frame buttons or arrow keys to step, play replays the strip at its real pace. The dot marks frames where the page changed visually.

    if frames.length > 0
      .rendering-lightbox#rendering-lightbox(hidden)
        .rendering-lightbox-backdrop#rendering-lightbox-backdrop
        figure.rendering-lightbox-figure
          img.rendering-lightbox-img#rendering-lightbox-img(alt='Filmstrip frame')
          figcaption.rendering-lightbox-bar
            button.rendering-button#rendering-lightbox-prev(type='button', aria-label='Previous frame') ⟨
            span.rendering-lightbox-meta#rendering-lightbox-meta
            button.rendering-button#rendering-lightbox-next(type='button', aria-label='Next frame') ⟩
            a.rendering-lightbox-original#rendering-lightbox-original(href='#', target='_blank', rel='noopener') Open original
            button.rendering-button#rendering-lightbox-close(type='button', aria-label='Close') ✕

  script(type='text/javascript')
    include ../includes/renderingView.js

//- Screenshots — the automatic (and user generated) screenshots from
//- this run. They exist without video, so the card is gated on the
//- data, not on the playback options.
if screenshots.length > 0
  a#screenshots
  .listing-card
    .listing-card-header
      h3.listing-card-title Screenshots
      span.listing-card-meta #{screenshots.length} #{screenshots.length === 1 ? 'screenshot' : 'screenshots'}
    //- Responsive thumbnail grid; click a card to open the full-size
    //- screenshot in a new tab. Auto-fit columns adapt to whatever
    //- viewport size the report is opened in, instead of stacking each
    //- screenshot at full width.
    .screenshots-gallery
      each screenshot in screenshots
        - const filename = screenshot.substring(screenshot.lastIndexOf('/') + 1, screenshot.length)
        - const screenshotName = rootPath + screenshot
        a.screenshot-card(id=filename, href=screenshotName)
          .screenshot-card-thumb-wrap
            img.screenshot-card-thumb(src=screenshotName, alt=filename, loading='lazy')
          .screenshot-card-caption #{filename}

//- Frame delivery (cpu.frames) — how smoothly the compositor produced
//- frames during the traced window. Dropped frames and long gaps
//- between visual updates are invisible in the load metrics but very
//- visible on screen. effectiveFps and longestGap are omitted by
//- browsertime when fewer than two frames were presented.
if hasFrames
  a#frames
  h3 Frames
  p Frame delivery from the Chrome trace. Dropped counts only frames Chrome flags as affecting smoothness. On mostly-static pages the longest gap includes idle time where there was simply nothing to draw.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Presented
      span.cpu-kpi-value #{whyCpu.frames.presented}
    .cpu-kpi
      span.cpu-kpi-label Partial
      span.cpu-kpi-value #{whyCpu.frames.partial}
    .cpu-kpi(class=whyCpu.frames.dropped === 0 ? 'ok' : (whyCpu.frames.dropped <= 5 ? 'warning' : 'error'))
      span.cpu-kpi-label Dropped
      span.cpu-kpi-value #{whyCpu.frames.dropped}
    if whyCpu.frames.effectiveFps !== undefined
      .cpu-kpi
        span.cpu-kpi-label Effective FPS
        span.cpu-kpi-value #{whyCpu.frames.effectiveFps}
    if whyCpu.frames.longestGap
      .cpu-kpi
        span.cpu-kpi-label Longest gap
        span.cpu-kpi-value #{h.time.ms(whyCpu.frames.longestGap.duration.toFixed(0))}
        span.cpu-kpi-sub at #{h.time.ms(whyCpu.frames.longestGap.startTime.toFixed(0))}

//- Why was rendering delayed — the diagnostic half of the story.
if ttfbSlow || hasRecalculateStyle || (pagexray && pagexray.renderBlocking) || showRecalculateHint || reflowsMaterial || nonCompositedCount > 0
  h3 Why was rendering delayed?

//- The server answer comes before everything else in the render story,
//- so a slow TTFB leads the why-list. One number carries the message —
//- a note with the share of FCP for scale, not a card of tiles.
if ttfbSlow
  a#slow-ttfb
  p.rendering-why-note
    | The server took&nbsp;
    b #{h.time.ms(whyTtfb)}
    | &nbsp;to deliver the first byte
    if whyFcp
      |  (#{Math.round(whyTtfb / whyFcp * 100)} % of the time to First Contentful Paint)
    | . Nothing can render before the first byte arrives, and Google Web Vitals considers a TTFB over 800 ms in need of improvement.
    //- The Waterfall tab only exists when the run produced a HAR — don't
    //- render a dead cross-link without one. The HAR sits on
    //- browsertime.har on the summary page and browsertime.run.har on
    //- run pages, mirroring how each page's tabs.pug gates the tab.
    - const whyHar = whyBt ? (isSummary ? whyBt.har : (whyBt.run && whyBt.run.har)) : undefined
    if whyHar
      | &nbsp;
      a(href='#waterfall', onclick='const waterfallTab = document.querySelector("#tabs #waterfall"); if (waterfallTab) selectTab(waterfallTab, false)') See the request timing on the Waterfall tab
      | .

if hasRecalculateStyle
  a#recalculate-style
  .listing-card
    .listing-card-header
      h3.listing-card-title Recalculate style
      span.listing-card-meta from the Chrome trace
    p.listing-card-help
      | Style the browser had to recalculate before it could paint: many elements or a lot of time spent here points at expensive CSS on the critical rendering path. The event count and the largest single event tell the two problems apart: one massive style invalidation (few events, the largest close to the total) needs different medicine than thousands of small forced recalcs (many events, each tiny).
    //- count / maxElements / maxDurationInMillis are additive fields
    //- (Browsertime PR #2496) — guard each so older browsertime data
    //- still renders the totals. One tile row per phase with a small
    //- heading, so the tile labels stay short and every tile keeps the
    //- same shape (value + sub-line where there is one).
    - const recalcPhases = []
    - if (recalculateStyle.beforeFCP) recalcPhases.push(['Before first contentful paint', recalculateStyle.beforeFCP])
    - if (recalculateStyle.beforeLCP) recalcPhases.push(['Before largest contentful paint', recalculateStyle.beforeLCP])
    each phase in recalcPhases
      - const phaseName = phase[0]
      - const recalc = phase[1]
      h4.rendering-phase-heading= phaseName
      .metric-tiles
        if recalc.count !== undefined
          .metric-tile
            span.metric-tile-label Events
            span.metric-tile-value #{recalc.count}
        .metric-tile
          span.metric-tile-label Elements
          span.metric-tile-value #{recalc.elements}
        .metric-tile
          span.metric-tile-label Total time
          span.metric-tile-value #{h.time.ms(recalc.durationInMillis)}
        if recalc.maxElements !== undefined
          //- One value line like the neighbouring tiles — a sub-line
          //- here made this the only two-row tile in the row.
          .metric-tile
            span.metric-tile-label Largest event
            span.metric-tile-value #{recalc.maxElements} elements#{recalc.maxDurationInMillis !== undefined ? ' · ' + h.time.ms(recalc.maxDurationInMillis) : ''}
else if showRecalculateHint
  //- The recalculate-style counts come from parsing a Chrome timeline
  //- trace, gated on --cpu / --chrome.timeline. The matching Firefox
  //- Gecko profile doesn't carry the same `UpdateLayoutTree.elementCount`
  //- events, so the hint is Chromium-only — pointing Firefox or Safari
  //- users at --cpu would be misleading.
  p.metrics-cpu-hint
    | Want recalculate-style metrics for FCP and LCP, plus CPU long tasks? Run with&nbsp;
    code --cpu
    | .

if reflowsMaterial
  a#reflows-before-paint
  //- The totals count every pre-paint reflow, but the offender list drops
  //- sub-millisecond ones: a busy trace easily carries dozens of sub-ms
  //- layout events that are individually noise (they round to 0 ms) and
  //- would bury the reflows worth fixing — while leaving them out of the
  //- totals would under-report the aggregate cost.
  //- Round the float sums to one decimal so the tiles never show the
  //- 51.900000000000006-style floating point residue.
  - const preFcpTotal = Math.round(preFcpReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
  - const preLcpTotal = Math.round(preLcpReflows.reduce((total, r) => total + r.duration, 0) * 10) / 10
  - const topReflows = prePaintReflows.filter(r => r.duration >= 1).sort((a, b) => b.duration - a.duration).slice(0, 5)
  - const topReflowMax = topReflows.length > 0 ? topReflows[0].duration : 0
  .listing-card
    .listing-card-header
      h3.listing-card-title Forced reflows before the page painted
      span.listing-card-meta from the Chrome trace
    p.listing-card-help
      | JavaScript read a layout value (offsetTop, getBoundingClientRect, …) while the page was mid-change, so the browser had to re-layout synchronously, work that blocks rendering. Reflows before First Contentful Paint delayed the first pixels; reflows before Largest Contentful Paint delayed the main content.
    .metric-tiles
      if whyFcp
        .metric-tile
          span.metric-tile-label Forced reflows before FCP
          span.metric-tile-value #{preFcpReflows.length}
        .metric-tile
          span.metric-tile-label Time spent in forced reflows before FCP
          span.metric-tile-value #{h.time.ms(preFcpTotal)}
      if whyLcp
        .metric-tile
          span.metric-tile-label Forced reflows before LCP
          span.metric-tile-value #{preLcpReflows.length}
        .metric-tile
          span.metric-tile-label Time spent in forced reflows before LCP
          span.metric-tile-value #{h.time.ms(preLcpTotal)}
    //- Share of the milestone so the reader can judge scale — many small
    //- reflows are a thrashing pattern worth fixing, but the milliseconds
    //- alone rarely explain a slow paint.
    - const shareBase = whyLcp || whyFcp
    - const shareTotal = whyLcp ? preLcpTotal : preFcpTotal
    - const reflowShare = shareBase ? Math.round(shareTotal / shareBase * 1000) / 10 : undefined
    if reflowShare !== undefined
      p.rendering-why-note That is #{reflowShare} % of the time to #{whyLcp ? 'Largest' : 'First'} Contentful Paint. The number of reflows matters more than the milliseconds: layout thrashing multiplies on slower devices.
    if topReflows.length > 0
      .cpu-bars
        each reflow in topReflows
          - const pct = topReflowMax > 0 ? (reflow.duration / topReflowMax * 100) : 0
          .cpu-bar-row
            span.cpu-bar-asset
              if reflow.triggeredByUrl
                a(href=reflow.triggeredByUrl, title=reflow.triggeredByUrl)= h.shortAsset(reflow.triggeredByUrl, true)
              else
                span.cpu-bar-anon Anonymous / inline
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value
              | #{reflow.duration.toFixed(0)} ms
              span.cpu-bar-sub  · at #{h.time.ms(reflow.startTime)}
    p.listing-card-help
      a(href='#cpu-forced-reflows', onclick='const cpuTab = document.querySelector("#tabs #cpu"); if (cpuTab) selectTab(cpuTab, false)') See every forced reflow for the whole page load on the CPU tab

include ./blocking.pug

//- Slowest CSS selectors (cpu.selectorStats, profile run): the only
//- signal that says WHICH selectors the style-recalc time goes to.
//- Wasted selectors (thousands of match attempts, zero matches) get
//- their own list — they're pure removable cost.
if selectorStats && selectorStats.selectors && selectorStats.selectors.length > 0
  a#css-selectors
  h3
    | Slowest CSS selectors
    if selectorStatsFromProfileRun
      span.profile-run-badge(title=renderingProfileRunExplanation) Profile run
  p Per-selector matching cost during style recalculation, from Chrome's selector stats. A selector with many match attempts and zero matches is evaluated against the document over and over for rules that never apply.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Matching time
      span.cpu-kpi-value #{h.time.ms(selectorStats.totalElapsed.toFixed(0))}
    .cpu-kpi
      span.cpu-kpi-label Match attempts
      span.cpu-kpi-value #{selectorStats.totalMatchAttempts.toLocaleString('sv-SE')}
    .cpu-kpi
      span.cpu-kpi-label Matches
      span.cpu-kpi-value #{selectorStats.totalMatchCount.toLocaleString('sv-SE')}
  .listing-card
    .listing-card-header
      h3.listing-card-title Selectors by matching time
      span.listing-card-meta top #{selectorStats.selectors.length}
    .responsive
      table
        thead
          tr
            th Selector
            th.number Time
            th.number Attempts
            th.number Matches
        tbody
          each s in selectorStats.selectors.slice(0, 10)
            tr
              td.selector-cell
                code= s.selector
              td.number #{s.elapsed.toFixed(2)} ms
              td.number #{s.matchAttempts.toLocaleString('sv-SE')}
              td.number #{s.matchCount.toLocaleString('sv-SE')}
  if selectorStats.wastedSelectors && selectorStats.wastedSelectors.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Wasted selector work — attempts that never match
        span.listing-card-meta top #{selectorStats.wastedSelectors.length}
      .responsive
        table
          thead
            tr
              th Selector
              th.number Attempts
              th.number Time
          tbody
            each s in selectorStats.wastedSelectors.slice(0, 10)
              tr
                td.selector-cell
                  code= s.selector
                td.number #{s.matchAttempts.toLocaleString('sv-SE')}
                td.number #{s.elapsed.toFixed(2)} ms

//- Style invalidations (cpu.styleInvalidations): why style/layout is
//- recalculated — which class/attribute changes keep invalidating
//- and which script causes it. The counts side of the
//- recalculate-style durations above.
if styleInvalidations
  a#style-invalidations
  h3
    | Style invalidations
    if styleInvalidationsFromProfileRun
      span.profile-run-badge(title=renderingProfileRunExplanation) Profile run
  p Why the browser had to recalculate style and layout: every DOM/style change invalidates some set of nodes, and the same class or attribute churning over and over is the pattern to hunt. Counts, not milliseconds — the time is in the recalculate style numbers above.
  .cpu-kpis
    .cpu-kpi
      span.cpu-kpi-label Style recalcs
      span.cpu-kpi-value #{styleInvalidations.styleRecalcs.toLocaleString('sv-SE')}
    .cpu-kpi
      span.cpu-kpi-label Layout invalidations
      span.cpu-kpi-value #{styleInvalidations.layoutInvalidations.toLocaleString('sv-SE')}
  if styleInvalidations.triggers && styleInvalidations.triggers.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Changes that keep invalidating
        span.listing-card-meta top #{styleInvalidations.triggers.length}
      ul.cpu-anim-list
        each trigger in styleInvalidations.triggers
          li.cpu-anim-prop
            code #{trigger.kind}: #{trigger.name}
            span.cpu-anim-prop-count #{trigger.count}×
  if styleInvalidations.recalcReasons && styleInvalidations.recalcReasons.length > 0
    .listing-card
      .listing-card-header
        h3.listing-card-title Invalidation reasons
      .responsive
        table
          thead
            tr
              th Reason
              th.number Style recalc
              th.number Layout
          tbody
            each reason in styleInvalidations.recalcReasons
              tr
                td= reason.reason
                td.number #{reason.count.toLocaleString('sv-SE')}
                td.number –
            each reason in styleInvalidations.layoutReasons
              tr
                td= reason.reason
                td.number –
                td.number #{reason.count.toLocaleString('sv-SE')}
  if styleInvalidations.sources && styleInvalidations.sources.length > 0
    - const invalidationMax = styleInvalidations.sources[0].count
    .listing-card
      .listing-card-header
        h3.listing-card-title Scripts causing invalidations
        span.listing-card-meta top #{styleInvalidations.sources.length}
      .cpu-bars
        each entry in styleInvalidations.sources
          - const pct = invalidationMax > 0 ? (entry.count / invalidationMax * 100) : 0
          .cpu-bar-row
            //- `module` is the resolved ResourceLoader module owning
            //- the source position — one giant load.php row split
            //- into the modules that actually churn the DOM.
            a.cpu-bar-asset(href=entry.url, title=entry.url)
              if entry.module
                code= entry.module
              else
                | #{entry.label || h.shortAsset(entry.url, true)}
            .cpu-bar-track
              span.cpu-bar-fill(style=`width: ${pct.toFixed(2)}%`)
            span.cpu-bar-value #{entry.count.toLocaleString('sv-SE')}

//- Non-composited animations are a jank signal, not a first-paint
//- delay — one quiet cross-link is enough, the CPU tab owns the detail.
if nonCompositedCount > 0
  a#main-thread-animations
  p.rendering-why-note
    | #{nonCompositedCount} #{nonCompositedCount === 1 ? 'animation runs' : 'animations run'} on the main thread instead of the compositor; they can make the rendering you see above janky.&nbsp;
    a(href='#cpu-animations', onclick='const cpuTab = document.querySelector("#tabs #cpu"); if (cpuTab) selectTab(cpuTab, false)') See them on the CPU tab
    | .
