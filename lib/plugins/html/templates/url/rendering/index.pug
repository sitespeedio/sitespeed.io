//- only then is an empty list a real "nothing blocked rendering".
- const whyHar = whyBt ? (isSummary ? whyBt.har : (whyBt.run && whyBt.run.har)) : undefined
-
  const rbNorm = v => String(v).split('_').join('').toLowerCase()
  const RB_NOT_BLOCKING = ['nonblocking', 'nonblockingdynamic', 'dynamicallyinjectednonblocking']
  const rbShortType = mime => {
    if (!mime) return ''
    if (mime.includes('css')) return 'css'
    if (mime.includes('javascript') || mime.includes('ecmascript')) return 'javascript'
    if (mime.includes('html')) return 'html'
    if (mime.includes('font')) return 'font'
    return mime.split('/').pop().split(';')[0]
  }
