extends ./layout.pug

block content
  include ../includes/_quicklinks

  - const d = pageInfo.data
  - const daTitle = daurlAlias ? daurlAlias : daurl
  - const downloadName = (daTitle + '-' + options.browser + '-' + timestamp).replace(/(https?\:\/\/)|( )|(:)/ig, '')
  h1 Page summary

  p.url
    a(href=daurl) #{decodeURIComponent(daTitle)}

  include ../includes/pageRunInfo

  if d.browsertime && d.browsertime.pageSummary
    b #{d.browsertime.pageSummary.info.title}
    p !{d.browsertime.pageSummary.info.description}

  if d.browsertime && d.browsertime.pageSummary && d.browsertime.pageSummary.markedAsFailure
    .errors
      b This test was marked as a failure with the following #{h.plural(d.browsertime.pageSummary.failureMessages.length, 'message')}:
      ul
        each failureMessage in d.browsertime.pageSummary.failureMessages
          li #{failureMessage}

  //- Run navigation: number-only chips so tests with 20+ runs stay on
  //- one line, plus the side-by-side comparison page. Keep the
  //- #pageNavigation id — tabScripts.js forwards the active tab hash
  //- when any link in it is clicked.
  nav.run-nav#pageNavigation(aria-label='Runs')
    span.run-nav-label Runs
    ul.run-nav-chips
      each val, index in runPages
        - value = Number(index) + 1
        li
          a.run-nav-chip(href='./' + value + '.html', aria-label='Run ' + value) #{value}
    span.run-nav-sep
    a.run-nav-link(href='metrics.html') Side by side

  if pageInfo.errors
    .errors
      b Errors
      ul
        each errors, tool in pageInfo.errors
          each error in errors
            li #{error} 
              b (#{tool})
  //- The Rendering tab exists whenever there is a render story to tell:
  //- video or filmstrip, render-blocking requests from the HAR, or
  //- recalculate-style data from the Chrome trace. The old #video,
  //- #filmstrip and #requests-render-blocking anchors stay alive inside
  //- it (see rendering/index.pug and the alias mapping in tabScripts.js).
  - const hasRenderingMedia = !!(options.browsertime.video || options.browsertime.enableVideoRun || ((options.browsertime.video || options.browsertime.visualMetrics) && options.videoParams && options.videoParams.createFilmstrip) || (options.browsertime.chrome && options.browsertime.chrome.enableTraceScreenshots))
  - const summaryRecalculateStyle = d.browsertime && d.browsertime.pageSummary && d.browsertime.pageSummary.renderBlocking && d.browsertime.pageSummary.renderBlocking[medianRun.runIndex - 1] ? d.browsertime.pageSummary.renderBlocking[medianRun.runIndex - 1].recalculateStyle : undefined
  //- The trace-derived CPU signals (forced reflows before first paint,
  //- non-composited animations) can exist while the recalculate-style
  //- data is empty — recalc needs an FCP/LCP event in the trace, the
  //- other trace analyses don't — so they get their own gate clause.
  //- Forced reflows only count when the run has an FCP: the why-section
  //- windows them to before first paint and hides them otherwise.
  - const summaryCpu = d.browsertime && d.browsertime.pageSummary && d.browsertime.pageSummary.cpu ? d.browsertime.pageSummary.cpu[medianRun.runIndex - 1] : undefined
  - const summaryCpuTimings = d.browsertime && d.browsertime.pageSummary && d.browsertime.pageSummary.browserScripts && d.browsertime.pageSummary.browserScripts[medianRun.runIndex - 1] ? d.browsertime.pageSummary.browserScripts[medianRun.runIndex - 1].timings : undefined
  - const summaryCpuFcp = summaryCpuTimings && summaryCpuTimings.paintTiming ? summaryCpuTimings.paintTiming['first-contentful-paint'] : undefined
  - const summaryCpuLcp = summaryCpuTimings && summaryCpuTimings.largestContentfulPaint ? summaryCpuTimings.largestContentfulPaint.renderTime : undefined
  //- Reflows are windowed to the latest paint milestone (LCP can land
  //- before FCP) — mirrors the why-section's prePaintReflows window.
  - const summaryCpuPaintEnd = Math.max(summaryCpuFcp || 0, summaryCpuLcp || 0) || undefined
  - const hasCpuRenderSignals = !!(summaryCpu && ((summaryCpuPaintEnd && summaryCpu.forcedReflows && summaryCpu.forcedReflows.filter(r => r.startTime < summaryCpuPaintEnd).reduce((total, r) => total + r.duration, 0) >= 10) || (summaryCpu.nonCompositedAnimations && summaryCpu.nonCompositedAnimations.length > 0) || (summaryCpu.frames && summaryCpu.frames.presented !== undefined)))
  //- A slow server delays everything that renders after it, so a TTFB
  //- past the Web Vitals good threshold (800 ms, same cutoff as the
  //- why-section's ttfbSlow — keep in sync) earns the tab on its own.
  - const summaryTtfbSlow = !!(summaryCpuTimings && summaryCpuTimings.ttfb && summaryCpuTimings.ttfb >= 800)
  - const hasRendering = hasRenderingMedia || summaryTtfbSlow || !!(d.pagexray && d.pagexray.pageSummary && d.pagexray.pageSummary.renderBlocking) || !!(summaryRecalculateStyle && (summaryRecalculateStyle.beforeFCP || summaryRecalculateStyle.beforeLCP)) || hasCpuRenderSignals

  include ./tabs.pug

  #tabSections
    section#summary-panel
      - const summaryLinks = []
      - summaryLinks.push({href: '#summary', label: 'Summary'})
      if h.get(pageInfo.data, 'browsertime.pageSummary.statistics')
        - summaryLinks.push({href: '#browsertime-timing-statistics', label: 'Timings summary'})
      if options.browsertime.tcpdump
        - summaryLinks.push({href: '#tcpdump', label: 'Download TCP dump'})
      if options.html.logDownloadLink
        - summaryLinks.push({href: '#downloads', label: 'Download log'})
      if options.browsertime.video
        - summaryLinks.push({href: '#downloads', label: 'Download Video'})
      if options.browsertime.chrome && options.browsertime.chrome.timeline
        - summaryLinks.push({href: '#downloads', label: 'Download Chrome trace'})
      if d.browsertime && d.browsertime.har
        - summaryLinks.push({href: '#downloads', label: 'Download HAR'})
      if options.browsertime.chrome && options.browsertime.chrome.collectConsoleLog
        - summaryLinks.push({href: '#downloads', label: 'Download Console Logs'})
      +quicklinks(summaryLinks)

      a#summary

      //- Pull all values once up front so the markup below is just rendering.
      - performanceScore = get(d, 'coach.pageSummary.advice.performance.score')
      - totalTransferSize = get(d, 'pagexray.pageSummary.transferSize')
      - totalContentSize = get(d, 'pagexray.pageSummary.contentSize')
      - memory = get(d, 'browsertime.pageSummary.memory')
      - powerConsumption = get(d, 'browsertime.pageSummary.statistics.powerConsumption.median')
      - requests = get(d, 'pagexray.pageSummary.requests')
      - ttfb = get(d, 'browsertime.pageSummary.statistics.timings.pageTimings.backEndTime.median')
      - firstPaint = get(d, 'browsertime.pageSummary.statistics.timings.firstPaint.median')
      - fullyLoaded = get(d, 'browsertime.pageSummary.statistics.timings.fullyLoaded.median')
      - fcp = get(d, 'browsertime.pageSummary.statistics.timings.paintTiming["first-contentful-paint"].median')
      //- LCP renderTime is 0 for cross-origin images without Timing-Allow-Origin,
      //- so use max(renderTime, loadTime) like the Metrics tab, or it reads as 0.
      - lcp = Math.max(get(d, 'browsertime.pageSummary.statistics.timings.largestContentfulPaint.renderTime.median') || 0, get(d, 'browsertime.pageSummary.statistics.timings.largestContentfulPaint.loadTime.median') || 0) || undefined
      - inp = get(d, 'browsertime.pageSummary.statistics.timings.interactionToNextPaint.median')
      - cls = get(d, 'browsertime.pageSummary.statistics.pageinfo.cumulativeLayoutShift.median')
      - tbt = get(d, 'browsertime.pageSummary.statistics.cpu.longTasks.totalBlockingTime.median')
      - mpFID = get(d, 'browsertime.pageSummary.statistics.cpu.longTasks.maxPotentialFid.median')
      - longTasks = get(d, 'browsertime.pageSummary.statistics.cpu.longTasks.tasks.median')
      - maxLongTask = get(d, 'browsertime.pageSummary.statistics.cpu.longTasks.durations.max')
      - lastLongTask = get(d, 'browsertime.pageSummary.statistics.cpu.longTasks.lastLongTask.median')
      - firstVisualChange = get(d, 'browsertime.pageSummary.statistics.visualMetrics.FirstVisualChange.median')
      - speedIndex = get(d, 'browsertime.pageSummary.statistics.visualMetrics.SpeedIndex.median')
      - visualComplete85 = get(d, 'browsertime.pageSummary.statistics.visualMetrics.VisualComplete85.median')
      - visualComplete99 = get(d, 'browsertime.pageSummary.statistics.visualMetrics.VisualComplete99.median')
      - lastVisualChange = get(d, 'browsertime.pageSummary.statistics.visualMetrics.LastVisualChange.median')
      - cruxFCP = get(d, 'crux.pageSummary.loadingExperience.ALL.data.record.metrics.first_contentful_paint.percentiles.p75')
      - cruxLCP = get(d, 'crux.pageSummary.loadingExperience.ALL.data.record.metrics.largest_contentful_paint.percentiles.p75')
      - cruxFID = get(d, 'crux.pageSummary.loadingExperience.ALL.data.record.metrics.first_input_delay.percentiles.p75')
      - cruxCLS = get(d, 'crux.pageSummary.loadingExperience.ALL.data.record.metrics.cumulative_layout_shift.percentiles.p75')

      include ./_summaryHero.pug

      include ./_summaryCrux.pug

      include ./summaryBox.pug

      #downloads
      .downloads
        include ./downloads.pug
        include ./tcpdump.pug

    if d.browsertime && d.browsertime.har
      section#waterfall-panel
        include ../waterfall/index.pug

    if hasRendering
      section#rendering-panel
        include ../rendering/index.pug

    if d.coach && d.coach.pageSummary
      section#coach-panel
        include ../coach/index.pug

    if d.browsertime && d.browsertime.pageSummary
      section#metrics-panel
        include ../metrics/index.pug

    if d.pagexray && d.pagexray.pageSummary
      section#pagexray-panel
        include ../pagexray/index.pug

    //- Keep in sync with the CPU tab gate in ./tabs.pug — Chrome runs
    //- always get the panel so the --enableProfileRun pointer is
    //- discoverable.
    if options.browser === 'chrome' || options.cpu || options.browsertime && options.browsertime.chrome && options.browsertime.chrome.collectLongTasks || (options.browsertime && options.browsertime.firefox && options.browsertime.firefox.geckoProfiler || options.browsertime && options.browsertime.enableProfileRun)
      section#cpu-panel
        include ../cpu/index.pug  

    if d.thirdparty && d.thirdparty.pageSummary
      section#thirdparty-panel
        include ../thirdparty/index.pug

    each pageSummary in pageSummaries
      - const panelName = pageSummary.id + '-panel'
      section(id=panelName)
        p !{pugs[pageSummary.id]}
