extends ../layout.pug

block content
    - const daTitle = daurlAlias ? daurlAlias : daurl
    h1 Metrics per run
    p.url
        a(href=daurl) #{decodeURIComponent(daTitle)}

    include ../../includes/pageRunInfo

    //- Run navigation: number-only chips, with this side-by-side page
    //- as the highlighted current pill. Keep the #pageNavigation id —
    //- it is the same navigation row as on the summary and run pages.
    nav.run-nav#pageNavigation(aria-label='Runs')
        span.run-nav-label Runs
        ul.run-nav-chips
            each val, index in runPages
                - value = Number(index) + 1
                li
                    a.run-nav-chip(href='./' + value + '.html', aria-label='Run ' + value) #{value}
        span.run-nav-sep
        a.run-nav-link(href='index.html') Summary
        span.run-nav-link.run-nav-link--current(aria-current='page') Side by side

    - const tools = ['browsertime', 'pagexray']
    - const metrics = {};
    - for (let tool of Object.keys(friendlyNames)) {
        - if (tools.indexOf(tool) > -1) {
        -   metrics[tool] = friendlyNames[tool]
    -    }
    - }

    - const categoryNames = {googleWebVitals: "Google Web Vitals", timings: "Timing metrics", cpu: "CPU metrics", browser: 'Browser metrics', pageinfo: "Page metrics", visualMetrics: "Visual Metrics", thirdParty: "Third Party metrics", firstParty: "First Party metrics"}
    - const noCategory = ['requests','transferSize', 'contentSize']
    - const columnCount = runPages.length + 5

    .listing-card
        .listing-card-header
            h3.listing-card-title Side by side
            span.listing-card-meta #{h.plural(runPages.length, 'run')}
        .responsive
            table.timings-table.sidebyside-table
                thead
                    tr
                        th Metric
                        each page, index in runPages
                            th.number Run #{Number(index) + 1}
                        th.number Median
                        th.number Mean
                        th.number Stddev
                        th.number RSD
                tbody
                    each tool in Object.keys(metrics)
                        - let category = ''
                        each metricType in Object.keys(metrics[tool])
                            - if (category !== metricType) {
                                - if (noCategory.indexOf(metricType) === -1) {
                                    - category = metricType
                                    tr
                                        td.extraheader(colspan=columnCount) #{categoryNames[metricType] ? categoryNames[metricType] : h.metricName(metricType)}
                                - } else {
                                    - category = metricType
                                - }
                            - }
                            each metric in Object.keys(metrics[tool][metricType])
                                - const friendly = metrics[tool][metricType][metric]
                                - const m = get(runPages[0], 'data.' + tool + '.run.' + (friendly.runPath || friendly.path), 'notused')
                                if (m !== 'notused')
                                    tr
                                        td(data-title='metric') #{friendly.name}
                                        each page, index in runPages
                                            - const runValue = get(page, 'data.' + tool + '.run.' + (friendly.runPath || friendly.path))
                                            td.number(data-title='run ' + (Number(index) + 1))
                                                a(href='./' + (Number(index) + 1) + '.html', title='Go to run ' + (Number(index) + 1)) #{friendly.format(runValue)}
                                        td.number(data-title='median') #{friendly.format(get(mySummary, 'data.' + tool + '.pageSummary.statistics.' + friendly.runPath + '.median', ''))}
                                        td.number(data-title='mean') #{friendly.format(get(mySummary, 'data.' + tool + '.pageSummary.statistics.' + friendly.runPath + '.mean', ''))}
                                        td.number(data-title='stddev') #{friendly.format(get(mySummary, 'data.' + tool + '.pageSummary.statistics.' + friendly.runPath + '.stddev', ''))}
                                        - const rsd = get(mySummary, 'data.' + tool + '.pageSummary.statistics.' + friendly.runPath + '.rsd', '')
                                        td.number(data-title='rsd') #{rsd !== '' ? Number(rsd).toFixed(2) + ' %' : 'N/A'}
